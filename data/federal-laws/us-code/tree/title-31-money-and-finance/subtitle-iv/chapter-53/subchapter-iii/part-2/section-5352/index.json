{"type":"section","nativeType":"section","number":"5352","heading":"Program authorization","label":"5352 Program authorization","identifier":"/us/usc/t31/s5352","parentIdentifier":"/us/usc/t31/stIV/ch53/schIII/pt2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Grant Eligibility","label":"a .—Grant Eligibility","identifier":"/us/usc/t31/s5352/a","parentIdentifier":"/us/usc/t31/s5352","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Application","label":"1 .—Application","identifier":"/us/usc/t31/s5352/a/1","parentIdentifier":"/us/usc/t31/s5352/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fa%2F1","sourceRelease":"119-100","text":"The State or local law enforcement agency or prosecutor shall submit an application to the Secretary in accordance with section 5353(a)(2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Accountability","label":"2 .—Accountability","identifier":"/us/usc/t31/s5352/a/2","parentIdentifier":"/us/usc/t31/s5352/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t31/s5352/a/2/A","parentIdentifier":"/us/usc/t31/s5352/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fa%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t31/s5352/a/2/A/i","parentIdentifier":"/us/usc/t31/s5352/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fa%2F2%2FA%2Fi","sourceRelease":"119-100","text":"consistent with common indicators and evaluation protocols established by the Secretary, in consultation with the Attorney General; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t31/s5352/a/2/A/ii","parentIdentifier":"/us/usc/t31/s5352/a/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fa%2F2%2FA%2Fii","sourceRelease":"119-100","text":"approved by the Secretary;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t31/s5352/a/2/B","parentIdentifier":"/us/usc/t31/s5352/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fa%2F2%2FB","sourceRelease":"119-100","text":"conduct biennial surveys (or incorporate local surveys in existence at the time of the evaluation) to measure the progress and effectiveness of the coalition; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t31/s5352/a/2/C","parentIdentifier":"/us/usc/t31/s5352/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fa%2F2%2FC","sourceRelease":"119-100","text":"provide assurances that the entity conducting an evaluation under this paragraph, or from which the applicant receives information, has experience in gathering data related to money laundering and related financial crimes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grant Amounts.—","label":"b Grant Amounts.—","identifier":"/us/usc/t31/s5352/b","parentIdentifier":"/us/usc/t31/s5352","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Grants.—","label":"1 Grants.—","identifier":"/us/usc/t31/s5352/b/1","parentIdentifier":"/us/usc/t31/s5352/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t31/s5352/b/1/A","parentIdentifier":"/us/usc/t31/s5352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F1%2FA","sourceRelease":"119-100","text":"Subject to subparagraph (D), for a fiscal year, the Secretary of the Treasury, in consultation with the Attorney General, may grant to an eligible applicant under this section for that fiscal year, an amount determined by the Secretary of the Treasury, in consultation with the Attorney General, to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Suspension of grants","label":"B .—Suspension of grants","identifier":"/us/usc/t31/s5352/b/1/B","parentIdentifier":"/us/usc/t31/s5352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F1%2FB","sourceRelease":"119-100","text":"If such grant recipient fails to continue to meet the criteria specified in subsection (a), the Secretary may suspend the grant, after providing written notice to the grant recipient and an opportunity to appeal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":".—Renewal grants","label":"C .—Renewal grants","identifier":"/us/usc/t31/s5352/b/1/C","parentIdentifier":"/us/usc/t31/s5352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F1%2FC","sourceRelease":"119-100","text":"Subject to subparagraph (D), the Secretary may award a renewal grant to a grant recipient under this subparagraph for each fiscal year following the fiscal year for which an initial grant is awarded.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":".—Limitation","label":"D .—Limitation","identifier":"/us/usc/t31/s5352/b/1/D","parentIdentifier":"/us/usc/t31/s5352/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F1%2FD","sourceRelease":"119-100","text":"The amount of a grant award under this paragraph may not exceed $750,000 for a fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Grant awards.—","label":"2 Grant awards.—","identifier":"/us/usc/t31/s5352/b/2","parentIdentifier":"/us/usc/t31/s5352/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":".—In general","label":"A .—In general","identifier":"/us/usc/t31/s5352/b/2/A","parentIdentifier":"/us/usc/t31/s5352/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Except as provided in subparagraph (B), the Secretary may, with respect to a community, make a grant to one eligible applicant that represents that community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":".—Exception","label":"B .—Exception","identifier":"/us/usc/t31/s5352/b/2/B","parentIdentifier":"/us/usc/t31/s5352/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t31/s5352/b/2/B/i","parentIdentifier":"/us/usc/t31/s5352/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the eligible coalitions demonstrate that the coalitions are collaborating with one another; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t31/s5352/b/2/B/ii","parentIdentifier":"/us/usc/t31/s5352/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"each of the coalitions has independently met the requirements set forth in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Condition Relating to Proceeds of Asset Forfeitures.—","label":"c Condition Relating to Proceeds of Asset Forfeitures.—","identifier":"/us/usc/t31/s5352/c","parentIdentifier":"/us/usc/t31/s5352","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t31/s5352/c/1","parentIdentifier":"/us/usc/t31/s5352/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fc%2F1","sourceRelease":"119-100","text":"No grant may be made or renewed under this part to any State or local law enforcement agency or prosecutor unless the agency or prosecutor agrees to donate to the Secretary of the Treasury for the program established under this part any amount received by such agency or prosecutor (after the grant is made) pursuant to any criminal or civil forfeiture under chapter 46 of title 18, United States Code, or any similar provision of State law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Scope of application","label":"2 .—Scope of application","identifier":"/us/usc/t31/s5352/c/2","parentIdentifier":"/us/usc/t31/s5352/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fc%2F2","sourceRelease":"119-100","text":"Paragraph (1) shall not apply to any amount received by a State or local law enforcement agency or prosecutor pursuant to any criminal or civil forfeiture referred to in such paragraph in excess of the aggregate amount of grants received by such agency or prosecutor under this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Rolling Grant Application Periods","label":"d .—Rolling Grant Application Periods","identifier":"/us/usc/t31/s5352/d","parentIdentifier":"/us/usc/t31/s5352","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t31/s5352/d/1","parentIdentifier":"/us/usc/t31/s5352/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fd%2F1","sourceRelease":"119-100","text":"applications for grants under this part may be filed at any time during a fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t31/s5352/d/2","parentIdentifier":"/us/usc/t31/s5352/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft31%2Fs5352%2Fd%2F2","sourceRelease":"119-100","text":"some portion of the funds appropriated under this part for any such fiscal year will remain available for grant applications filed later in the fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
