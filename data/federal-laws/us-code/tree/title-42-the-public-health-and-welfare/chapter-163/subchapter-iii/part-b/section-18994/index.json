{"type":"section","nativeType":"section","number":"18994","heading":"STEM workforce data","label":"18994 STEM workforce data","identifier":"/us/usc/t42/s18994","parentIdentifier":"/us/usc/t42/ch163/schIII/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Skilled technical workforce portfolio review","label":"a Skilled technical workforce portfolio review","identifier":"/us/usc/t42/s18994/a","parentIdentifier":"/us/usc/t42/s18994","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s18994/a/1","parentIdentifier":"/us/usc/t42/s18994/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fa%2F1","sourceRelease":"119-100","text":"Not later than 1 year after , the Director shall conduct a full portfolio analysis of the Foundation’s skilled technical workforce investments across all Directorates in the areas of education, research, infrastructure, data collection, and analysis.August 9, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t42/s18994/a/2","parentIdentifier":"/us/usc/t42/s18994/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fa%2F2","sourceRelease":"119-100","text":"Not later than 180 days after the date of the review under paragraph (1) is complete, the Director shall submit to Congress and make widely available to the public a summary report of the portfolio review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Survey data","label":"b Survey data","identifier":"/us/usc/t42/s18994/b","parentIdentifier":"/us/usc/t42/s18994","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Rotating topic modules","label":"1 Rotating topic modules","identifier":"/us/usc/t42/s18994/b/1","parentIdentifier":"/us/usc/t42/s18994/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F1","sourceRelease":"119-100","text":"To meet evolving needs for data on the state of the science and engineering workforce, the Director shall assess, through coordination with other Federal statistical agencies and drawing on input from relevant stakeholders, the feasibility and benefits of incorporating questions or topic modules to existing National Center for Science and Engineering Statistics surveys that would vary from cycle to cycle.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"New data","label":"2 New data","identifier":"/us/usc/t42/s18994/b/2","parentIdentifier":"/us/usc/t42/s18994/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18994/b/2/A","parentIdentifier":"/us/usc/t42/s18994/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the skilled technical workforce;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18994/b/2/B","parentIdentifier":"/us/usc/t42/s18994/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F2%2FB","sourceRelease":"119-100","text":"working conditions and work-life balance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s18994/b/2/C","parentIdentifier":"/us/usc/t42/s18994/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F2%2FC","sourceRelease":"119-100","text":"harassment and discrimination;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s18994/b/2/D","parentIdentifier":"/us/usc/t42/s18994/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F2%2FD","sourceRelease":"119-100","text":"immigration and emigration; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s18994/b/2/E","parentIdentifier":"/us/usc/t42/s18994/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F2%2FE","sourceRelease":"119-100","text":"any other topics at the discretion of the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Longitudinal design","label":"3 Longitudinal design","identifier":"/us/usc/t42/s18994/b/3","parentIdentifier":"/us/usc/t42/s18994/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F3","sourceRelease":"119-100","text":"The Director shall continue and accelerate efforts to enhance the usefulness of National Center for Science and Engineering Statistics survey data for longitudinal research and analysis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Government Accountability Office review","label":"4 Government Accountability Office review","identifier":"/us/usc/t42/s18994/b/4","parentIdentifier":"/us/usc/t42/s18994/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s18994/b/4/A","parentIdentifier":"/us/usc/t42/s18994/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F4%2FA","sourceRelease":"119-100","text":"evaluates Foundation processes for ensuring the data and analysis produced by the National Center for Science and Engineering Statistics meets current and future needs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s18994/b/4/B","parentIdentifier":"/us/usc/t42/s18994/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs18994%2Fb%2F4%2FB","sourceRelease":"119-100","text":"includes such recommendations as the Comptroller General determines are appropriate to improve such processes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
