mber":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3507/c/2","parentIdentifier":"/us/usc/t25/s3507/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3507%2Fc%2F2","sourceRelease":"119-100","text":"how the appraisal should be corrected or otherwise cured to meet the applicable standards set forth in the regulations promulgated under subsection (d).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Regulations","label":"d Regulations","identifier":"/us/usc/t25/s3507/d","parentIdentifier":"/us/usc/t25/s3507","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3507%2Fd","sourceRelease":"119-100","text":"The Secretary shall promulgate regulations to carry out this section, including standards the Secretary shall use for approving or disapproving the appraisal described in subsection (a).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
