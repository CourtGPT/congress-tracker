{"type":"section","nativeType":"section","number":"1722","heading":"Sense of Congress","label":"1722 Sense of Congress","identifier":"/us/usc/t47/s1722","parentIdentifier":"/us/usc/t47/ch16/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1722/1","parentIdentifier":"/us/usc/t47/s1722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1722/1/A","parentIdentifier":"/us/usc/t47/s1722/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F1%2FA","sourceRelease":"119-100","text":"participate in the society, economy, and civic institutions of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1722/1/B","parentIdentifier":"/us/usc/t47/s1722/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F1%2FB","sourceRelease":"119-100","text":"access health care and essential services, obtain education, and build careers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1722/2","parentIdentifier":"/us/usc/t47/s1722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t47/s1722/2/A","parentIdentifier":"/us/usc/t47/s1722/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F2%2FA","sourceRelease":"119-100","text":"carries a high societal and economic cost;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t47/s1722/2/B","parentIdentifier":"/us/usc/t47/s1722/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F2%2FB","sourceRelease":"119-100","text":"materially harms the opportunity of an individual with respect to the economic success, educational achievement, positive health outcomes, social inclusion, and civic engagement of that individual; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t47/s1722/2/C","parentIdentifier":"/us/usc/t47/s1722/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F2%2FC","sourceRelease":"119-100","text":"exacerbates existing wealth and income gaps, especially those experienced by covered populations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t47/s1722/3","parentIdentifier":"/us/usc/t47/s1722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F3","sourceRelease":"119-100","text":"achieving digital equity for all people of the United States requires additional and sustained investment and research efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t47/s1722/4","parentIdentifier":"/us/usc/t47/s1722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F4","sourceRelease":"119-100","text":"the Federal Government, as well as State, tribal, territorial, and local governments, have made social, legal, and economic obligations that necessarily extend to how the citizens and residents of those governments access and use the internet; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t47/s1722/5","parentIdentifier":"/us/usc/t47/s1722","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1722%2F5","sourceRelease":"119-100","text":"achieving digital equity is a matter of social and economic justice and is worth pursuing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
