{"type":"section","nativeType":"section","number":"256i","heading":"Community-based collaborative care network program","label":"256i Community-based collaborative care network program","identifier":"/us/usc/t42/s256i","parentIdentifier":"/us/usc/t42/ch6A/schII/ptD/sptxii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s256i/a","parentIdentifier":"/us/usc/t42/s256i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fa","sourceRelease":"119-100","text":"The Secretary may award grants to eligible entities to support community-based collaborative care networks that meet the requirements of subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Community-based collaborative care networks","label":"b Community-based collaborative care networks","identifier":"/us/usc/t42/s256i/b","parentIdentifier":"/us/usc/t42/s256i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Description","label":"1 Description","identifier":"/us/usc/t42/s256i/b/1","parentIdentifier":"/us/usc/t42/s256i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fb%2F1","sourceRelease":"119-100","text":"A community-based collaborative care network (referred to in this section as a “network”) shall be a consortium of health care providers with a joint governance structure (including providers within a single entity) that provides comprehensive coordinated and integrated health care services (as defined by the Secretary) for low-income populations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Required inclusion","label":"2 Required inclusion","identifier":"/us/usc/t42/s256i/b/2","parentIdentifier":"/us/usc/t42/s256i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s256i/b/2/A","parentIdentifier":"/us/usc/t42/s256i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fb%2F2%2FA","sourceRelease":"119-100","text":"A hospital that meets the criteria in ; andsection 1396r–4(b)(1) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s256i/b/2/B","parentIdentifier":"/us/usc/t42/s256i/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fb%2F2%2FB","sourceRelease":"119-100","text":"All Federally qualified health centers (as defined in located in the community.section 1395x(aa) of this title1So in original. A closing parenthesis probably should appear.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Priority","label":"3 Priority","identifier":"/us/usc/t42/s256i/b/3","parentIdentifier":"/us/usc/t42/s256i/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s256i/b/3/A","parentIdentifier":"/us/usc/t42/s256i/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the capability to provide the broadest range of services to low-income individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s256i/b/3/B","parentIdentifier":"/us/usc/t42/s256i/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the broadest range of providers that currently serve a high volume of low-income individuals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s256i/b/3/C","parentIdentifier":"/us/usc/t42/s256i/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fb%2F3%2FC","sourceRelease":"119-100","text":"a county or municipal department of health.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Application","label":"c Application","identifier":"/us/usc/t42/s256i/c","parentIdentifier":"/us/usc/t42/s256i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Application","label":"1 Application","identifier":"/us/usc/t42/s256i/c/1","parentIdentifier":"/us/usc/t42/s256i/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fc%2F1","sourceRelease":"119-100","text":"A network described in subsection (b) shall submit an application to the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Renewal","label":"2 Renewal","identifier":"/us/usc/t42/s256i/c/2","parentIdentifier":"/us/usc/t42/s256i/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fc%2F2","sourceRelease":"119-100","text":"In subsequent years, based on the performance of grantees, the Secretary may provide renewal grants to prior year grant recipients.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Use of funds","label":"d Use of funds","identifier":"/us/usc/t42/s256i/d","parentIdentifier":"/us/usc/t42/s256i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Use by grantees","label":"1 Use by grantees","identifier":"/us/usc/t42/s256i/d/1","parentIdentifier":"/us/usc/t42/s256i/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s256i/d/1/A","parentIdentifier":"/us/usc/t42/s256i/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s256i/d/1/A/i","parentIdentifier":"/us/usc/t42/s256i/d/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1%2FA%2Fi","sourceRelease":"119-100","text":"access and appropriately use health services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s256i/d/1/A/ii","parentIdentifier":"/us/usc/t42/s256i/d/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1%2FA%2Fii","sourceRelease":"119-100","text":"enroll in health coverage programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s256i/d/1/A/iii","parentIdentifier":"/us/usc/t42/s256i/d/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"obtain a regular primary care provider or a medical home.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s256i/d/1/B","parentIdentifier":"/us/usc/t42/s256i/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1%2FB","sourceRelease":"119-100","text":"Provide case management and care management.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s256i/d/1/C","parentIdentifier":"/us/usc/t42/s256i/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1%2FC","sourceRelease":"119-100","text":"Perform health outreach using neighborhood health workers or through other means.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s256i/d/1/D","parentIdentifier":"/us/usc/t42/s256i/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1%2FD","sourceRelease":"119-100","text":"Provide transportation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s256i/d/1/E","parentIdentifier":"/us/usc/t42/s256i/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1%2FE","sourceRelease":"119-100","text":"Expand capacity, including through telehealth, after-hours services or urgent care.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s256i/d/1/F","parentIdentifier":"/us/usc/t42/s256i/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F1%2FF","sourceRelease":"119-100","text":"Provide direct patient care services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Grant funds to HRSA grantees","label":"2 Grant funds to HRSA grantees","identifier":"/us/usc/t42/s256i/d/2","parentIdentifier":"/us/usc/t42/s256i/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fd%2F2","sourceRelease":"119-100","text":"The Secretary may limit the percent of grant funding that may be spent on direct care services provided by grantees of programs administered by the Health Resources and Services Administration or impose other requirements on such grantees deemed necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Authorization of appropriations","label":"e Authorization of appropriations","identifier":"/us/usc/t42/s256i/e","parentIdentifier":"/us/usc/t42/s256i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs256i%2Fe","sourceRelease":"119-100","text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each of fiscal years 2011 through 2015.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
