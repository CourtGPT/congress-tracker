{"type":"section","nativeType":"section","number":"2919","heading":"Department of Defense participation in programs for management of energy demand or reduction of energy usage during peak periods","label":"2919 Department of Defense participation in programs for management of energy demand or reduction of energy usage during peak periods","identifier":"/us/usc/t10/s2919","parentIdentifier":"/us/usc/t10/stA/ptIV/ch173/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Participation in Demand Response or Load Management Programs","label":"a .—Participation in Demand Response or Load Management Programs","identifier":"/us/usc/t10/s2919/a","parentIdentifier":"/us/usc/t10/s2919","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2919/a/1","parentIdentifier":"/us/usc/t10/s2919/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919%2Fa%2F1","sourceRelease":"119-100","text":"An electric utility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2919/a/2","parentIdentifier":"/us/usc/t10/s2919/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919%2Fa%2F2","sourceRelease":"119-100","text":"An independent system operator.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t10/s2919/a/3","parentIdentifier":"/us/usc/t10/s2919/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919%2Fa%2F3","sourceRelease":"119-100","text":"A State agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t10/s2919/a/4","parentIdentifier":"/us/usc/t10/s2919/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919%2Fa%2F4","sourceRelease":"119-100","text":"A third party entity (such as a demand response aggregator or curtailment service provider) implementing demand response programs on behalf of an electric utility, independent system operator, or State agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Treatment of Certain Financial Incentives","label":"b .—Treatment of Certain Financial Incentives","identifier":"/us/usc/t10/s2919/b","parentIdentifier":"/us/usc/t10/s2919","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2919/b/1","parentIdentifier":"/us/usc/t10/s2919/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919%2Fb%2F1","sourceRelease":"119-100","text":"received as a cost reduction in the utility bill for a facility; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2919/b/2","parentIdentifier":"/us/usc/t10/s2919/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919%2Fb%2F2","sourceRelease":"119-100","text":"deposited into the fund established under subsection (c) for use, to the extent provided for in an appropriations Act, by the military department, Defense Agency, or instrumentality receiving such financial incentive for energy management initiatives.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Energy Savings Financial Incentives Fund","label":"c .—Energy Savings Financial Incentives Fund","identifier":"/us/usc/t10/s2919/c","parentIdentifier":"/us/usc/t10/s2919","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2919%2Fc","sourceRelease":"119-100","text":"There is established in the Treasury a fund to be known as the “Energy Savings Financial Incentives Fund”. The Fund shall consist of any amount deposited in the Fund pursuant to subsection (b)(2) and amounts appropriated or otherwise made available to the Fund by law.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
