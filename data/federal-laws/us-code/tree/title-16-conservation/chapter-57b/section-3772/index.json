{"type":"section","nativeType":"section","number":"3772","heading":"Definitions","label":"3772 Definitions","identifier":"/us/usc/t16/s3772","parentIdentifier":"/us/usc/t16/ch57B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Federal trust species","label":"1 Federal trust species","identifier":"/us/usc/t16/s3772/1","parentIdentifier":"/us/usc/t16/s3772","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F1","sourceRelease":"119-100","text":"The term “Federal trust species” means migratory birds, threatened species, endangered species, interjurisdictional fish, marine mammals, and other species of concern.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Habitat enhancement","label":"2 Habitat enhancement","identifier":"/us/usc/t16/s3772/2","parentIdentifier":"/us/usc/t16/s3772","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s3772/2/A","parentIdentifier":"/us/usc/t16/s3772/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FA","sourceRelease":"119-100","text":"The term “habitat enhancement” means the manipulation of the physical, chemical, or biological characteristics of a habitat to change a specific function or seral stage of the habitat.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusions","label":"B Inclusions","identifier":"/us/usc/t16/s3772/2/B","parentIdentifier":"/us/usc/t16/s3772/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s3772/2/B/i","parentIdentifier":"/us/usc/t16/s3772/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3772/2/B/i/I","parentIdentifier":"/us/usc/t16/s3772/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fi%2FI","sourceRelease":"119-100","text":"increasing the hydroperiod and water depth of a stream or wetland beyond what would naturally occur;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3772/2/B/i/II","parentIdentifier":"/us/usc/t16/s3772/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fi%2FII","sourceRelease":"119-100","text":"improving waterfowl habitat conditions;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s3772/2/B/i/III","parentIdentifier":"/us/usc/t16/s3772/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fi%2FIII","sourceRelease":"119-100","text":"establishing water level management capabilities for native plant communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t16/s3772/2/B/i/IV","parentIdentifier":"/us/usc/t16/s3772/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fi%2FIV","sourceRelease":"119-100","text":"creating mud flat conditions important for shorebirds; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"V","heading":null,"label":"V","identifier":"/us/usc/t16/s3772/2/B/i/V","parentIdentifier":"/us/usc/t16/s3772/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fi%2FV","sourceRelease":"119-100","text":"cross fencing or establishing a rotational grazing system on native range to improve grassland nesting bird habitat conditions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s3772/2/B/ii","parentIdentifier":"/us/usc/t16/s3772/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3772/2/B/ii/I","parentIdentifier":"/us/usc/t16/s3772/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fii%2FI","sourceRelease":"119-100","text":"burning an established native grass community to reduce or eliminate invading brush or exotic species;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3772/2/B/ii/II","parentIdentifier":"/us/usc/t16/s3772/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fii%2FII","sourceRelease":"119-100","text":"brush shearing to set back early successional plant communities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s3772/2/B/ii/III","parentIdentifier":"/us/usc/t16/s3772/2/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FB%2Fii%2FIII","sourceRelease":"119-100","text":"forest management that promotes a particular seral stage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Exclusions","label":"C Exclusions","identifier":"/us/usc/t16/s3772/2/C","parentIdentifier":"/us/usc/t16/s3772/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F2%2FC","sourceRelease":"119-100","text":"The term “habitat enhancement” does not include regularly scheduled and routine maintenance and management activities, such as annual mowing or spraying of unwanted vegetation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Habitat establishment","label":"3 Habitat establishment","identifier":"/us/usc/t16/s3772/3","parentIdentifier":"/us/usc/t16/s3772","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s3772/3/A","parentIdentifier":"/us/usc/t16/s3772/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F3%2FA","sourceRelease":"119-100","text":"shallow water impoundments on non-hydric soils; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s3772/3/B","parentIdentifier":"/us/usc/t16/s3772/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F3%2FB","sourceRelease":"119-100","text":"side channel spawning and rearing habitat.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Habitat improvement","label":"4 Habitat improvement","identifier":"/us/usc/t16/s3772/4","parentIdentifier":"/us/usc/t16/s3772","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F4","sourceRelease":"119-100","text":"The term “habitat improvement” means restoring, enhancing, or establishing physiographic, hydrological, or disturbance conditions necessary to establish or maintain native plant and animal communities, including periodic manipulations to maintain intended habitat conditions on completed project sites.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Habitat restoration","label":"5 Habitat restoration","identifier":"/us/usc/t16/s3772/5","parentIdentifier":"/us/usc/t16/s3772","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s3772/5/A","parentIdentifier":"/us/usc/t16/s3772/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FA","sourceRelease":"119-100","text":"The term “habitat restoration” means the manipulation of the physical, chemical, or biological characteristics of a site with the goal of returning the majority of natural functions to the lost or degraded native habitat.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusions","label":"B Inclusions","identifier":"/us/usc/t16/s3772/5/B","parentIdentifier":"/us/usc/t16/s3772/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s3772/5/B/i","parentIdentifier":"/us/usc/t16/s3772/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3772/5/B/i/I","parentIdentifier":"/us/usc/t16/s3772/5/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB%2Fi%2FI","sourceRelease":"119-100","text":"removing tile drains or plugging drainage ditches in former or degraded wetland;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3772/5/B/i/II","parentIdentifier":"/us/usc/t16/s3772/5/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB%2Fi%2FII","sourceRelease":"119-100","text":"returning meanders and sustainable profiles to straightened streams;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t16/s3772/5/B/i/III","parentIdentifier":"/us/usc/t16/s3772/5/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB%2Fi%2FIII","sourceRelease":"119-100","text":"burning grass communities heavily invaded by exotic species to reestablish native grass and plant communities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t16/s3772/5/B/i/IV","parentIdentifier":"/us/usc/t16/s3772/5/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB%2Fi%2FIV","sourceRelease":"119-100","text":"planting plant communities that are native to the project site;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s3772/5/B/ii","parentIdentifier":"/us/usc/t16/s3772/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB%2Fii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t16/s3772/5/B/ii/I","parentIdentifier":"/us/usc/t16/s3772/5/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB%2Fii%2FI","sourceRelease":"119-100","text":"the installation of a water control structure in a swale on land isolated from overbank flooding by a major levee to simulate natural hydrological processes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t16/s3772/5/B/ii/II","parentIdentifier":"/us/usc/t16/s3772/5/B/ii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB%2Fii%2FII","sourceRelease":"119-100","text":"the placement of streambank or instream habitat diversity structures in streams that cannot be restored to original conditions or profile; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s3772/5/B/iii","parentIdentifier":"/us/usc/t16/s3772/5/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F5%2FB%2Fiii","sourceRelease":"119-100","text":"removal of a disturbing or degrading element to enable the native habitat to reestablish or become fully functional.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"Private land","label":"6 Private land","identifier":"/us/usc/t16/s3772/6","parentIdentifier":"/us/usc/t16/s3772","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","label":"A In general","identifier":"/us/usc/t16/s3772/6/A","parentIdentifier":"/us/usc/t16/s3772/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F6%2FA","sourceRelease":"119-100","text":"The term “private land” means any land that is not owned by the Federal Government or a State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Inclusions","label":"B Inclusions","identifier":"/us/usc/t16/s3772/6/B","parentIdentifier":"/us/usc/t16/s3772/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F6%2FB","sourceRelease":"119-100","text":"The term “private land” includes tribal land and Hawaiian homeland.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Project","label":"7 Project","identifier":"/us/usc/t16/s3772/7","parentIdentifier":"/us/usc/t16/s3772","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F7","sourceRelease":"119-100","text":"The term “project” means a project carried out under the Partners for Fish and Wildlife Program established by .section 3773 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Secretary","label":"8 Secretary","identifier":"/us/usc/t16/s3772/8","parentIdentifier":"/us/usc/t16/s3772","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs3772%2F8","sourceRelease":"119-100","text":"The term “Secretary” means the Secretary of the Interior.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
