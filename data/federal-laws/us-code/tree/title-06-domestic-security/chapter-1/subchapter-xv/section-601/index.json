l?req=%2Fus%2Fusc%2Ft6%2Fs601%2F3%2FI","sourceRelease":"119-100","text":"Energy.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t6/s601/3/J","parentIdentifier":"/us/usc/t6/s601/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F3%2FJ","sourceRelease":"119-100","text":"Government facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"K","heading":null,"label":"K","identifier":"/us/usc/t6/s601/3/K","parentIdentifier":"/us/usc/t6/s601/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F3%2FK","sourceRelease":"119-100","text":"Information technology.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"L","heading":null,"label":"L","identifier":"/us/usc/t6/s601/3/L","parentIdentifier":"/us/usc/t6/s601/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F3%2FL","sourceRelease":"119-100","text":"National monuments and icons.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"M","heading":null,"label":"M","identifier":"/us/usc/t6/s601/3/M","parentIdentifier":"/us/usc/t6/s601/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F3%2FM","sourceRelease":"119-100","text":"Postal and shipping.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"N","heading":null,"label":"N","identifier":"/us/usc/t6/s601/3/N","parentIdentifier":"/us/usc/t6/s601/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F3%2FN","sourceRelease":"119-100","text":"Public health and health care.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"O","heading":null,"label":"O","identifier":"/us/usc/t6/s601/3/O","parentIdentifier":"/us/usc/t6/s601/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F3%2FO","sourceRelease":"119-100","text":"Telecommunications.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"P","heading":null,"label":"P","identifier":"/us/usc/t6/s601/3/P","parentIdentifier":"/us/usc/t6/s601/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F3%2FP","sourceRelease":"119-100","text":"Transportation systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"Q","heading":null,"label":"Q","identifier":"/us/usc/t6/s601/3/Q","parentIdentifier":"/us/usc/t6/s601/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F3%2FQ","sourceRelease":"119-100","text":"Water.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Directly eligible tribe","label":"4 Directly eligible tribe","identifier":"/us/usc/t6/s601/4","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s601/4/A","parentIdentifier":"/us/usc/t6/s601/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t6/s601/4/A/i","parentIdentifier":"/us/usc/t6/s601/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FA%2Fi","sourceRelease":"119-100","text":"that is located in the continental United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t6/s601/4/A/ii","parentIdentifier":"/us/usc/t6/s601/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FA%2Fii","sourceRelease":"119-100","text":"that operates a law enforcement or emergency response agency with the capacity to respond to calls for law enforcement or emergency services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t6/s601/4/A/iii","parentIdentifier":"/us/usc/t6/s601/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FA%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t6/s601/4/A/iii/I","parentIdentifier":"/us/usc/t6/s601/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FA%2Fiii%2FI","sourceRelease":"119-100","text":"that is located on or near an international border or a coastline bordering an ocean (including the Gulf of Mexico) or international waters;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t6/s601/4/A/iii/II","parentIdentifier":"/us/usc/t6/s601/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FA%2Fiii%2FII","sourceRelease":"119-100","text":"that is located within 10 miles of a system or asset included on the prioritized critical infrastructure list established under or has such a system or asset within its territory;section 664(a)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t6/s601/4/A/iii/III","parentIdentifier":"/us/usc/t6/s601/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FA%2Fiii%2FIII","sourceRelease":"119-100","text":"that is located within or contiguous to 1 of the 50 most populous metropolitan statistical areas in the United States; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t6/s601/4/A/iii/IV","parentIdentifier":"/us/usc/t6/s601/4/A/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FA%2Fiii%2FIV","sourceRelease":"119-100","text":"the jurisdiction of which includes not less than 1,000 square miles of Indian country, as that term is defined in ; andsection 1151 of title 18","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t6/s601/4/A/iv","parentIdentifier":"/us/usc/t6/s601/4/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FA%2Fiv","sourceRelease":"119-100","text":"that certifies to the Secretary that a State has not provided funds under section 604 or 605 of this title to the Indian tribe or consortium of Indian tribes for the purpose for which direct funding is sought; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s601/4/B","parentIdentifier":"/us/usc/t6/s601/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F4%2FB","sourceRelease":"119-100","text":"a consortium of Indian tribes, if each tribe satisfies the requirements of subparagraph (A).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"Eligible metropolitan area","label":"5 Eligible metropolitan area","identifier":"/us/usc/t6/s601/5","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F5","sourceRelease":"119-100","text":"The term “eligible metropolitan area” means any of the 100 most populous metropolitan statistical areas in the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":"High-risk urban area","label":"6 High-risk urban area","identifier":"/us/usc/t6/s601/6","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F6","sourceRelease":"119-100","text":"The term “high-risk urban area” means a high-risk urban area designated under .section 604(b)(3)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":"Indian tribe","label":"7 Indian tribe","identifier":"/us/usc/t6/s601/7","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F7","sourceRelease":"119-100","text":"The term “Indian tribe” has the meaning given that term in .section 5304(e) of title 25","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":"Metropolitan statistical area","label":"8 Metropolitan statistical area","identifier":"/us/usc/t6/s601/8","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F8","sourceRelease":"119-100","text":"The term “metropolitan statistical area” means a metropolitan statistical area, as defined by the Office of Management and Budget.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":"National Special Security Event","label":"9 National Special Security Event","identifier":"/us/usc/t6/s601/9","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F9","sourceRelease":"119-100","text":"The term “National Special Security Event” means a designated event that, by virtue of its political, economic, social, or religious significance, may be the target of terrorism or other criminal activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":"Population","label":"10 Population","identifier":"/us/usc/t6/s601/10","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F10","sourceRelease":"119-100","text":"The term “population” means population according to the most recent United States census population estimates available at the start of the relevant fiscal year.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":"Population density","label":"11 Population density","identifier":"/us/usc/t6/s601/11","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F11","sourceRelease":"119-100","text":"The term “population density” means population divided by land area in square miles.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":"Qualified intelligence analyst","label":"12 Qualified intelligence analyst","identifier":"/us/usc/t6/s601/12","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F12","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s601/12/A","parentIdentifier":"/us/usc/t6/s601/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F12%2FA","sourceRelease":"119-100","text":"who has successfully completed training to ensure baseline proficiency in intelligence analysis and production, as determined by the Secretary, which may include training using a curriculum developed under ; orsection 124f of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s601/12/B","parentIdentifier":"/us/usc/t6/s601/12","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F12%2FB","sourceRelease":"119-100","text":"whose experience ensures baseline proficiency in intelligence analysis and production equivalent to the training required under subparagraph (A), as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"13","heading":"Target capabilities","label":"13 Target capabilities","identifier":"/us/usc/t6/s601/13","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F13","sourceRelease":"119-100","text":"The term “target capabilities” means the target capabilities for Federal, State, local, and tribal government preparedness for which guidelines are required to be established under .section 746(a) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"14","heading":"Tribal government","label":"14 Tribal government","identifier":"/us/usc/t6/s601/14","parentIdentifier":"/us/usc/t6/s601","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs601%2F14","sourceRelease":"119-100","text":"The term “tribal government” means the government of an Indian tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
