{"type":"section","nativeType":"section","number":"1161e","heading":"American history for freedom","label":"1161e American history for freedom","identifier":"/us/usc/t20/s1161e","parentIdentifier":"/us/usc/t20/ch28/schIX/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Grants authorized","label":"a Grants authorized","identifier":"/us/usc/t20/s1161e/a","parentIdentifier":"/us/usc/t20/s1161e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1161e/a/1","parentIdentifier":"/us/usc/t20/s1161e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fa%2F1","sourceRelease":"119-100","text":"traditional American history;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1161e/a/2","parentIdentifier":"/us/usc/t20/s1161e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fa%2F2","sourceRelease":"119-100","text":"the history and nature of, and threats to, free institutions; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1161e/a/3","parentIdentifier":"/us/usc/t20/s1161e/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fa%2F3","sourceRelease":"119-100","text":"the history and achievements of Western civilization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Definitions","label":"b Definitions","identifier":"/us/usc/t20/s1161e/b","parentIdentifier":"/us/usc/t20/s1161e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible institution","label":"1 Eligible institution","identifier":"/us/usc/t20/s1161e/b/1","parentIdentifier":"/us/usc/t20/s1161e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fb%2F1","sourceRelease":"119-100","text":"The term “eligible institution” means an institution of higher education as defined in .section 1001 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Free institution","label":"2 Free institution","identifier":"/us/usc/t20/s1161e/b/2","parentIdentifier":"/us/usc/t20/s1161e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fb%2F2","sourceRelease":"119-100","text":"The term “free institution” means an institution that emerged out of Western civilization, such as democracy, constitutional government, individual rights, market economics, religious freedom and religious tolerance, and freedom of thought and inquiry.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Traditional American history","label":"3 Traditional American history","identifier":"/us/usc/t20/s1161e/b/3","parentIdentifier":"/us/usc/t20/s1161e/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161e/b/3/A","parentIdentifier":"/us/usc/t20/s1161e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fb%2F3%2FA","sourceRelease":"119-100","text":"the significant constitutional, political, intellectual, economic, and foreign policy trends and issues that have shaped the course of American history; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161e/b/3/B","parentIdentifier":"/us/usc/t20/s1161e/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fb%2F3%2FB","sourceRelease":"119-100","text":"the key episodes, turning points, and leading figures involved in the constitutional, political, intellectual, diplomatic, and economic history of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Application","label":"c Application","identifier":"/us/usc/t20/s1161e/c","parentIdentifier":"/us/usc/t20/s1161e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s1161e/c/1","parentIdentifier":"/us/usc/t20/s1161e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fc%2F1","sourceRelease":"119-100","text":"Each eligible institution that desires a grant under this section shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may reasonably require.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Contents","label":"2 Contents","identifier":"/us/usc/t20/s1161e/c/2","parentIdentifier":"/us/usc/t20/s1161e/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161e/c/2/A","parentIdentifier":"/us/usc/t20/s1161e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fc%2F2%2FA","sourceRelease":"119-100","text":"how funds made available under this section will be used for the activities set forth under subsection (e), including how such activities will increase knowledge with respect to traditional American history, free institutions, or Western civilization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s1161e/c/2/B","parentIdentifier":"/us/usc/t20/s1161e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fc%2F2%2FB","sourceRelease":"119-100","text":"how the eligible institution will ensure that information about the activities funded under this section is widely disseminated pursuant to subsection (e)(1)(B);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s1161e/c/2/C","parentIdentifier":"/us/usc/t20/s1161e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fc%2F2%2FC","sourceRelease":"119-100","text":"any activities to be undertaken pursuant to subsection (e)(2)(A), including identification of entities intended to participate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s1161e/c/2/D","parentIdentifier":"/us/usc/t20/s1161e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fc%2F2%2FD","sourceRelease":"119-100","text":"how funds made available under this section shall be used to supplement and not supplant non-Federal funds available for the activities described in subsection (e); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s1161e/c/2/E","parentIdentifier":"/us/usc/t20/s1161e/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fc%2F2%2FE","sourceRelease":"119-100","text":"such fiscal controls and accounting procedures as may be necessary to ensure proper disbursement of and accounting for funding made available to the eligible institution under this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Award basis","label":"d Award basis","identifier":"/us/usc/t20/s1161e/d","parentIdentifier":"/us/usc/t20/s1161e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s1161e/d/1","parentIdentifier":"/us/usc/t20/s1161e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fd%2F1","sourceRelease":"119-100","text":"increase access to quality programming that expands knowledge of traditional American history, free institutions, or Western civilization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s1161e/d/2","parentIdentifier":"/us/usc/t20/s1161e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fd%2F2","sourceRelease":"119-100","text":"involve personnel with strong expertise in traditional American history, free institutions, or Western civilization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s1161e/d/3","parentIdentifier":"/us/usc/t20/s1161e/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fd%2F3","sourceRelease":"119-100","text":"sustain the activities funded under this section after the grant has expired.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Use of funds","label":"e Use of funds","identifier":"/us/usc/t20/s1161e/e","parentIdentifier":"/us/usc/t20/s1161e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Required use of funds","label":"1 Required use of funds","identifier":"/us/usc/t20/s1161e/e/1","parentIdentifier":"/us/usc/t20/s1161e/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s1161e/e/1/A","parentIdentifier":"/us/usc/t20/s1161e/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs1161e%2Fe%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifie