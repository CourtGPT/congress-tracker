{"type":"section","nativeType":"section","number":"2502","heading":"Outreach to employers and labor unions","label":"2502 Outreach to employers and labor unions","identifier":"/us/usc/t29/s2502","parentIdentifier":"/us/usc/t29/ch27","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2502","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t29/s2502/a","parentIdentifier":"/us/usc/t29/s2502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2502%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t29/s2502/a/1","parentIdentifier":"/us/usc/t29/s2502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2502%2Fa%2F1","sourceRelease":"119-100","text":"Under such program the Secretary shall provide outreach to employers through, but not limited to, the private industry councils in each service delivery area.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t29/s2502/a/2","parentIdentifier":"/us/usc/t29/s2502/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2502%2Fa%2F2","sourceRelease":"119-100","text":"The Secretary shall provide outreach to labor unions through, but not limited to, the building trade councils, joint apprenticeable occupations councils, and individual labor unions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Priority","label":"b Priority","identifier":"/us/usc/t29/s2502/b","parentIdentifier":"/us/usc/t29/s2502","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft29%2Fs2502%2Fb","sourceRelease":"119-100","text":"The Secretary shall give priority to providing outreach to employers located in areas that have nontraditional employment and training programs specifically targeted to women.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
