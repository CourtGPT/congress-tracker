{"type":"section","nativeType":"section","number":"7108","heading":"Definitions","label":"7108 Definitions","identifier":"/us/usc/t15/s7108","parentIdentifier":"/us/usc/t15/ch97","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s7108/1","parentIdentifier":"/us/usc/t15/s7108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F1","sourceRelease":"119-100","text":"the term “Administration” means the Small Business Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s7108/2","parentIdentifier":"/us/usc/t15/s7108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F2","sourceRelease":"119-100","text":"the term “Administrator” means the Administrator of the Small Business Administration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s7108/3","parentIdentifier":"/us/usc/t15/s7108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F3","sourceRelease":"119-100","text":"the term “control” means exercising the power to make policy decisions concerning a business;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s7108/4","parentIdentifier":"/us/usc/t15/s7108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F4","sourceRelease":"119-100","text":"the term “Council” means the National Women’s Business Council, established under ;section 7105 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s7108/5","parentIdentifier":"/us/usc/t15/s7108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F5","sourceRelease":"119-100","text":"the term “Interagency Committee” means the Interagency Committee on Women’s Business Enterprise, established under ;section 7101 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t15/s7108/6","parentIdentifier":"/us/usc/t15/s7108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F6","sourceRelease":"119-100","text":"the term “operate” means being actively involved in the day-to-day management of a business;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t15/s7108/7","parentIdentifier":"/us/usc/t15/s7108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7108/7/A","parentIdentifier":"/us/usc/t15/s7108/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F7%2FA","sourceRelease":"119-100","text":"a business or businesses owned by a woman or a group of women; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7108/7/B","parentIdentifier":"/us/usc/t15/s7108/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F7%2FB","sourceRelease":"119-100","text":"the establishment, maintenance, or development of a business or businesses by a woman or a group of women; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t15/s7108/8","parentIdentifier":"/us/usc/t15/s7108","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F8","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s7108/8/A","parentIdentifier":"/us/usc/t15/s7108/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F8%2FA","sourceRelease":"119-100","text":"control and operate; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s7108/8/B","parentIdentifier":"/us/usc/t15/s7108/8","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs7108%2F8%2FB","sourceRelease":"119-100","text":"own not less than 51 percent of the business.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
