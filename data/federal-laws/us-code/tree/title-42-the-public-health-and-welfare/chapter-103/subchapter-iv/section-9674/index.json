{"type":"section","nativeType":"section","number":"9674","heading":"Purchasing groups","label":"9674 Purchasing groups","identifier":"/us/usc/t42/s9674","parentIdentifier":"/us/usc/t42/ch103/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Exemption","label":"a Exemption","identifier":"/us/usc/t42/s9674/a","parentIdentifier":"/us/usc/t42/s9674","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s9674/a/1","parentIdentifier":"/us/usc/t42/s9674/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fa%2F1","sourceRelease":"119-100","text":"A State law, rule, or order which prohibits the establishment of a purchasing group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s9674/a/2","parentIdentifier":"/us/usc/t42/s9674/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fa%2F2","sourceRelease":"119-100","text":"A State law, rule, or order which makes it unlawful for an insurer to provide or offer to provide insurance on a basis providing, to a purchasing group or its member, advantages, based on their loss and expense experience, not afforded to other persons with respect to rates, policy forms, coverages, or other matters.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s9674/a/3","parentIdentifier":"/us/usc/t42/s9674/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fa%2F3","sourceRelease":"119-100","text":"A State law, rule, or order which prohibits a purchasing group or its members from purchasing insurance on the group basis described in paragraph (2) of this subsection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s9674/a/4","parentIdentifier":"/us/usc/t42/s9674/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fa%2F4","sourceRelease":"119-100","text":"A State law, rule, or order which prohibits a purchasing group from obtaining insurance on a group basis because the group has not been in existence for a minimum period of time or because any member has not belonged to the group for a minimum period of time.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s9674/a/5","parentIdentifier":"/us/usc/t42/s9674/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fa%2F5","sourceRelease":"119-100","text":"A State law, rule, or order which requires that a purchasing group must have a minimum number of members, common ownership or affiliation, or a certain legal form.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s9674/a/6","parentIdentifier":"/us/usc/t42/s9674/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fa%2F6","sourceRelease":"119-100","text":"A State law, rule, or order which requires that a certain percentage of a purchasing group must obtain insurance on a group basis.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s9674/a/7","parentIdentifier":"/us/usc/t42/s9674/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fa%2F7","sourceRelease":"119-100","text":"A State law, rule, or order which requires that any insurance policy issued to a purchasing group or any members of the group be countersigned by an insurance agent or broker residing in that State.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s9674/a/8","parentIdentifier":"/us/usc/t42/s9674/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fa%2F8","sourceRelease":"119-100","text":"A State law, rule, or order which otherwise discriminate against a purchasing group or any of its members.1So in original. Probably should be “discriminates”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Application of exemptions","label":"b Application of exemptions","identifier":"/us/usc/t42/s9674/b","parentIdentifier":"/us/usc/t42/s9674","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s9674/b/1","parentIdentifier":"/us/usc/t42/s9674/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s9674/b/1/A","parentIdentifier":"/us/usc/t42/s9674/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fb%2F1%2FA","sourceRelease":"119-100","text":"a purchasing group; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s9674/b/1/B","parentIdentifier":"/us/usc/t42/s9674/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fb%2F1%2FB","sourceRelease":"119-100","text":"any person who is a member of a purchasing group.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s9674/b/2","parentIdentifier":"/us/usc/t42/s9674/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s9674/b/2/A","parentIdentifier":"/us/usc/t42/s9674/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Pollution liability insurance and comprehensive general liability coverage.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s9674/b/2/B","parentIdentifier":"/us/usc/t42/s9674/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fb%2F2%2FB","sourceRelease":"119-100","text":"Insurance related services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s9674/b/2/C","parentIdentifier":"/us/usc/t42/s9674/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fb%2F2%2FC","sourceRelease":"119-100","text":"Management services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Agents or brokers","label":"c Agents or brokers","identifier":"/us/usc/t42/s9674/c","parentIdentifier":"/us/usc/t42/s9674","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs9674%2Fc","sourceRelease":"119-100","text":"A State may require that a person acting, or offering to act, as an agent or broker for a purchasing group obtain a license from that State, except that a State may not impose any qualification or requirement which discriminates against a nonresident agent or broker.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
