ssary to support aquatic, riparian, and terrestrial species and communities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Management","label":"c Management","identifier":"/us/usc/t16/s460zzz–1/c","parentIdentifier":"/us/usc/t16/s460zzz–1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%931%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t16/s460zzz–1/c/1","parentIdentifier":"/us/usc/t16/s460zzz–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%931%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s460zzz–1/c/1/A","parentIdentifier":"/us/usc/t16/s460zzz–1/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%931%2Fc%2F1%2FA","sourceRelease":"119-100","text":"as a component of the National Landscape Conservation System;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s460zzz–1/c/1/B","parentIdentifier":"/us/usc/t16/s460zzz–1/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%931%2Fc%2F1%2FB","sourceRelease":"119-100","text":"in a manner that conserves, protects, and enhances the resources and values of the Conservation Area described in subsection (b); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s460zzz–1/c/1/C","parentIdentifier":"/us/usc/t16/s460zzz–1/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%931%2Fc%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t16/s460zzz–1/c/1/C/i","parentIdentifier":"/us/usc/t16/s460zzz–1/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%931%2Fc%2F1%2FC%2Fi","sourceRelease":"119-100","text":"the Federal Land Policy and Management Act of 1976 ( et seq.);43 U.S.C. 1701","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t16/s460zzz–1/c/1/C/ii","parentIdentifier":"/us/usc/t16/s460zzz–1/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%931%2Fc%2F1%2FC%2Fii","sourceRelease":"119-100","text":"this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t16/s460zzz–1/c/1/C/iii","parentIdentifier":"/us/usc/t16/s460zzz–1/c/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%931%2Fc%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"any other applicable laws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Uses","label":"2 Uses","identifier":"/us/usc/t16/s460zzz–1/c/2","parentIdentifier":"/us/usc/t16/s460zzz–1/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs460zzz%E2%80%931%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"In general","