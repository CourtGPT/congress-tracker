{"type":"section","nativeType":"section","number":"6706","heading":"Monitoring and evaluation","label":"6706 Monitoring and evaluation","identifier":"/us/usc/t16/s6706","parentIdentifier":"/us/usc/t16/ch86","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Change of NameCommittee on Resources of House of Representatives changed to Committee on Natural Resources of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, .Jan. 5, 2007"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t16/s6706/a","parentIdentifier":"/us/usc/t16/s6706","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t16/s6706/a/1","parentIdentifier":"/us/usc/t16/s6706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t16/s6706/a/1/A","parentIdentifier":"/us/usc/t16/s6706/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fa%2F1%2FA","sourceRelease":"119-100","text":"implementing active adaptive ecosystem management practices at the landscape level;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t16/s6706/a/1/B","parentIdentifier":"/us/usc/t16/s6706/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fa%2F1%2FB","sourceRelease":"119-100","text":"reducing unnecessary planning costs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t16/s6706/a/1/C","parentIdentifier":"/us/usc/t16/s6706/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fa%2F1%2FC","sourceRelease":"119-100","text":"avoiding duplicative and conflicting efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t16/s6706/a/1/D","parentIdentifier":"/us/usc/t16/s6706/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fa%2F1%2FD","sourceRelease":"119-100","text":"increasing public acceptance of active adaptive ecosystem management practices; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t16/s6706/a/1/E","parentIdentifier":"/us/usc/t16/s6706/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fa%2F1%2FE","sourceRelease":"119-100","text":"achieving general satisfaction on the part of affected entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t16/s6706/a/2","parentIdentifier":"/us/usc/t16/s6706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fa%2F2","sourceRelease":"119-100","text":"to determine the extent to which each Institute has implemented its duties under ; andsection 6704(c) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t16/s6706/a/3","parentIdentifier":"/us/usc/t16/s6706/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fa%2F3","sourceRelease":"119-100","text":"to determine whether continued provision of Federal assistance to each Institute is warranted.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Termination of assistance","label":"b Termination of assistance","identifier":"/us/usc/t16/s6706/b","parentIdentifier":"/us/usc/t16/s6706","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft16%2Fs6706%2Fb","sourceRelease":"119-100","text":"If, as a result of an evaluation under subsection (a), the Secretary, in consultation with the Secretary of the Interior, determines that an Institute does not qualify for further Federal assistance under this chapter, the Institute shall receive no further Federal assistance under this chapter until such time as the qualifications of the Institute are reestablished to the satisfaction of the Secretaries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
