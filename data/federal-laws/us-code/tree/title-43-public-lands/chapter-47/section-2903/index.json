{"type":"section","nativeType":"section","number":"2903","heading":"Authorization of transfers of title to eligible facilities","label":"2903 Authorization of transfers of title to eligible facilities","identifier":"/us/usc/t43/s2903","parentIdentifier":"/us/usc/t43/ch47","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorization","label":"a Authorization","identifier":"/us/usc/t43/s2903/a","parentIdentifier":"/us/usc/t43/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t43/s2903/a/1","parentIdentifier":"/us/usc/t43/s2903/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2903/a/1/A","parentIdentifier":"/us/usc/t43/s2903/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t43/s2903/a/1/A/i","parentIdentifier":"/us/usc/t43/s2903/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"a written notice of the proposed conveyance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t43/s2903/a/1/A/ii","parentIdentifier":"/us/usc/t43/s2903/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"a description of the reasons for the conveyance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2903/a/1/B","parentIdentifier":"/us/usc/t43/s2903/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fa%2F1%2FB","sourceRelease":"119-100","text":"a joint resolution disapproving the conveyance is not enacted before the date on which the Secretary makes the conveyance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Consultation","label":"2 Consultation","identifier":"/us/usc/t43/s2903/a/2","parentIdentifier":"/us/usc/t43/s2903/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fa%2F2","sourceRelease":"119-100","text":"A conveyance under paragraph (1) shall be made by written agreement between the Secretary and the qualifying entity, developed in consultation with any existing water and power customers affected by the conveyance of the eligible facility.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reservation of easement","label":"b Reservation of easement","identifier":"/us/usc/t43/s2903/b","parentIdentifier":"/us/usc/t43/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2903/b/1","parentIdentifier":"/us/usc/t43/s2903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fb%2F1","sourceRelease":"119-100","text":"the Secretary determines that the easement is necessary for the management of any interests retained by the Federal Government under this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2903/b/2","parentIdentifier":"/us/usc/t43/s2903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fb%2F2","sourceRelease":"119-100","text":"the Reclamation project or a portion of the Reclamation project remains under Federal ownership; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2903/b/3","parentIdentifier":"/us/usc/t43/s2903/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fb%2F3","sourceRelease":"119-100","text":"the Secretary enters into an agreement regarding the easement with the applicable qualifying entity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Interests in water","label":"c Interests in water","identifier":"/us/usc/t43/s2903/c","parentIdentifier":"/us/usc/t43/s2903","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2903%2Fc","sourceRelease":"119-100","text":"No interests in water shall be conveyed under this chapter unless the conveyance is provided for in a separate, quantified agreement between the Secretary and the qualifying entity, subject to applicable State law and public process requirements.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
