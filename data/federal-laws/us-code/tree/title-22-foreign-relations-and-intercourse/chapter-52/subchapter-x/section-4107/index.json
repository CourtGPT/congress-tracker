{"type":"section","nativeType":"section","number":"4107","heading":"Functions of Foreign Service Labor Relations Board","label":"4107 Functions of Foreign Service Labor Relations Board","identifier":"/us/usc/t22/s4107","parentIdentifier":"/us/usc/t22/ch52/schX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"General provisions","label":"a General provisions","identifier":"/us/usc/t22/s4107/a","parentIdentifier":"/us/usc/t22/s4107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4107/a/1","parentIdentifier":"/us/usc/t22/s4107/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fa%2F1","sourceRelease":"119-100","text":"supervise or conduct elections and determine whether a labor organization has been selected as the exclusive representative by a majority of employees who cast valid ballots and otherwise administer the provisions of this subchapter relating to the according of exclusive recognition to a labor organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4107/a/2","parentIdentifier":"/us/usc/t22/s4107/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fa%2F2","sourceRelease":"119-100","text":"resolve complaints of alleged unfair labor practices;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s4107/a/3","parentIdentifier":"/us/usc/t22/s4107/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fa%2F3","sourceRelease":"119-100","text":"resolve issues relating to the obligation to bargain in good faith;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s4107/a/4","parentIdentifier":"/us/usc/t22/s4107/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fa%2F4","sourceRelease":"119-100","text":"resolve disputes concerning the effect, the interpretation, or a claim of breach of a collective bargaining agreement, in accordance with ; andsection 4114 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s4107/a/5","parentIdentifier":"/us/usc/t22/s4107/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fa%2F5","sourceRelease":"119-100","text":"take any action considered necessary to administer effectively the provisions of this subchapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Consistency or precedence of decisions under other provisions of law","label":"b Consistency or precedence of decisions under other provisions of law","identifier":"/us/usc/t22/s4107/b","parentIdentifier":"/us/usc/t22/s4107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fb","sourceRelease":"119-100","text":"Decisions of the Board under this subchapter shall be consistent with decisions rendered by the Authority under chapter 71 of title 5, other than in cases in which the Board finds that special circumstances require otherwise. Decisions of the Board under this subchapter shall not be construed as precedent by the Authority, or any court or other authority, for any decision under chapter 71 of title 5.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Implementation","label":"c Implementation","identifier":"/us/usc/t22/s4107/c","parentIdentifier":"/us/usc/t22/s4107","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4107/c/1","parentIdentifier":"/us/usc/t22/s4107/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fc%2F1","sourceRelease":"119-100","text":"the Board shall by regulation adopt procedures to apply in the administration of this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4107/c/2","parentIdentifier":"/us/usc/t22/s4107/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s4107/c/2/A","parentIdentifier":"/us/usc/t22/s4107/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fc%2F2%2FA","sourceRelease":"119-100","text":"adopt other regulations concerning its functions under this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s4107/c/2/B","parentIdentifier":"/us/usc/t22/s4107/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fc%2F2%2FB","sourceRelease":"119-100","text":"conduct appropriate inquiries wherever persons subject to this subchapter are located;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s4107/c/2/C","parentIdentifier":"/us/usc/t22/s4107/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fc%2F2%2FC","sourceRelease":"119-100","text":"hold hearings;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s4107/c/2/D","parentIdentifier":"/us/usc/t22/s4107/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fc%2F2%2FD","sourceRelease":"119-100","text":"administer oaths, take the testimony or deposition of any individual under oath, and issue subpenas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t22/s4107/c/2/E","parentIdentifier":"/us/usc/t22/s4107/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fc%2F2%2FE","sourceRelease":"119-100","text":"require the Department or a labor organization to cease and desist from violations of this subchapter and require it to take any remedial action the Board considers appropriate to carry out this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t22/s4107/c/2/F","parentIdentifier":"/us/usc/t22/s4107/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4107%2Fc%2F2%2FF","sourceRelease":"119-100","text":"consistent with the provisions of this subchapter, exercise the functions the Authority has under chapter 71 of title 5 to the same extent and in the same manner as is the case with respect to persons subject to chapter 71 of such title.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
