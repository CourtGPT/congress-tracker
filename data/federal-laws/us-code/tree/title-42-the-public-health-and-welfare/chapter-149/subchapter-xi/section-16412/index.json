{"type":"section","nativeType":"section","number":"16412","heading":"Training guidelines for nonnuclear electric energy industry personnel","label":"16412 Training guidelines for nonnuclear electric energy industry personnel","identifier":"/us/usc/t42/s16412","parentIdentifier":"/us/usc/t42/ch149/schXI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t42/s16412/a","parentIdentifier":"/us/usc/t42/s16412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fa","sourceRelease":"119-100","text":"The Secretary of Labor, in consultation with the Secretary and in conjunction with the electric industry and recognized employee representatives, shall develop model personnel training guidelines to support the reliability and safety of the nonnuclear electric system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Requirements","label":"b Requirements","identifier":"/us/usc/t42/s16412/b","parentIdentifier":"/us/usc/t42/s16412","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s16412/b/1","parentIdentifier":"/us/usc/t42/s16412/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16412/b/1/A","parentIdentifier":"/us/usc/t42/s16412/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fb%2F1%2FA","sourceRelease":"119-100","text":"competency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16412/b/1/B","parentIdentifier":"/us/usc/t42/s16412/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fb%2F1%2FB","sourceRelease":"119-100","text":"certification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16412/b/1/C","parentIdentifier":"/us/usc/t42/s16412/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fb%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s16412/b/1/C/i","parentIdentifier":"/us/usc/t42/s16412/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fb%2F1%2FC%2Fi","sourceRelease":"119-100","text":"initial and continuous evaluation of workers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s16412/b/1/C/ii","parentIdentifier":"/us/usc/t42/s16412/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fb%2F1%2FC%2Fii","sourceRelease":"119-100","text":"recertification procedures; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s16412/b/1/C/iii","parentIdentifier":"/us/usc/t42/s16412/b/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fb%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"methods for examining or testing the qualification of an individual who performs a covered task; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s16412/b/2","parentIdentifier":"/us/usc/t42/s16412/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16412%2Fb%2F2","sourceRelease":"119-100","text":"consolidate training guidelines in existence on the date on which the guidelines under subsection (a) are developed relating to the construction, operation, maintenance, and inspection of nonnuclear electric generation, transmission, and distribution facilities, such as guidelines established by the National Electric Safety Code and other industry consensus standards.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
