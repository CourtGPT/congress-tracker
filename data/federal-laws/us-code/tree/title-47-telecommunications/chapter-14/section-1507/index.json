{"type":"section","nativeType":"section","number":"1507","heading":"Unlicensed spectrum policy","label":"1507 Unlicensed spectrum policy","identifier":"/us/usc/t47/s1507","parentIdentifier":"/us/usc/t47/ch14","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1507","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Statement of policy","label":"a Statement of policy","identifier":"/us/usc/t47/s1507/a","parentIdentifier":"/us/usc/t47/s1507","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1507%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1507/a/1","parentIdentifier":"/us/usc/t47/s1507/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1507%2Fa%2F1","sourceRelease":"119-100","text":"to maximize the benefit to the people of the United States of the spectrum resources of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1507/a/2","parentIdentifier":"/us/usc/t47/s1507/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1507%2Fa%2F2","sourceRelease":"119-100","text":"to advance innovation and investment in wireless broadband services; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t47/s1507/a/3","parentIdentifier":"/us/usc/t47/s1507/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1507%2Fa%2F3","sourceRelease":"119-100","text":"to promote spectrum policy that makes available on an unlicensed basis radio frequency bands to address consumer demand for unlicensed wireless broadband operations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Commission responsibilities","label":"b Commission responsibilities","identifier":"/us/usc/t47/s1507/b","parentIdentifier":"/us/usc/t47/s1507","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1507%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t47/s1507/b/1","parentIdentifier":"/us/usc/t47/s1507/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1507%2Fb%2F1","sourceRelease":"119-100","text":"reasonable; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t47/s1507/b/2","parentIdentifier":"/us/usc/t47/s1507/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1507%2Fb%2F2","sourceRelease":"119-100","text":"in the public interest.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Rule of construction","label":"c Rule of construction","identifier":"/us/usc/t47/s1507/c","parentIdentifier":"/us/usc/t47/s1507","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft47%2Fs1507%2Fc","sourceRelease":"119-100","text":"Nothing in this section confers any additional rights on unlicensed users or users licensed by rule under part 96 of title 47, Code of Federal Regulations, to protection from harmful interference.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
