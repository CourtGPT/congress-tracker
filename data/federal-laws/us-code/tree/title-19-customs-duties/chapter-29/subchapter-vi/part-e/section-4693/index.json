{"type":"section","nativeType":"section","number":"4693","heading":"Final remedies","label":"4693 Final remedies","identifier":"/us/usc/t19/s4693","parentIdentifier":"/us/usc/t19/ch29/schVI/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4693","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t19/s4693/a","parentIdentifier":"/us/usc/t19/s4693","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4693%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s4693/a/1","parentIdentifier":"/us/usc/t19/s4693/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4693%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t19/s4693/a/1/A","parentIdentifier":"/us/usc/t19/s4693/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4693%2Fa%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t19/s4693/a/1/A/i","parentIdentifier":"/us/usc/t19/s4693/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4693%2Fa%2F1%2FA%2Fi","sourceRelease":"119-100","text":"deny entry to goods, produced wholly or in part, from any covered facility involved in such case; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t19/s4693/a/1/A/ii","parentIdentifier":"/us/usc/t19/s4693/a/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4693%2Fa%2F1%2FA%2Fii","sourceRelease":"119-100","text":"allow for the release of goods, produced wholly or in part, from such covered facilities only upon payment of duties and any penalty; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t19/s4693/a/1/B","parentIdentifier":"/us/usc/t19/s4693/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4693%2Fa%2F1%2FB","sourceRelease":"119-100","text":"to apply any duties or penalties to customs entries for which liquidation was suspended pursuant to ; andsection 4692 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s4693/a/2","parentIdentifier":"/us/usc/t19/s4693/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4693%2Fa%2F2","sourceRelease":"119-100","text":"apply other remedies that are appropriate and available under Annex 31–A of the USMCA, until the denial of rights with respect to the case has been remedied.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Remediation notification","label":"b Remediation notification","identifier":"/us/usc/t19/s4693/b","parentIdentifier":"/us/usc/t19/s4693","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs4693%2Fb","sourceRelease":"119-100","text":"The Trade Representative shall promptly notify the Secretary when the denial of rights with respect to a case described in subsection (a) has been remedied.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
