{"type":"section","nativeType":"section","number":"4025","heading":"Grant program","label":"4025 Grant program","identifier":"/us/usc/t25/s4025","parentIdentifier":"/us/usc/t25/ch42/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4025","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"General authority","label":"a General authority","identifier":"/us/usc/t25/s4025/a","parentIdentifier":"/us/usc/t25/s4025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4025%2Fa","sourceRelease":"119-100","text":"The Secretary is authorized to award grants to Indian tribes for the purpose of developing and implementing plans for the investment of Indian tribal trust funds.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Use of funds","label":"b Use of funds","identifier":"/us/usc/t25/s4025/b","parentIdentifier":"/us/usc/t25/s4025","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4025%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4025/b/1","parentIdentifier":"/us/usc/t25/s4025/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4025%2Fb%2F1","sourceRelease":"119-100","text":"the training and education of employees responsible for monitoring the investment of trust funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4025/b/2","parentIdentifier":"/us/usc/t25/s4025/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4025%2Fb%2F2","sourceRelease":"119-100","text":"the building of tribal capacity for the investment and management of trust funds;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t25/s4025/b/3","parentIdentifier":"/us/usc/t25/s4025/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4025%2Fb%2F3","sourceRelease":"119-100","text":"the development of a comprehensive tribal investment plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t25/s4025/b/4","parentIdentifier":"/us/usc/t25/s4025/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4025%2Fb%2F4","sourceRelease":"119-100","text":"the implementation and management of tribal trust fund investment plans; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t25/s4025/b/5","parentIdentifier":"/us/usc/t25/s4025/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4025%2Fb%2F5","sourceRelease":"119-100","text":"such other purposes related to this subchapter that the Secretary deems appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
