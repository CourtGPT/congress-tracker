":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s4145a/c/1","parentIdentifier":"/us/usc/t25/s4145a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4145a%2Fc%2F1","sourceRelease":"119-100","text":"an amount equal to 20 percent of the total grant amount for the recipient for that fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s4145a/c/2","parentIdentifier":"/us/usc/t25/s4145a/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs4145a%2Fc%2F2","sourceRelease":"119-100","text":"$2,000,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
