agraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s16135/b/1","parentIdentifier":"/us/usc/t42/s16135/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16135/b/1/A","parentIdentifier":"/us/usc/t42/s16135/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F1%2FA","sourceRelease":"119-100","text":"informs stakeholders of the benefits of eligible technologies; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16135/b/1/B","parentIdentifier":"/us/usc/t42/s16135/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F1%2FB","sourceRelease":"119-100","text":"develops nonfinancial incentives to promote the use of eligible technologies.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible stakeholders","label":"2 Eligible stakeholders","identifier":"/us/usc/t42/s16135/b/2","parentIdentifier":"/us/usc/t42/s16135/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s16135/b/2/A","parentIdentifier":"/us/usc/t42/s16135/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F2%2FA","sourceRelease":"119-100","text":"equipment owners and operators;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s16135/b/2/B","parentIdentifier":"/us/usc/t42/s16135/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F2%2FB","sourceRelease":"119-100","text":"emission and pollution control technology manufacturers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s16135/b/2/C","parentIdentifier":"/us/usc/t42/s16135/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F2%2FC","sourceRelease":"119-100","text":"engine and equipment manufacturers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t42/s16135/b/2/D","parentIdentifier":"/us/usc/t42/s16135/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F2%2FD","sourceRelease":"119-100","text":"State and local officials responsible for air quality management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t42/s16135/b/2/E","parentIdentifier":"/us/usc/t42/s16135/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F2%2FE","sourceRelease":"119-100","text":"community organizations; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t42/s16135/b/2/F","parentIdentifier":"/us/usc/t42/s16135/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fb%2F2%2FF","sourceRelease":"119-100","text":"public health, educational, and environmental organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"State implementation plans","label":"c State implementation plans","identifier":"/us/usc/t42/s16135/c","parentIdentifier":"/us/usc/t42/s16135","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fc","sourceRelease":"119-100","text":"The Administrator shall develop appropriate guidance to provide credit to a State for emission reductions in the State created by the use of eligible technologies through a State implementation plan under .section 7410 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"International markets","label":"d International markets","identifier":"/us/usc/t42/s16135/d","parentIdentifier":"/us/usc/t42/s16135","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs16135%2Fd","sourceRelease":"119-100","text":"The Administrator, in coordination with the Department of Commerce and industry stakeholders, shall inform foreign countries with air quality problems of the potential of technology developed or used in the United States to provide emission reductions in those countries.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
