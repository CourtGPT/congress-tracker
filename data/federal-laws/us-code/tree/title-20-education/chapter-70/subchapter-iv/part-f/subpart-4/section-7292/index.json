{"type":"section","nativeType":"section","number":"7292","heading":"Assistance for arts education","label":"7292 Assistance for arts education","identifier":"/us/usc/t20/s7292","parentIdentifier":"/us/usc/t20/ch70/schIV/ptF/spt4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , except with respect to certain noncompetitive programs and competitive programs, see , set out as an Effective Date of 2015 Amendment note under .Dec. 10, 2015section 5 of Pub. L. 114–95section 6301 of this title"],"amendments":["Effective DateSection effective , except with respect to certain noncompetitive programs and competitive programs, see , set out as an Effective Date of 2015 Amendment note under .Dec. 10, 2015section 5 of Pub. L. 114–95section 6301 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Awards to provide assistance for arts education","label":"a Awards to provide assistance for arts education","identifier":"/us/usc/t20/s7292/a","parentIdentifier":"/us/usc/t20/s7292","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t20/s7292/a/1","parentIdentifier":"/us/usc/t20/s7292/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7292/a/1/A","parentIdentifier":"/us/usc/t20/s7292/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fa%2F1%2FA","sourceRelease":"119-100","text":"professional development for arts educators, teachers, and principals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7292/a/1/B","parentIdentifier":"/us/usc/t20/s7292/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fa%2F1%2FB","sourceRelease":"119-100","text":"development and dissemination of accessible instructional materials and arts-based educational programming, including online resources, in multiple arts disciplines; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s7292/a/1/C","parentIdentifier":"/us/usc/t20/s7292/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fa%2F1%2FC","sourceRelease":"119-100","text":"community and national outreach activities that strengthen and expand partnerships among schools, local educational agencies, communities, or centers for the arts, including national centers for the arts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Conditions","label":"b Conditions","identifier":"/us/usc/t20/s7292/b","parentIdentifier":"/us/usc/t20/s7292","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s7292/b/1","parentIdentifier":"/us/usc/t20/s7292/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fb%2F1","sourceRelease":"119-100","text":"to coordinate, to the extent practicable, each project or program carried out with such assistance with appropriate activities of public or private cultural agencies, institutions, and organizations, including museums, arts education associations, libraries, and theaters; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s7292/b/2","parentIdentifier":"/us/usc/t20/s7292/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fb%2F2","sourceRelease":"119-100","text":"to use such assistance only to supplement, and not to supplant, any other assistance or funds made available from non-Federal sources for the activities assisted under this subpart.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Consultation","label":"c Consultation","identifier":"/us/usc/t20/s7292/c","parentIdentifier":"/us/usc/t20/s7292","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fc","sourceRelease":"119-100","text":"In carrying out this section, the Secretary shall consult with Federal agencies or institutions, arts educators (including professional arts education associations), and organizations representing the arts (including State and local arts agencies involved in arts education).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Priority","label":"d Priority","identifier":"/us/usc/t20/s7292/d","parentIdentifier":"/us/usc/t20/s7292","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fd","sourceRelease":"119-100","text":"In awarding grants under this section, the Secretary shall give priority to eligible entities that are eligible national nonprofit organizations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Definitions","label":"e Definitions","identifier":"/us/usc/t20/s7292/e","parentIdentifier":"/us/usc/t20/s7292","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Eligible entity","label":"1 Eligible entity","identifier":"/us/usc/t20/s7292/e/1","parentIdentifier":"/us/usc/t20/s7292/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7292/e/1/A","parentIdentifier":"/us/usc/t20/s7292/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F1%2FA","sourceRelease":"119-100","text":"a local educational agency in which 20 percent or more of the students served by the local educational agency are from families with an income below the poverty line;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7292/e/1/B","parentIdentifier":"/us/usc/t20/s7292/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F1%2FB","sourceRelease":"119-100","text":"a consortium of such local educational agencies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s7292/e/1/C","parentIdentifier":"/us/usc/t20/s7292/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F1%2FC","sourceRelease":"119-100","text":"a State educational agency;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t20/s7292/e/1/D","parentIdentifier":"/us/usc/t20/s7292/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F1%2FD","sourceRelease":"119-100","text":"an institution of higher education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t20/s7292/e/1/E","parentIdentifier":"/us/usc/t20/s7292/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F1%2FE","sourceRelease":"119-100","text":"a museum or cultural institution;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t20/s7292/e/1/F","parentIdentifier":"/us/usc/t20/s7292/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F1%2FF","sourceRelease":"119-100","text":"the Bureau of Indian Education;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t20/s7292/e/1/G","parentIdentifier":"/us/usc/t20/s7292/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F1%2FG","sourceRelease":"119-100","text":"an eligible national nonprofit organization; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t20/s7292/e/1/H","parentIdentifier":"/us/usc/t20/s7292/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F1%2FH","sourceRelease":"119-100","text":"another private agency, institution, or organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible national nonprofit organization","label":"2 Eligible national nonprofit organization","identifier":"/us/usc/t20/s7292/e/2","parentIdentifier":"/us/usc/t20/s7292/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s7292/e/2/A","parentIdentifier":"/us/usc/t20/s7292/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F2%2FA","sourceRelease":"119-100","text":"is supported by staff, which may include volunteers, or affiliates at the State and local levels; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s7292/e/2/B","parentIdentifier":"/us/usc/t20/s7292/e/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs7292%2Fe%2F2%2FB","sourceRelease":"119-100","text":"demonstrates effectiveness or high-quality plans for addressing arts education activities for disadvantaged students or students who are children with disabilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
