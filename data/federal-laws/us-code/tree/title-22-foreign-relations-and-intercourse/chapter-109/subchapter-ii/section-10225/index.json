{"type":"section","nativeType":"section","number":"10225","heading":"Sunset","label":"10225 Sunset","identifier":"/us/usc/t22/s10225","parentIdentifier":"/us/usc/t22/ch109/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t22/s10225/a","parentIdentifier":"/us/usc/t22/s10225","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fa","sourceRelease":"119-100","text":"The authority to impose sanctions and the sanctions imposed under this subchapter shall terminate on the date that is 8 years after .December 23, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Certification for early sunset of sanctions","label":"b Certification for early sunset of sanctions","identifier":"/us/usc/t22/s10225/b","parentIdentifier":"/us/usc/t22/s10225","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s10225/b/1","parentIdentifier":"/us/usc/t22/s10225/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fb%2F1","sourceRelease":"119-100","text":"the Burmese military has released all political prisoners taken into custody on or after , or is providing legal recourse to those that remain in custody;February 1, 2021","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s10225/b/2","parentIdentifier":"/us/usc/t22/s10225/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fb%2F2","sourceRelease":"119-100","text":"the elected government of Burma has been reinstated or new free and fair elections have been held;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s10225/b/3","parentIdentifier":"/us/usc/t22/s10225/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fb%2F3","sourceRelease":"119-100","text":"all legal charges against those winning election in November 2020 are dropped; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s10225/b/4","parentIdentifier":"/us/usc/t22/s10225/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fb%2F4","sourceRelease":"119-100","text":"the 2008 constitution of Burma has been amended or replaced to place the Burmese military under civilian oversight and ensure that the Burmese military no longer automatically receives 25 percent of seats in Burma’s state, regional, and national Hluttaws.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Notification for early sunset of sanctions on individuals","label":"c Notification for early sunset of sanctions on individuals","identifier":"/us/usc/t22/s10225/c","parentIdentifier":"/us/usc/t22/s10225","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s10225/c/1","parentIdentifier":"/us/usc/t22/s10225/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10225/c/1/A","parentIdentifier":"/us/usc/t22/s10225/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fc%2F1%2FA","sourceRelease":"119-100","text":"a notice of and justification for the termination; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10225/c/1/B","parentIdentifier":"/us/usc/t22/s10225/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fc%2F1%2FB","sourceRelease":"119-100","text":"a notice that the individual is not engaging in the activity or is no longer occupying the position that was the basis for the sanctions or has taken significant verifiable steps toward stopping the activity.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Form","label":"2 Form","identifier":"/us/usc/t22/s10225/c/2","parentIdentifier":"/us/usc/t22/s10225/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10225%2Fc%2F2","sourceRelease":"119-100","text":"The notice required by paragraph (1) shall be submitted in unclassified form but may include a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
