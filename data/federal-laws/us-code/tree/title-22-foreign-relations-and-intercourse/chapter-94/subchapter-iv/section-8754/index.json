{"type":"section","nativeType":"section","number":"8754","heading":"Comprehensive strategy to promote Internet freedom and access to information in Iran","label":"8754 Comprehensive strategy to promote Internet freedom and access to information in Iran","identifier":"/us/usc/t22/s8754","parentIdentifier":"/us/usc/t22/ch94/schIV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s8754/1","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F1","sourceRelease":"119-100","text":"assist the people of Iran to produce, access, and share information freely and safely via the Internet, including in Farsi and regional languages;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s8754/2","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F2","sourceRelease":"119-100","text":"support the development of counter-censorship technologies that enable the citizens of Iran to undertake Internet activities without interference from the Government of Iran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s8754/3","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F3","sourceRelease":"119-100","text":"increase the capabilities and availability of secure mobile and other communications through connective technology among human rights and democracy activists in Iran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s8754/4","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F4","sourceRelease":"119-100","text":"provide resources for digital safety training for media and academic and civil society organizations in Iran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s8754/5","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F5","sourceRelease":"119-100","text":"provide accurate and substantive Internet content in local languages in Iran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t22/s8754/6","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F6","sourceRelease":"119-100","text":"increase emergency resources for the most vulnerable human rights advocates seeking to organize, share information, and support human rights in Iran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t22/s8754/7","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s8754/7/A","parentIdentifier":"/us/usc/t22/s8754/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F7%2FA","sourceRelease":"119-100","text":"by expanding Voice of America’s Persian News Network and Radio Free Europe/Radio Liberty’s Radio Farda to provide hourly live news update programming and breaking news coverage capability 24 hours a day and 7 days a week; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s8754/7/B","parentIdentifier":"/us/usc/t22/s8754/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F7%2FB","sourceRelease":"119-100","text":"by assisting telecommunications and software companies that are United States persons to comply with the export licensing requirements of the United States for the purpose of expanding such communications inside Iran;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t22/s8754/8","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F8","sourceRelease":"119-100","text":"expand activities to safely assist and train human rights, civil society, and democracy activists in Iran to operate effectively and securely;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t22/s8754/9","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F9","sourceRelease":"119-100","text":"identify and utilize all available resources to overcome attempts by the Government of Iran to jam or otherwise deny international satellite broadcasting signals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t22/s8754/10","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F10","sourceRelease":"119-100","text":"expand worldwide United States embassy and consulate programming for and outreach to Iranian dissident communities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t22/s8754/11","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F11","sourceRelease":"119-100","text":"expand access to proxy servers for democracy activists in Iran; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"12","heading":null,"label":"12","identifier":"/us/usc/t22/s8754/12","parentIdentifier":"/us/usc/t22/s8754","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs8754%2F12","sourceRelease":"119-100","text":"discourage telecommunications and software companies from facilitating Internet censorship by the Government of Iran.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
