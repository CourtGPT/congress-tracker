{"type":"section","nativeType":"section","number":"25","heading":"Use of minors in crimes of violence","label":"25 Use of minors in crimes of violence","identifier":"/us/usc/t18/s25","parentIdentifier":"/us/usc/t18/ptI/ch1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs25","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t18/s25/a","parentIdentifier":"/us/usc/t18/s25","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs25%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Crime of violence","label":"1 .—Crime of violence","identifier":"/us/usc/t18/s25/a/1","parentIdentifier":"/us/usc/t18/s25/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs25%2Fa%2F1","sourceRelease":"119-100","text":"The term “crime of violence” has the meaning set forth in section 16.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Minor","label":"2 .—Minor","identifier":"/us/usc/t18/s25/a/2","parentIdentifier":"/us/usc/t18/s25/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs25%2Fa%2F2","sourceRelease":"119-100","text":"The term “minor” means a person who has not reached 18 years of age.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Uses","label":"3 .—Uses","identifier":"/us/usc/t18/s25/a/3","parentIdentifier":"/us/usc/t18/s25/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs25%2Fa%2F3","sourceRelease":"119-100","text":"The term “uses” means employs, hires, persuades, induces, entices, or coerces.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Penalties","label":"b .—Penalties","identifier":"/us/usc/t18/s25/b","parentIdentifier":"/us/usc/t18/s25","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs25%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t18/s25/b/1","parentIdentifier":"/us/usc/t18/s25/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs25%2Fb%2F1","sourceRelease":"119-100","text":"for the first conviction, be subject to twice the maximum term of imprisonment and twice the maximum fine that would otherwise be authorized for the offense; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t18/s25/b/2","parentIdentifier":"/us/usc/t18/s25/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs25%2Fb%2F2","sourceRelease":"119-100","text":"for each subsequent conviction, be subject to 3 times the maximum term of imprisonment and 3 times the maximum fine that would otherwise be authorized for the offense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
