{"type":"section","nativeType":"section","number":"2461","heading":"Audit, review, and evaluation","label":"2461 Audit, review, and evaluation","identifier":"/us/usc/t15/s2461","parentIdentifier":"/us/usc/t15/ch51/schV","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2461","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Audit, etc., by Comptroller General","label":"a Audit, etc., by Comptroller General","identifier":"/us/usc/t15/s2461/a","parentIdentifier":"/us/usc/t15/s2461","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2461%2Fa","sourceRelease":"119-100","text":"The Comptroller General of the United States shall audit, review, and evaluate the implementation of the provisions of this chapter by the Center.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report to Congress; contents","label":"b Report to Congress; contents","identifier":"/us/usc/t15/s2461/b","parentIdentifier":"/us/usc/t15/s2461","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2461%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s2461/b/1","parentIdentifier":"/us/usc/t15/s2461/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2461%2Fb%2F1","sourceRelease":"119-100","text":"an evaluation of the effectiveness of the Center’s activities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s2461/b/2","parentIdentifier":"/us/usc/t15/s2461/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2461%2Fb%2F2","sourceRelease":"119-100","text":"an evaluation of the effect of the activities of the Center on the efficiency, and effectiveness, of affected Federal agencies in carrying out their assigned functions and duties under this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s2461/b/3","parentIdentifier":"/us/usc/t15/s2461/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs2461%2Fb%2F3","sourceRelease":"119-100","text":"recommendations concerning any legislation he deems necessary, and the reasons therefor, for improving the implementation of the objectives of this chapter as set forth in .section 2402 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
