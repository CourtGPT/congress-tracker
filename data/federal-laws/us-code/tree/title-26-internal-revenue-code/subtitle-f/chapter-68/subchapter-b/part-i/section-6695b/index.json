ufactured by a prohibited foreign entity that were provided on such certification, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t26/s6695B/a/3","parentIdentifier":"/us/usc/t26/s6695B/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6695B%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t26/s6695B/a/3/A","parentIdentifier":"/us/usc/t26/s6695B/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6695B%2Fa%2F3%2FA","sourceRelease":"119-100","text":"5 percent of the tax required to be shown on the return for the taxable year, or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t26/s6695B/a/3/B","parentIdentifier":"/us/usc/t26/s6695B/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6695B%2Fa%2F3%2FB","sourceRelease":"119-100","text":"$100,000,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Amount of penalty","label":"b Amount of penalty","identifier":"/us/usc/t26/s6695B/b","parentIdentifier":"/us/usc/t26/s6695B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6695B%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t26/s6695B/b/1","parentIdentifier":"/us/usc/t26/s6695B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6695B%2Fb%2F1","sourceRelease":"119-100","text":"10 percent of the amount of the underpayment (as defined in section 6664(a)) solely attributable to the inaccuracy or falsity described in subsection (a)(2), or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t26/s6695B/b/2","parentIdentifier":"/us/usc/t26/s6695B/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6695B%2Fb%2F2","sourceRelease":"119-100","text":"$5,000.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Exception","label":"c Exception","identifier":"/us/usc/t26/s6695B/c","parentIdentifier":"/us/usc/t26/s6695B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6695B%2Fc","sourceRelease":"119-100","text":"No penalty shall be imposed under subsection (a) if the person establishes to the satisfaction of the Secretary that any inaccuracy or falsity described in subsection (a)(2) is due to a reasonable cause and not willful neglect.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Definitions","label":"d Definitions","identifier":"/us/usc/t26/s6695B/d","parentIdentifier":"/us/usc/t26/s6695B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft26%2Fs6695B%2Fd","sourceRelease":"119-100","text":"Any term used in this section which is also used in section 7701(a)(52) shall have the meaning given such term in such section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
