{"type":"section","nativeType":"section","number":"17372","heading":"Annual national energy security strategy report","label":"17372 Annual national energy security strategy report","identifier":"/us/usc/t42/s17372","parentIdentifier":"/us/usc/t42/ch152/schVIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective on the date that is 1 day after , see , set out as a note under , The Congress.Dec. 19, 2007section 1601 of Pub. L. 110–140section 1824 of Title 2"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Reports","label":"a Reports","identifier":"/us/usc/t42/s17372/a","parentIdentifier":"/us/usc/t42/s17372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t42/s17372/a/1","parentIdentifier":"/us/usc/t42/s17372/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fa%2F1","sourceRelease":"119-100","text":"Subject to paragraph (2), on the date on which the President submits to Congress the budget for the following fiscal year under , the President shall submit to Congress a comprehensive report on the national energy security of the United States.section 1105 of title 31","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"New Presidents","label":"2 New Presidents","identifier":"/us/usc/t42/s17372/a/2","parentIdentifier":"/us/usc/t42/s17372/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fa%2F2","sourceRelease":"119-100","text":"In addition to the reports required under paragraph (1), the President shall submit a comprehensive report on the national energy security of the United States by not later than 150 days after the date on which the President assumes the office of President after a presidential election.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Contents","label":"b Contents","identifier":"/us/usc/t42/s17372/b","parentIdentifier":"/us/usc/t42/s17372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17372/b/1","parentIdentifier":"/us/usc/t42/s17372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb%2F1","sourceRelease":"119-100","text":"the worldwide interests, goals, and objectives of the United States that are vital to the national energy security of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17372/b/2","parentIdentifier":"/us/usc/t42/s17372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17372/b/2/A","parentIdentifier":"/us/usc/t42/s17372/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb%2F2%2FA","sourceRelease":"119-100","text":"to deter political manipulation of world energy resources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17372/b/2/B","parentIdentifier":"/us/usc/t42/s17372/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb%2F2%2FB","sourceRelease":"119-100","text":"to implement the national energy security strategy of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17372/b/3","parentIdentifier":"/us/usc/t42/s17372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s17372/b/3/A","parentIdentifier":"/us/usc/t42/s17372/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb%2F3%2FA","sourceRelease":"119-100","text":"to protect or promote energy security; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s17372/b/3/B","parentIdentifier":"/us/usc/t42/s17372/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb%2F3%2FB","sourceRelease":"119-100","text":"to achieve the goals and objectives described in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17372/b/4","parentIdentifier":"/us/usc/t42/s17372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb%2F4","sourceRelease":"119-100","text":"the adequacy of the capabilities of the United States to protect the national energy security of the United States, including an evaluation of the balance among the capabilities of all elements of the national authority of the United States to support the implementation of the national energy security strategy; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t42/s17372/b/5","parentIdentifier":"/us/usc/t42/s17372/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fb%2F5","sourceRelease":"119-100","text":"such other information as the President determines to be necessary to inform Congress on matters relating to the national energy security of the United States.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Classified and unclassified form","label":"c Classified and unclassified form","identifier":"/us/usc/t42/s17372/c","parentIdentifier":"/us/usc/t42/s17372","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s17372/c/1","parentIdentifier":"/us/usc/t42/s17372/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fc%2F1","sourceRelease":"119-100","text":"a classified form; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17372/c/2","parentIdentifier":"/us/usc/t42/s17372/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17372%2Fc%2F2","sourceRelease":"119-100","text":"an unclassified form.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
