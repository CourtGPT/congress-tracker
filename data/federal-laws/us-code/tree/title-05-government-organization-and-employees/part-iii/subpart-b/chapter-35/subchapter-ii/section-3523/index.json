{"type":"section","nativeType":"section","number":"3523","heading":"Authority to provide voluntary separation incentive payments","label":"3523 Authority to provide voluntary separation incentive payments","identifier":"/us/usc/t5/s3523","parentIdentifier":"/us/usc/t5/ptIII/sptB/ch35/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective 60 days after , see , set out as a note under .Nov. 25, 2002section 1313(a)(4) of Pub. L. 107–296section 3521 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":null,"label":"a","identifier":"/us/usc/t5/s3523/a","parentIdentifier":"/us/usc/t5/s3523","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fa","sourceRelease":"119-100","text":"A voluntary separation incentive payment under this subchapter may be paid to an employee only as provided in the plan of an agency established under section 3522.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":null,"label":"b","identifier":"/us/usc/t5/s3523/b","parentIdentifier":"/us/usc/t5/s3523","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s3523/b/1","parentIdentifier":"/us/usc/t5/s3523/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s3523/b/1/A","parentIdentifier":"/us/usc/t5/s3523/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F1%2FA","sourceRelease":"119-100","text":"1 or more organizational units;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s3523/b/1/B","parentIdentifier":"/us/usc/t5/s3523/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F1%2FB","sourceRelease":"119-100","text":"1 or more occupational series or levels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s3523/b/1/C","parentIdentifier":"/us/usc/t5/s3523/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F1%2FC","sourceRelease":"119-100","text":"1 or more geographical locations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t5/s3523/b/1/D","parentIdentifier":"/us/usc/t5/s3523/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F1%2FD","sourceRelease":"119-100","text":"skills, knowledge, or other factors related to a position;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t5/s3523/b/1/E","parentIdentifier":"/us/usc/t5/s3523/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F1%2FE","sourceRelease":"119-100","text":"specific periods of time during which eligible employees may elect a voluntary incentive payment; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t5/s3523/b/1/F","parentIdentifier":"/us/usc/t5/s3523/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F1%2FF","sourceRelease":"119-100","text":"any appropriate combination of such factors;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s3523/b/2","parentIdentifier":"/us/usc/t5/s3523/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F2","sourceRelease":"119-100","text":"shall be paid in a lump sum after the employee’s separation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s3523/b/3","parentIdentifier":"/us/usc/t5/s3523/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s3523/b/3/A","parentIdentifier":"/us/usc/t5/s3523/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F3%2FA","sourceRelease":"119-100","text":"an amount equal to the amount the employee would be entitled to receive under section 5595(c) if the employee were entitled to payment under such section (without adjustment for any previous payment made); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s3523/b/3/B","parentIdentifier":"/us/usc/t5/s3523/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F3%2FB","sourceRelease":"119-100","text":"an amount determined by the agency head, not to exceed $25,000;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s3523/b/4","parentIdentifier":"/us/usc/t5/s3523/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F4","sourceRelease":"119-100","text":"may be made only in the case of an employee who voluntarily separates (whether by retirement or resignation) under this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t5/s3523/b/5","parentIdentifier":"/us/usc/t5/s3523/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F5","sourceRelease":"119-100","text":"shall not be a basis for payment, and shall not be included in the computation, of any other type of Government benefit;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t5/s3523/b/6","parentIdentifier":"/us/usc/t5/s3523/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F6","sourceRelease":"119-100","text":"shall not be taken into account in determining the amount of any severance pay to which the employee may be entitled under section 5595, based on another other separation; and1So in original.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t5/s3523/b/7","parentIdentifier":"/us/usc/t5/s3523/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs3523%2Fb%2F7","sourceRelease":"119-100","text":"shall be paid from appropriations or funds available for the payment of the basic pay of the employee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
