{"type":"section","nativeType":"section","number":"3702","heading":"Statement of policy","label":"3702 Statement of policy","identifier":"/us/usc/t19/s3702","parentIdentifier":"/us/usc/t19/ch23/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","Amendments2015—Par. (10). added par. (10).Pub. L. 114–27"],"amendments":["Amendments2015—Par. (10). added par. (10).Pub. L. 114–27"],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t19/s3702/1","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F1","sourceRelease":"119-100","text":"encouraging increased trade and investment between the United States and sub-Saharan Africa;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t19/s3702/2","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F2","sourceRelease":"119-100","text":"reducing tariff and nontariff barriers and other obstacles to sub-Saharan African and United States trade;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t19/s3702/3","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F3","sourceRelease":"119-100","text":"expanding United States assistance to sub-Saharan Africa’s regional integration efforts;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t19/s3702/4","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F4","sourceRelease":"119-100","text":"negotiating reciprocal and mutually beneficial trade agreements, including the possibility of establishing free trade areas that serve the interests of both the United States and the countries of sub-Saharan Africa;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t19/s3702/5","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F5","sourceRelease":"119-100","text":"focusing on countries committed to the rule of law, economic reform, and the eradication of poverty;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t19/s3702/6","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F6","sourceRelease":"119-100","text":"strengthening and expanding the private sector in sub-Saharan Africa, especially enterprises owned by women and small businesses;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t19/s3702/7","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F7","sourceRelease":"119-100","text":"facilitating the development of civil societies and political freedom in sub-Saharan Africa;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t19/s3702/8","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F8","sourceRelease":"119-100","text":"establishing a United States-Sub-Saharan Africa Trade and Economic Cooperation Forum;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t19/s3702/9","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F9","sourceRelease":"119-100","text":"the accession of the countries in sub-Saharan Africa to the Organization for Economic Cooperation and Development (OECD) Convention on Combating Bribery of Foreign Public Officials in International Business Transactions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t19/s3702/10","parentIdentifier":"/us/usc/t19/s3702","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft19%2Fs3702%2F10","sourceRelease":"119-100","text":"promoting the role of women in social, political, and economic development in sub-Saharan Africa.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
