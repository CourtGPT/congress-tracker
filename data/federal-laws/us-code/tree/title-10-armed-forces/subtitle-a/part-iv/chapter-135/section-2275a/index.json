{"type":"section","nativeType":"section","number":"2275a","heading":"Requirements for protection of satellites","label":"2275a Requirements for protection of satellites","identifier":"/us/usc/t10/s2275a","parentIdentifier":"/us/usc/t10/stA/ptIV/ch135","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2275a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Establishment of Requirements","label":"a .—Establishment of Requirements","identifier":"/us/usc/t10/s2275a/a","parentIdentifier":"/us/usc/t10/s2275a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2275a%2Fa","sourceRelease":"119-100","text":"Before a major satellite acquisition program achieves Milestone A approval, or equivalent, the Chief of Staff of the Space Force, in consultation with the Commander of the United States Space Command, shall establish requirements for the defense and resilience of the satellites under that program against the capabilities of adversaries to target, degrade, or destroy the satellites.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Definitions","label":"b .—Definitions","identifier":"/us/usc/t10/s2275a/b","parentIdentifier":"/us/usc/t10/s2275a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2275a%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t10/s2275a/b/1","parentIdentifier":"/us/usc/t10/s2275a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2275a%2Fb%2F1","sourceRelease":"119-100","text":"The term “major satellite acquisition program” has the meaning given that term in .section 2275 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t10/s2275a/b/2","parentIdentifier":"/us/usc/t10/s2275a/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft10%2Fs2275a%2Fb%2F2","sourceRelease":"119-100","text":"The term “Milestone A approval” has the meaning given that term in 10.section 4251 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
