{"type":"section","nativeType":"section","number":"677d","heading":"Notification and reporting","label":"677d Notification and reporting","identifier":"/us/usc/t6/s677d","parentIdentifier":"/us/usc/t6/ch1/schXVIII/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Notification","label":"a Notification","identifier":"/us/usc/t6/s677d/a","parentIdentifier":"/us/usc/t6/s677d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s677d/a/1","parentIdentifier":"/us/usc/t6/s677d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fa%2F1","sourceRelease":"119-100","text":"an estimation of the planned duration of the declaration;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s677d/a/2","parentIdentifier":"/us/usc/t6/s677d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s677d/a/2/A","parentIdentifier":"/us/usc/t6/s677d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the operational or mission impact or anticipated impact of the specific significant incident on Federal and non-Federal entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s677d/a/2/B","parentIdentifier":"/us/usc/t6/s677d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fa%2F2%2FB","sourceRelease":"119-100","text":"if known, the perpetrator of the specific significant incident; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s677d/a/2/C","parentIdentifier":"/us/usc/t6/s677d/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fa%2F2%2FC","sourceRelease":"119-100","text":"the scope of the Federal and non-Federal entities impacted or anticipated to be impacted by the specific significant incident;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s677d/a/3","parentIdentifier":"/us/usc/t6/s677d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fa%2F3","sourceRelease":"119-100","text":"with respect to a notification of a renewal, the reason for the renewal;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s677d/a/4","parentIdentifier":"/us/usc/t6/s677d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fa%2F4","sourceRelease":"119-100","text":"justification as to why available resources, other than the Fund, are insufficient to respond to or mitigate the specific significant incident; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s677d/a/5","parentIdentifier":"/us/usc/t6/s677d/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fa%2F5","sourceRelease":"119-100","text":"a description of the coordination activities described in that the Secretary anticipates the Director to perform.section 677b(b) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Report to Congress","label":"b Report to Congress","identifier":"/us/usc/t6/s677d/b","parentIdentifier":"/us/usc/t6/s677d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s677d/b/1","parentIdentifier":"/us/usc/t6/s677d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fb%2F1","sourceRelease":"119-100","text":"the reason for the declaration or renewal, including information and intelligence relating to the specific significant incident that led to the declaration or renewal;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s677d/b/2","parentIdentifier":"/us/usc/t6/s677d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fb%2F2","sourceRelease":"119-100","text":"the use of any funds from the Fund for the purpose of responding to the incident or threat described in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s677d/b/3","parentIdentifier":"/us/usc/t6/s677d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fb%2F3","sourceRelease":"119-100","text":"a description of the actions, initiatives, and projects undertaken by the Department and State and local governments and public and private entities in responding to and recovering from the specific significant incident described in paragraph (1);","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t6/s677d/b/4","parentIdentifier":"/us/usc/t6/s677d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fb%2F4","sourceRelease":"119-100","text":"an accounting of the specific obligations and outlays of the Fund; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t6/s677d/b/5","parentIdentifier":"/us/usc/t6/s677d/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fb%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s677d/b/5/A","parentIdentifier":"/us/usc/t6/s677d/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fb%2F5%2FA","sourceRelease":"119-100","text":"the impact of the specific significant incident described in paragraph (1) on Federal and non-Federal entities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s677d/b/5/B","parentIdentifier":"/us/usc/t6/s677d/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fb%2F5%2FB","sourceRelease":"119-100","text":"the impact of the declaration or renewal on the response to, and recovery from, the specific significant incident described in paragraph (1); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s677d/b/5/C","parentIdentifier":"/us/usc/t6/s677d/b/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fb%2F5%2FC","sourceRelease":"119-100","text":"the impact of the funds made available from the Fund as a result of the declaration or renewal on the recovery from, and response to, the specific significant incident described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Classification","label":"c Classification","identifier":"/us/usc/t6/s677d/c","parentIdentifier":"/us/usc/t6/s677d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s677d/c/1","parentIdentifier":"/us/usc/t6/s677d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fc%2F1","sourceRelease":"119-100","text":"shall be in an unclassified form with appropriate markings to indicate information that is exempt from disclosure under (commonly known as the “Freedom of Information Act”); andsection 552 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s677d/c/2","parentIdentifier":"/us/usc/t6/s677d/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fc%2F2","sourceRelease":"119-100","text":"may include a classified annex.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Consolidated report","label":"d Consolidated report","identifier":"/us/usc/t6/s677d/d","parentIdentifier":"/us/usc/t6/s677d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fd","sourceRelease":"119-100","text":"The Secretary shall not be required to submit multiple reports under subsection (b) for multiple declarations or renewals if the Secretary determines that the declarations or renewals substantively relate to the same specific significant incident.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Exemption","label":"e Exemption","identifier":"/us/usc/t6/s677d/e","parentIdentifier":"/us/usc/t6/s677d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs677d%2Fe","sourceRelease":"119-100","text":"The requirements of subchapter I of chapter 35 of title 44 (commonly known as the “Paperwork Reduction Act”) shall not apply to the voluntary collection of information by the Department during an investigation of, a response to, or an immediate post-response review of, the specific significant incident leading to a declaration or renewal.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
