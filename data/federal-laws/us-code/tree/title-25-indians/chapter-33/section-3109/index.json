{"type":"section","nativeType":"section","number":"3109","heading":"Indian forest land assistance account","label":"3109 Indian forest land assistance account","identifier":"/us/usc/t25/s3109","parentIdentifier":"/us/usc/t25/ch33","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t25/s3109/a","parentIdentifier":"/us/usc/t25/s3109","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109%2Fa","sourceRelease":"119-100","text":"At the request of an Indian tribe, the Secretary may establish a special Indian forest land assistance account within the tribe’s trust fund account to fund the Indian forest land management activities of such tribe.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Deposits and expenditures","label":"b Deposits and expenditures","identifier":"/us/usc/t25/s3109/b","parentIdentifier":"/us/usc/t25/s3109","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t25/s3109/b/1","parentIdentifier":"/us/usc/t25/s3109/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t25/s3109/b/1/A","parentIdentifier":"/us/usc/t25/s3109/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109%2Fb%2F1%2FA","sourceRelease":"119-100","text":"non-Federal sources, if such funds are related to activities on or for the Indian forest lands of such tribe’s reservation,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t25/s3109/b/1/B","parentIdentifier":"/us/usc/t25/s3109/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109%2Fb%2F1%2FB","sourceRelease":"119-100","text":"donations and contributions,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t25/s3109/b/1/C","parentIdentifier":"/us/usc/t25/s3109/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109%2Fb%2F1%2FC","sourceRelease":"119-100","text":"unobligated forestry appropriations for the benefit of such Indian tribe, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t25/s3109/b/1/D","parentIdentifier":"/us/usc/t25/s3109/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109%2Fb%2F1%2FD","sourceRelease":"119-100","text":"user fees or other funds transferred under Federal interagency agreements if otherwise authorized by Federal law and, if such funds are related to activities on or for the Indian forest lands of such tribe’s reservation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t25/s3109/b/2","parentIdentifier":"/us/usc/t25/s3109/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109%2Fb%2F2","sourceRelease":"119-100","text":"Funds in the Indian forest land assistance account and any interest or other income earned thereon shall remain available until expended and shall not be available to otherwise offset Federal appropriations for meeting the Federal responsibility for management of Indian forest lands.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Audits","label":"c Audits","identifier":"/us/usc/t25/s3109/c","parentIdentifier":"/us/usc/t25/s3109","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft25%2Fs3109%2Fc","sourceRelease":"119-100","text":"At the request of an Indian tribe or upon the Secretary’s own volition, the Secretary may conduct audits of the Indian forest land assistance account and shall publish the results of such audit.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
