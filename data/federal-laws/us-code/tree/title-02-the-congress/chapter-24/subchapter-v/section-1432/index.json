usc/t2/s1432/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1432%2Fb%2F2%2FC","sourceRelease":"119-100","text":"a joint committee of the Congress;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s1432/b/3","parentIdentifier":"/us/usc/t2/s1432/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1432%2Fb%2F3","sourceRelease":"119-100","text":"an employee on the staff of a Member of the House of Representatives or on the staff of a Senator;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t2/s1432/b/4","parentIdentifier":"/us/usc/t2/s1432/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1432%2Fb%2F4","sourceRelease":"119-100","text":"an officer of the House of Representatives or the Senate or a congressional employee who is elected by the House of Representatives or Senate or is appointed by a Member of the House of Representatives or by a Senator (in addition an employee described in paragraph (1), (2), or (3)); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t2/s1432/b/5","parentIdentifier":"/us/usc/t2/s1432/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs1432%2Fb%2F5","sourceRelease":"119-100","text":"an applicant for a position that is to be occupied by an individual described in any of paragraphs (1) through (4).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
