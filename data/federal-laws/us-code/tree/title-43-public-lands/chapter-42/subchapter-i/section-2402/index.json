nts":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2402/d/1/B","parentIdentifier":"/us/usc/t43/s2402/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fd%2F1%2FB","sourceRelease":"119-100","text":"promotes and applies a regional or watershed perspective to water resources management;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2402/d/2","parentIdentifier":"/us/usc/t43/s2402/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t43/s2402/d/2/A","parentIdentifier":"/us/usc/t43/s2402/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fd%2F2%2FA","sourceRelease":"119-100","text":"improve the health or aesthetic quality of water;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t43/s2402/d/2/B","parentIdentifier":"/us/usc/t43/s2402/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fd%2F2%2FB","sourceRelease":"119-100","text":"result in continuous, measurable, and significant water quality benefits; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t43/s2402/d/2/C","parentIdentifier":"/us/usc/t43/s2402/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fd%2F2%2FC","sourceRelease":"119-100","text":"address current or future water supply needs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t43/s2402/d/3","parentIdentifier":"/us/usc/t43/s2402/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fd%2F3","sourceRelease":"119-100","text":"a rural water supply project helps meet applicable requirements established by law; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t43/s2402/d/4","parentIdentifier":"/us/usc/t43/s2402/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fd%2F4","sourceRelease":"119-100","text":"a rural water supply project is cost effective.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Inclusions","label":"e Inclusions","identifier":"/us/usc/t43/s2402/e","parentIdentifier":"/us/usc/t43/s2402","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t43/s2402/e/1","parentIdentifier":"/us/usc/t43/s2402/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fe%2F1","sourceRelease":"119-100","text":"to the extent that connection provides a reliable water supply, a connection to pre-existing infrastructure (including impoundments and conveyance channels) as part of a rural water supply project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t43/s2402/e/2","parentIdentifier":"/us/usc/t43/s2402/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft43%2Fs2402%2Fe%2F2","sourceRelease":"119-100","text":"notwithstanding the limitation on population under , a town or community with a population in excess of 50,000 inhabitants in an area served by a rural water supply project if, at the discretion of the Secretary, the town or community is considered to be a critical partner in the rural supply project.section 2401(9)(A) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
