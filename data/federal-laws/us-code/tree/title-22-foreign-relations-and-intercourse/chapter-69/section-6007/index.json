{"type":"section","nativeType":"section","number":"6007","heading":"Policy toward a democratic Cuban Government","label":"6007 Policy toward a democratic Cuban Government","identifier":"/us/usc/t22/s6007","parentIdentifier":"/us/usc/t22/ch69","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Waiver of restrictions","label":"a Waiver of restrictions","identifier":"/us/usc/t22/s6007/a","parentIdentifier":"/us/usc/t22/s6007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s6007/a/1","parentIdentifier":"/us/usc/t22/s6007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fa%2F1","sourceRelease":"119-100","text":"has held free and fair elections conducted under internationally recognized observers;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s6007/a/2","parentIdentifier":"/us/usc/t22/s6007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fa%2F2","sourceRelease":"119-100","text":"has permitted opposition parties ample time to organize and campaign for such elections, and has permitted full access to the media to all candidates in the elections;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s6007/a/3","parentIdentifier":"/us/usc/t22/s6007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fa%2F3","sourceRelease":"119-100","text":"is showing respect for the basic civil liberties and human rights of the citizens of Cuba;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s6007/a/4","parentIdentifier":"/us/usc/t22/s6007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fa%2F4","sourceRelease":"119-100","text":"is moving toward establishing a free market economic system; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s6007/a/5","parentIdentifier":"/us/usc/t22/s6007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fa%2F5","sourceRelease":"119-100","text":"has committed itself to constitutional change that would ensure regular free and fair elections that meet the requirements of paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Policies","label":"b Policies","identifier":"/us/usc/t22/s6007/b","parentIdentifier":"/us/usc/t22/s6007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s6007/b/1","parentIdentifier":"/us/usc/t22/s6007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fb%2F1","sourceRelease":"119-100","text":"To encourage the admission or reentry of such government to international organizations and international financial institutions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s6007/b/2","parentIdentifier":"/us/usc/t22/s6007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fb%2F2","sourceRelease":"119-100","text":"To provide emergency relief during Cuba’s transition to a viable economic system.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s6007/b/3","parentIdentifier":"/us/usc/t22/s6007/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs6007%2Fb%2F3","sourceRelease":"119-100","text":"To take steps to end the United States trade embargo of Cuba.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
