s1165/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fa%2F2%2FC","sourceRelease":"119-100","text":"$5,000,000 for fiscal year 2010; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s1165/a/2/D","parentIdentifier":"/us/usc/t6/s1165/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fa%2F2%2FD","sourceRelease":"119-100","text":"$5,000,000 for fiscal year 2011.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s1165/a/3","parentIdentifier":"/us/usc/t6/s1165/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1165/a/3/A","parentIdentifier":"/us/usc/t6/s1165/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fa%2F3%2FA","sourceRelease":"119-100","text":"$5,000,000 for fiscal year 2008;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1165/a/3/B","parentIdentifier":"/us/usc/t6/s1165/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fa%2F3%2FB","sourceRelease":"119-100","text":"$5,000,000 for fiscal year 2009;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s1165/a/3/C","parentIdentifier":"/us/usc/t6/s1165/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fa%2F3%2FC","sourceRelease":"119-100","text":"$5,000,000 for fiscal year 2010; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s1165/a/3/D","parentIdentifier":"/us/usc/t6/s1165/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fa%2F3%2FD","sourceRelease":"119-100","text":"$5,000,000 for fiscal year 2011.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Infrastructure upgrades","label":"b Infrastructure upgrades","identifier":"/us/usc/t6/s1165/b","parentIdentifier":"/us/usc/t6/s1165","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fb","sourceRelease":"119-100","text":"Out of funds appropriated pursuant to , there shall be made available to the Secretary of Transportation for fiscal year 2008, $3,000,000 for the preliminary design of options for a new tunnel on a different alignment to augment the capacity of the existing Baltimore tunnels.section 1153 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Availability of amounts","label":"c Availability of amounts","identifier":"/us/usc/t6/s1165/c","parentIdentifier":"/us/usc/t6/s1165","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fc","sourceRelease":"119-100","text":"Amounts appropriated pursuant to this section shall remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Plans required","label":"d Plans required","identifier":"/us/usc/t6/s1165/d","parentIdentifier":"/us/usc/t6/s1165","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s1165/d/1","parentIdentifier":"/us/usc/t6/s1165/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fd%2F1","sourceRelease":"119-100","text":"until Amtrak has submitted to the Secretary of Transportation, and the Secretary of Transportation has approved, an engineering and financial plan for such projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s1165/d/2","parentIdentifier":"/us/usc/t6/s1165/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fd%2F2","sourceRelease":"119-100","text":"unless, for each project funded pursuant to this section, the Secretary of Transportation has approved a project management plan prepared by Amtrak.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Review of plans","label":"e Review of plans","identifier":"/us/usc/t6/s1165/e","parentIdentifier":"/us/usc/t6/s1165","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t6/s1165/e/1","parentIdentifier":"/us/usc/t6/s1165/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fe%2F1","sourceRelease":"119-100","text":"The Secretary of Transportation shall complete the review of a plan required under subsection (d) and approve or disapprove the plan within 45 days after the date on which each such plan is submitted by Amtrak.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Incomplete or deficient plan","label":"2 Incomplete or deficient plan","identifier":"/us/usc/t6/s1165/e/2","parentIdentifier":"/us/usc/t6/s1165/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fe%2F2","sourceRelease":"119-100","text":"If the Secretary of Transportation determines that a plan is incomplete or deficient, the Secretary of Transportation shall notify Amtrak of the incomplete items or deficiencies and Amtrak shall, within 30 days after receiving the Secretary of Transportation’s notification, submit a modified plan for the Secretary of Transportation’s review.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Approval of plan","label":"3 Approval of plan","identifier":"/us/usc/t6/s1165/e/3","parentIdentifier":"/us/usc/t6/s1165/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fe%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t6/s1165/e/3/A","parentIdentifier":"/us/usc/t6/s1165/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fe%2F3%2FA","sourceRelease":"119-100","text":"identify in writing to the appropriate congressional committees the portions of the plan the Secretary finds incomplete or deficient;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t6/s1165/e/3/B","parentIdentifier":"/us/usc/t6/s1165/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fe%2F3%2FB","sourceRelease":"119-100","text":"approve all other portions of the plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t6/s1165/e/3/C","parentIdentifier":"/us/usc/t6/s1165/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fe%2F3%2FC","sourceRelease":"119-100","text":"obligate the funds associated with those portions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t6/s1165/e/3/D","parentIdentifier":"/us/usc/t6/s1165/e/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Fe%2F3%2FD","sourceRelease":"119-100","text":"execute an agreement with Amtrak within 15 days thereafter on a process for resolving the remaining portions of the plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Financial contribution from other tunnel users","label":"f Financial contribution from other tunnel users","identifier":"/us/usc/t6/s1165/f","parentIdentifier":"/us/usc/t6/s1165","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t6/s1165/f/1","parentIdentifier":"/us/usc/t6/s1165/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Ff%2F1","sourceRelease":"119-100","text":"consider the extent to which railroad carriers other than Amtrak use or plan to use the tunnels;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t6/s1165/f/2","parentIdentifier":"/us/usc/t6/s1165/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Ff%2F2","sourceRelease":"119-100","text":"consider the feasibility of seeking a financial contribution from those other railroad carriers toward the costs of the projects; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t6/s1165/f/3","parentIdentifier":"/us/usc/t6/s1165/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft6%2Fs1165%2Ff%2F3","sourceRelease":"119-100","text":"obtain financial contributions or commitments from such other railroad carriers at levels reflecting the extent of their use or planned use of the tunnels, if feasible.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
