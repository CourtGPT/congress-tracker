{"type":"section","nativeType":"section","number":"7007","heading":"Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs","label":"7007 Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs","identifier":"/us/usc/t7/s7007","parentIdentifier":"/us/usc/t7/ch98/schVIII–B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7007","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t7/s7007/a","parentIdentifier":"/us/usc/t7/s7007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7007%2Fa","sourceRelease":"119-100","text":"There is established in the Department the position of Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Appointment","label":"b Appointment","identifier":"/us/usc/t7/s7007/b","parentIdentifier":"/us/usc/t7/s7007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7007%2Fb","sourceRelease":"119-100","text":"The Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs shall be appointed by the President, by and with the advice and consent of the Senate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Functions","label":"c Functions","identifier":"/us/usc/t7/s7007/c","parentIdentifier":"/us/usc/t7/s7007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7007%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Principal functions","label":"1 Principal functions","identifier":"/us/usc/t7/s7007/c/1","parentIdentifier":"/us/usc/t7/s7007/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7007%2Fc%2F1","sourceRelease":"119-100","text":"The Secretary shall delegate to the Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs those functions and duties under the jurisdiction of the Department that are related to trade and foreign agricultural affairs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Additional functions","label":"2 Additional functions","identifier":"/us/usc/t7/s7007/c/2","parentIdentifier":"/us/usc/t7/s7007/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7007%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s7007/c/2/A","parentIdentifier":"/us/usc/t7/s7007/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7007%2Fc%2F2%2FA","sourceRelease":"119-100","text":"required by law; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s7007/c/2/B","parentIdentifier":"/us/usc/t7/s7007/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs7007%2Fc%2F2%2FB","sourceRelease":"119-100","text":"prescribed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
