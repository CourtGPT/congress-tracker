{"type":"section","nativeType":"section","number":"12514","heading":"Pilot program on restorative practices","label":"12514 Pilot program on restorative practices","identifier":"/us/usc/t34/s12514","parentIdentifier":"/us/usc/t34/stI/ch121/schIII/ptP","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection not effective until Oct. 1 of the first fiscal year beginning after , see , set out as a note under , Commerce and Trade.Mar. 15, 2022section 4(a) of div. W of Pub. L. 117–103section 6851 of Title 15"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t34/s12514/a","parentIdentifier":"/us/usc/t34/s12514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Director","label":"1 Director","identifier":"/us/usc/t34/s12514/a/1","parentIdentifier":"/us/usc/t34/s12514/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F1","sourceRelease":"119-100","text":"The term “Director” means the Director of the Office on Violence Against Women.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Eligible entity","label":"2 Eligible entity","identifier":"/us/usc/t34/s12514/a/2","parentIdentifier":"/us/usc/t34/s12514/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12514/a/2/A","parentIdentifier":"/us/usc/t34/s12514/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2%2FA","sourceRelease":"119-100","text":"a State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12514/a/2/B","parentIdentifier":"/us/usc/t34/s12514/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2%2FB","sourceRelease":"119-100","text":"a unit of local government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s12514/a/2/C","parentIdentifier":"/us/usc/t34/s12514/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2%2FC","sourceRelease":"119-100","text":"a tribal government;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s12514/a/2/D","parentIdentifier":"/us/usc/t34/s12514/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2%2FD","sourceRelease":"119-100","text":"a tribal organization;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s12514/a/2/E","parentIdentifier":"/us/usc/t34/s12514/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2%2FE","sourceRelease":"119-100","text":"a victim service provider;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t34/s12514/a/2/F","parentIdentifier":"/us/usc/t34/s12514/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2%2FF","sourceRelease":"119-100","text":"an institution of higher education (as defined in ; andsection 1001(a) of title 20","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t34/s12514/a/2/G","parentIdentifier":"/us/usc/t34/s12514/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2%2FG","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12514/a/2/G/i","parentIdentifier":"/us/usc/t34/s12514/a/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2%2FG%2Fi","sourceRelease":"119-100","text":"a tribal nonprofit organization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12514/a/2/G/ii","parentIdentifier":"/us/usc/t34/s12514/a/2/G","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F2%2FG%2Fii","sourceRelease":"119-100","text":"a faith-based nonprofit organization.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Restorative practice","label":"3 Restorative practice","identifier":"/us/usc/t34/s12514/a/3","parentIdentifier":"/us/usc/t34/s12514/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12514/a/3/A","parentIdentifier":"/us/usc/t34/s12514/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FA","sourceRelease":"119-100","text":"is community-based and unaffiliated with any civil or criminal legal process;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12514/a/3/B","parentIdentifier":"/us/usc/t34/s12514/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FB","sourceRelease":"119-100","text":"is initiated by a victim of the harm;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s12514/a/3/C","parentIdentifier":"/us/usc/t34/s12514/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12514/a/3/C/i","parentIdentifier":"/us/usc/t34/s12514/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FC%2Fi","sourceRelease":"119-100","text":"1 or more individuals who committed the harm;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12514/a/3/C/ii","parentIdentifier":"/us/usc/t34/s12514/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FC%2Fii","sourceRelease":"119-100","text":"1 or more victims of the harm; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s12514/a/3/C/iii","parentIdentifier":"/us/usc/t34/s12514/a/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FC%2Fiii","sourceRelease":"119-100","text":"the community affected by the harm through 1 or more representatives of the community;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s12514/a/3/D","parentIdentifier":"/us/usc/t34/s12514/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12514/a/3/D/i","parentIdentifier":"/us/usc/t34/s12514/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FD%2Fi","sourceRelease":"119-100","text":"collectively seeking accountability from 1 or more individuals who committed the harm;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12514/a/3/D/ii","parentIdentifier":"/us/usc/t34/s12514/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FD%2Fii","sourceRelease":"119-100","text":"developing a written process whereby 1 or more individuals who committed the harm will take responsibility for the actions that caused harm to 1 or more victims of the harm; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s12514/a/3/D/iii","parentIdentifier":"/us/usc/t34/s12514/a/3/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FD%2Fiii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t34/s12514/a/3/D/iii/I","parentIdentifier":"/us/usc/t34/s12514/a/3/D/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FD%2Fiii%2FI","sourceRelease":"119-100","text":"that is responsive to the needs of 1 or more victims of the harm; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t34/s12514/a/3/D/iii/II","parentIdentifier":"/us/usc/t34/s12514/a/3/D/iii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FD%2Fiii%2FII","sourceRelease":"119-100","text":"upon which 1 or more victims, 1 or more individuals who committed the harm, and the community can agree; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s12514/a/3/E","parentIdentifier":"/us/usc/t34/s12514/a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fa%2F3%2FE","sourceRelease":"119-100","text":"is conducted in a victim services framework that protects the safety and supports the autonomy of 1 or more victims of the harm and the community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Grants authorized","label":"b Grants authorized","identifier":"/us/usc/t34/s12514/b","parentIdentifier":"/us/usc/t34/s12514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s12514/b/1","parentIdentifier":"/us/usc/t34/s12514/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fb%2F1","sourceRelease":"119-100","text":"restorative practices to prevent or address domestic violence, dating violence, sexual assault, or stalking;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s12514/b/2","parentIdentifier":"/us/usc/t34/s12514/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fb%2F2","sourceRelease":"119-100","text":"training by eligible entities, or for eligible entities, courts, or prosecutors, on restorative practices and program implementation; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t34/s12514/b/3","parentIdentifier":"/us/usc/t34/s12514/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fb%2F3","sourceRelease":"119-100","text":"evaluations of a restorative practice described in paragraph (1).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Priority","label":"c Priority","identifier":"/us/usc/t34/s12514/c","parentIdentifier":"/us/usc/t34/s12514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fc","sourceRelease":"119-100","text":"In awarding grants under subsection (b), the Director shall give priority to eligible entities that submit proposals that meaningfully address the needs of culturally specific or underserved populations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Qualifications","label":"d Qualifications","identifier":"/us/usc/t34/s12514/d","parentIdentifier":"/us/usc/t34/s12514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fd","sourceRelease":"119-100","text":"To be eligible to receive a grant under this section, an eligible entity shall demonstrate a history of comprehensive training and experience in working with victims of domestic violence, dating violence, sexual assault, or stalking.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Program requirements","label":"e Program requirements","identifier":"/us/usc/t34/s12514/e","parentIdentifier":"/us/usc/t34/s12514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t34/s12514/e/1","parentIdentifier":"/us/usc/t34/s12514/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12514/e/1/A","parentIdentifier":"/us/usc/t34/s12514/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12514/e/1/A/i","parentIdentifier":"/us/usc/t34/s12514/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FA%2Fi","sourceRelease":"119-100","text":"the history of civil and criminal complaints against the individual involving domestic violence, sexual assault, dating violence, or stalking;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12514/e/1/A/ii","parentIdentifier":"/us/usc/t34/s12514/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FA%2Fii","sourceRelease":"119-100","text":"parole or probation violations of the individual or whether active parole or probation supervision of the individual is being conducted for prior offenses involving domestic violence, sexual assault, dating violence, or stalking;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s12514/e/1/A/iii","parentIdentifier":"/us/usc/t34/s12514/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FA%2Fiii","sourceRelease":"119-100","text":"the risk to the safety of any victim of the harm based on an evidence-based risk assessment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t34/s12514/e/1/A/iv","parentIdentifier":"/us/usc/t34/s12514/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FA%2Fiv","sourceRelease":"119-100","text":"the risk to public safety, including an evidence-based risk assessment of the danger to the public; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t34/s12514/e/1/A/v","parentIdentifier":"/us/usc/t34/s12514/e/1/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FA%2Fv","sourceRelease":"119-100","text":"past participation of any individual who committed the harm in restorative practice programing; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12514/e/1/B","parentIdentifier":"/us/usc/t34/s12514/e/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12514/e/1/B/i","parentIdentifier":"/us/usc/t34/s12514/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FB%2Fi","sourceRelease":"119-100","text":"a pending felony or misdemeanor prosecution for an offense against any victim of the harm or a dependent of any such victim;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12514/e/1/B/ii","parentIdentifier":"/us/usc/t34/s12514/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FB%2Fii","sourceRelease":"119-100","text":"a restraining order or a protection order (as defined in ) that protects any victim of the harm or a dependent of any such victim, unless there is an exception in the restraining order or protective order allowing for participation in a restorative practices program;section 2266 of title 18","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s12514/e/1/B/iii","parentIdentifier":"/us/usc/t34/s12514/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"a pending criminal charge involving or relating to sexual assault, including rape, human trafficking, or child abuse, including child sexual abuse; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t34/s12514/e/1/B/iv","parentIdentifier":"/us/usc/t34/s12514/e/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"a conviction for child sexual abuse against the victim or a sibling of the victim if the victim or sibling of the victim is currently a minor.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Referral","label":"2 Referral","identifier":"/us/usc/t34/s12514/e/2","parentIdentifier":"/us/usc/t34/s12514/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fe%2F2","sourceRelease":"119-100","text":"With respect to a risk assessment described in paragraph (1)(A)(iii) for which an eligible entity or a subgrantee of an eligible entity determines that a victim or a dependent of a victim are at significant risk of subsequent serious injury, sexual assault, or death, the eligible entity or subgrantee shall refer the victim or dependent to other victim services, instead of restorative practices.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Nondisclosure of confidential or private information","label":"f Nondisclosure of confidential or private information","identifier":"/us/usc/t34/s12514/f","parentIdentifier":"/us/usc/t34/s12514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Ff","sourceRelease":"119-100","text":"For the purpose of , an individual described in subsection (a)(3)(C) shall be considered a person receiving services.section 12291(b)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"g","heading":"Relation to criminal justice intervention","label":"g Relation to criminal justice intervention","identifier":"/us/usc/t34/s12514/g","parentIdentifier":"/us/usc/t34/s12514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fg","sourceRelease":"119-100","text":"Restorative practices performed with funds awarded under this section are not intended to function as a replacement for criminal justice intervention for a specific harm.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"h","heading":"Reports","label":"h Reports","identifier":"/us/usc/t34/s12514/h","parentIdentifier":"/us/usc/t34/s12514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Report to Director","label":"1 Report to Director","identifier":"/us/usc/t34/s12514/h/1","parentIdentifier":"/us/usc/t34/s12514/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s12514/h/1/A","parentIdentifier":"/us/usc/t34/s12514/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FA","sourceRelease":"119-100","text":"the number of individuals for whom the eligible entity supported a restorative practice;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s12514/h/1/B","parentIdentifier":"/us/usc/t34/s12514/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12514/h/1/B/i","parentIdentifier":"/us/usc/t34/s12514/h/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FB%2Fi","sourceRelease":"119-100","text":"sought restorative practices from the eligible entity; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12514/h/1/B/ii","parentIdentifier":"/us/usc/t34/s12514/h/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the eligible entity could not serve;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s12514/h/1/C","parentIdentifier":"/us/usc/t34/s12514/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12514/h/1/C/i","parentIdentifier":"/us/usc/t34/s12514/h/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FC%2Fi","sourceRelease":"119-100","text":"who sought restorative practice training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12514/h/1/C/ii","parentIdentifier":"/us/usc/t34/s12514/h/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FC%2Fii","sourceRelease":"119-100","text":"who received restorative practice training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s12514/h/1/C/iii","parentIdentifier":"/us/usc/t34/s12514/h/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FC%2Fiii","sourceRelease":"119-100","text":"who provided restorative practice training; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t34/s12514/h/1/C/iv","parentIdentifier":"/us/usc/t34/s12514/h/1/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FC%2Fiv","sourceRelease":"119-100","text":"to whom the eligible entity could not provide restorative practice training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t34/s12514/h/1/D","parentIdentifier":"/us/usc/t34/s12514/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FD","sourceRelease":"119-100","text":"a victim evaluation component that is documented through survey or interview, including the satisfaction of victims of a harm with the restorative practice services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t34/s12514/h/1/E","parentIdentifier":"/us/usc/t34/s12514/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FE","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s12514/h/1/E/i","parentIdentifier":"/us/usc/t34/s12514/h/1/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FE%2Fi","sourceRelease":"119-100","text":"successfully completed and executed a written course of action plan;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s12514/h/1/E/ii","parentIdentifier":"/us/usc/t34/s12514/h/1/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FE%2Fii","sourceRelease":"119-100","text":"failed to successfully complete and execute a written course of action plan; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t34/s12514/h/1/E/iii","parentIdentifier":"/us/usc/t34/s12514/h/1/E","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FE%2Fiii","sourceRelease":"119-100","text":"were involved in a criminal or civil complaint involving domestic violence, dating violence, sexual assault, or stalking against the victims or victims during the course of the restorative practice process; and1So in original.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t34/s12514/h/1/F","parentIdentifier":"/us/usc/t34/s12514/h/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F1%2FF","sourceRelease":"119-100","text":"any other qualitative or quantitative information determined by the Director.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report to Congress","label":"2 Report to Congress","identifier":"/us/usc/t34/s12514/h/2","parentIdentifier":"/us/usc/t34/s12514/h","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fh%2F2","sourceRelease":"119-100","text":"Not later than 2 years after , and biennially thereafter, the Director shall submit to Congress a report that summarizes the reports received by the Director under paragraph (1).March 15, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"i","heading":"Authorization of appropriations","label":"i Authorization of appropriations","identifier":"/us/usc/t34/s12514/i","parentIdentifier":"/us/usc/t34/s12514","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs12514%2Fi","sourceRelease":"119-100","text":"There are authorized to be appropriated to the Director such sums as may be necessary for each of fiscal years 2023 through 2027 to carry out this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
