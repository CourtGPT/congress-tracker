{"type":"section","nativeType":"section","number":"10306","heading":"Vulnerability disclosure policy and bug bounty program report","label":"10306 Vulnerability disclosure policy and bug bounty program report","identifier":"/us/usc/t22/s10306","parentIdentifier":"/us/usc/t22/ch110","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Definitions“Department” and “Secretary” as used in this section mean the Department and Secretary of State, unless otherwise specified, see , set out as a note under .section 9002 of Pub. L. 117–263section 2651 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Definitions","label":"a Definitions","identifier":"/us/usc/t22/s10306/a","parentIdentifier":"/us/usc/t22/s10306","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Bug bounty program","label":"1 Bug bounty program","identifier":"/us/usc/t22/s10306/a/1","parentIdentifier":"/us/usc/t22/s10306/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fa%2F1","sourceRelease":"119-100","text":"The term “bug bounty program” means a program under which an approved individual, organization, or company is temporarily authorized to identify and report vulnerabilities of internet-facing information technology of the Department in exchange for compensation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Information technology","label":"2 Information technology","identifier":"/us/usc/t22/s10306/a/2","parentIdentifier":"/us/usc/t22/s10306/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fa%2F2","sourceRelease":"119-100","text":"The term “information technology” has the meaning given such term in .section 11101 of title 40","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Vulnerability Disclosure Policy","label":"b Vulnerability Disclosure Policy","identifier":"/us/usc/t22/s10306/b","parentIdentifier":"/us/usc/t22/s10306","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s10306/b/1","parentIdentifier":"/us/usc/t22/s10306/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10306/b/1/A","parentIdentifier":"/us/usc/t22/s10306/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F1%2FA","sourceRelease":"119-100","text":"creating Department policy and infrastructure to receive reports of and remediate discovered vulnerabilities in line with existing policies of the Office of Management and Budget and the Department of Homeland Security Binding Operational Directive 20–01 or any subsequent directive; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10306/b/1/B","parentIdentifier":"/us/usc/t22/s10306/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F1%2FB","sourceRelease":"119-100","text":"providing a report on such policy and infrastructure to Congress.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Annual reports","label":"2 Annual reports","identifier":"/us/usc/t22/s10306/b/2","parentIdentifier":"/us/usc/t22/s10306/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10306/b/2/A","parentIdentifier":"/us/usc/t22/s10306/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the number and severity of all security vulnerabilities reported;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10306/b/2/B","parentIdentifier":"/us/usc/t22/s10306/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the number of previously unidentified security vulnerabilities remediated as a result;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10306/b/2/C","parentIdentifier":"/us/usc/t22/s10306/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the current number of outstanding previously unidentified security vulnerabilities and Department of State remediation plans;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s10306/b/2/D","parentIdentifier":"/us/usc/t22/s10306/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F2%2FD","sourceRelease":"119-100","text":"the average time between the reporting of security vulnerabilities and remediation of such vulnerabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t22/s10306/b/2/E","parentIdentifier":"/us/usc/t22/s10306/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F2%2FE","sourceRelease":"119-100","text":"the resources, surge staffing, roles, and responsibilities within the Department used to implement the VDP and complete security vulnerability remediation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t22/s10306/b/2/F","parentIdentifier":"/us/usc/t22/s10306/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F2%2FF","sourceRelease":"119-100","text":"how the VDP identified vulnerabilities are incorporated into existing Department vulnerability prioritization and management processes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t22/s10306/b/2/G","parentIdentifier":"/us/usc/t22/s10306/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F2%2FG","sourceRelease":"119-100","text":"any challenges in implementing the VDP and plans for expansion or contraction in the scope of the VDP across Department information systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t22/s10306/b/2/H","parentIdentifier":"/us/usc/t22/s10306/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fb%2F2%2FH","sourceRelease":"119-100","text":"any other topic that the Secretary determines to be relevant.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Bug bounty program report","label":"c Bug bounty program report","identifier":"/us/usc/t22/s10306/c","parentIdentifier":"/us/usc/t22/s10306","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t22/s10306/c/1","parentIdentifier":"/us/usc/t22/s10306/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F1","sourceRelease":"119-100","text":"Not later than 180 days after , the Secretary shall submit a report to Congress that describes any ongoing efforts by the Department or a third-party vendor under contract with the Department to establish or carry out a bug bounty program that identifies security vulnerabilities of internet-facing information technology of the Department.December 23, 2022","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Report","label":"2 Report","identifier":"/us/usc/t22/s10306/c/2","parentIdentifier":"/us/usc/t22/s10306/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s10306/c/2/A","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t22/s10306/c/2/A/i","parentIdentifier":"/us/usc/t22/s10306/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"registered;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t22/s10306/c/2/A/ii","parentIdentifier":"/us/usc/t22/s10306/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"were approved;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t22/s10306/c/2/A/iii","parentIdentifier":"/us/usc/t22/s10306/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FA%2Fiii","sourceRelease":"119-100","text":"submitted security vulnerabilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t22/s10306/c/2/A/iv","parentIdentifier":"/us/usc/t22/s10306/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FA%2Fiv","sourceRelease":"119-100","text":"received compensation;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s10306/c/2/B","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FB","sourceRelease":"119-100","text":"the number and severity of all security vulnerabilities reported as part of such program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s10306/c/2/C","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FC","sourceRelease":"119-100","text":"the number of previously unidentified security vulnerabilities remediated as a result of such program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s10306/c/2/D","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FD","sourceRelease":"119-100","text":"the current number of outstanding previously unidentified security vulnerabilities and Department remediation plans for such outstanding vulnerabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t22/s10306/c/2/E","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FE","sourceRelease":"119-100","text":"the average length of time between the reporting of security vulnerabilities and remediation of such vulnerabilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"F","heading":null,"label":"F","identifier":"/us/usc/t22/s10306/c/2/F","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FF","sourceRelease":"119-100","text":"the types of compensation provided under such program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"G","heading":null,"label":"G","identifier":"/us/usc/t22/s10306/c/2/G","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FG","sourceRelease":"119-100","text":"the lessons learned from such program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"H","heading":null,"label":"H","identifier":"/us/usc/t22/s10306/c/2/H","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FH","sourceRelease":"119-100","text":"the public accessibility of contact information for the Department regarding the bug bounty program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"I","heading":null,"label":"I","identifier":"/us/usc/t22/s10306/c/2/I","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FI","sourceRelease":"119-100","text":"the incorporation of bug bounty program identified vulnerabilities into existing Department vulnerability prioritization and management processes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"J","heading":null,"label":"J","identifier":"/us/usc/t22/s10306/c/2/J","parentIdentifier":"/us/usc/t22/s10306/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs10306%2Fc%2F2%2FJ","sourceRelease":"119-100","text":"any challenges in implementing the bug bounty program and plans for expansion or contraction in the scope of the bug bounty program across Department information systems.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
