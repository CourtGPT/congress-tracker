{"type":"section","nativeType":"section","number":"1645a","heading":"Definitions","label":"1645a Definitions","identifier":"/us/usc/t22/s1645a","parentIdentifier":"/us/usc/t22/ch21/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s1645a/1","parentIdentifier":"/us/usc/t22/s1645a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s1645a/1/A","parentIdentifier":"/us/usc/t22/s1645a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F1%2FA","sourceRelease":"119-100","text":"a natural person who is a citizen of the United States; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s1645a/1/B","parentIdentifier":"/us/usc/t22/s1645a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F1%2FB","sourceRelease":"119-100","text":"a corporation or other legal entity which is organized under the laws of the United States or of any State, the District of Columbia, or the Commonwealth of Puerto Rico, if natural persons who are citizens of the United States own, directly or indirectly, 50 per centum or more of the outstanding capital stock or other beneficial interest of such corporation or entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s1645a/2","parentIdentifier":"/us/usc/t22/s1645a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F2","sourceRelease":"119-100","text":"the term “Commission” means the Foreign Claims Settlement Commission of the United States;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s1645a/3","parentIdentifier":"/us/usc/t22/s1645a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s1645a/3/A","parentIdentifier":"/us/usc/t22/s1645a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F3%2FA","sourceRelease":"119-100","text":"any property, right, or interest, including any leasehold interest,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s1645a/3/B","parentIdentifier":"/us/usc/t22/s1645a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F3%2FB","sourceRelease":"119-100","text":"any debt owed by Vietnam or by any enterprise which has been nationalized, expropriated, or otherwise taken by Vietnam, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s1645a/3/C","parentIdentifier":"/us/usc/t22/s1645a/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F3%2FC","sourceRelease":"119-100","text":"any debt which is a charge on property which has been nationalized, expropriated, or otherwise taken by Vietnam;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t22/s1645a/4","parentIdentifier":"/us/usc/t22/s1645a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s1645a/4/A","parentIdentifier":"/us/usc/t22/s1645a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F4%2FA","sourceRelease":"119-100","text":"the Government of the Socialist Republic of Vietnam,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s1645a/4/B","parentIdentifier":"/us/usc/t22/s1645a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F4%2FB","sourceRelease":"119-100","text":"any predecessor governing authority operating in South Vietnam on or after , including the Provisional Revolutionary Government of South Vietnam,April 29, 1975","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s1645a/4/C","parentIdentifier":"/us/usc/t22/s1645a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F4%2FC","sourceRelease":"119-100","text":"the Government of the former Democratic Republic of Vietnam, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t22/s1645a/4/D","parentIdentifier":"/us/usc/t22/s1645a/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F4%2FD","sourceRelease":"119-100","text":"any political subdivision, agency, or instrumentality of any of the entities referred to in subparagraphs (A), (B), and (C); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t22/s1645a/5","parentIdentifier":"/us/usc/t22/s1645a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs1645a%2F5","sourceRelease":"119-100","text":"the term “Claims Fund” means the special fund established in the Treasury of the United States composed of such sums as may be paid to or realized by the United States pursuant to the terms of any agreement settling those claims described in that may be entered into between the Governments of the United States and Vietnam.section 1645b of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
