{"type":"section","nativeType":"section","number":"10105","heading":"Retention bonuses","label":"10105 Retention bonuses","identifier":"/us/usc/t5/s10105","parentIdentifier":"/us/usc/t5/ptIII/sptI/ch101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105","sourceRelease":"119-100","text":null,"notes":["Editorial Notes","References in TextThe date of enactment of this chapter, referred to in subsec. (e), is the date of enactment of , which was approved .Pub. L. 109–295Oct. 4, 2006"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Authority","label":"a .—Authority","identifier":"/us/usc/t5/s10105/a","parentIdentifier":"/us/usc/t5/s10105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s10105/a/1","parentIdentifier":"/us/usc/t5/s10105/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fa%2F1","sourceRelease":"119-100","text":"the unusually high or unique qualifications of the employee or a special need of the Agency for the employee’s services makes it essential to retain the employee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s10105/a/2","parentIdentifier":"/us/usc/t5/s10105/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s10105/a/2/A","parentIdentifier":"/us/usc/t5/s10105/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the Federal service; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s10105/a/2/B","parentIdentifier":"/us/usc/t5/s10105/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fa%2F2%2FB","sourceRelease":"119-100","text":"for a different position in the Federal service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Service Agreement","label":"b .—Service Agreement","identifier":"/us/usc/t5/s10105/b","parentIdentifier":"/us/usc/t5/s10105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s10105/b/1","parentIdentifier":"/us/usc/t5/s10105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fb%2F1","sourceRelease":"119-100","text":"the period of service the individual shall be required to complete in return for the bonus; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s10105/b/2","parentIdentifier":"/us/usc/t5/s10105/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fb%2F2","sourceRelease":"119-100","text":"the conditions under which the agreement may be terminated before the agreed-upon service period has been completed, and the effect of the termination.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Bonus Amount.—","label":"c Bonus Amount.—","identifier":"/us/usc/t5/s10105/c","parentIdentifier":"/us/usc/t5/s10105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t5/s10105/c/1","parentIdentifier":"/us/usc/t5/s10105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fc%2F1","sourceRelease":"119-100","text":"The amount of a bonus under this section shall be determined by the Administrator, but may not exceed 25 percent of the annual rate of basic pay of the position involved.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Form of payment","label":"2 .—Form of payment","identifier":"/us/usc/t5/s10105/c/2","parentIdentifier":"/us/usc/t5/s10105/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fc%2F2","sourceRelease":"119-100","text":"A bonus under this section shall be paid in the form of a lump-sum payment and shall not be considered to be part of basic pay.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Limitation","label":"d .—Limitation","identifier":"/us/usc/t5/s10105/d","parentIdentifier":"/us/usc/t5/s10105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s10105/d/1","parentIdentifier":"/us/usc/t5/s10105/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fd%2F1","sourceRelease":"119-100","text":"may not be based on any period of service which is the basis for a recruitment bonus under section 10104;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s10105/d/2","parentIdentifier":"/us/usc/t5/s10105/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s10105/d/2/A","parentIdentifier":"/us/usc/t5/s10105/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fd%2F2%2FA","sourceRelease":"119-100","text":"a position to which an individual is appointed by the President, by and with the advice and consent of the Senate;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s10105/d/2/B","parentIdentifier":"/us/usc/t5/s10105/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fd%2F2%2FB","sourceRelease":"119-100","text":"a position in the Senior Executive Service as a noncareer appointee (as defined in section 3132(a)); or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t5/s10105/d/2/C","parentIdentifier":"/us/usc/t5/s10105/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fd%2F2%2FC","sourceRelease":"119-100","text":"a position which has been excepted from the competitive service by reason of its confidential, policy-determining, policy-making, or policy-advocating character; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s10105/d/3","parentIdentifier":"/us/usc/t5/s10105/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fd%2F3","sourceRelease":"119-100","text":"upon completion of the strategic human capital plan, shall be paid in accordance with that plan.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":".—Termination of Authority","label":"e .—Termination of Authority","identifier":"/us/usc/t5/s10105/e","parentIdentifier":"/us/usc/t5/s10105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Fe","sourceRelease":"119-100","text":"The authority to grant bonuses under this section shall expire 5 years after the date of enactment of this chapter.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"f","heading":"Reports.—","label":"f Reports.—","identifier":"/us/usc/t5/s10105/f","parentIdentifier":"/us/usc/t5/s10105","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Ff","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t5/s10105/f/1","parentIdentifier":"/us/usc/t5/s10105/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Ff%2F1","sourceRelease":"119-100","text":"The Office of Personnel Management shall submit to the appropriate committees of Congress, annually for each of the first 5 years during which this section is in effect, a report on the operation of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Contents","label":"2 .—Contents","identifier":"/us/usc/t5/s10105/f/2","parentIdentifier":"/us/usc/t5/s10105/f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Ff%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s10105/f/2/A","parentIdentifier":"/us/usc/t5/s10105/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Ff%2F2%2FA","sourceRelease":"119-100","text":"the number and dollar amount of bonuses paid to individuals holding positions within each pay grade, pay level, or other pay classification; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s10105/f/2/B","parentIdentifier":"/us/usc/t5/s10105/f/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs10105%2Ff%2F2%2FB","sourceRelease":"119-100","text":"a determination of the extent to which such bonuses furthered the purposes of this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]}
