[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s17033/b/2","parentIdentifier":"/us/usc/t42/s17033/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17033%2Fb%2F2","sourceRelease":"119-100","text":"make information available relating to processes and technologies for renewable fuel production;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t42/s17033/b/3","parentIdentifier":"/us/usc/t42/s17033/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17033%2Fb%2F3","sourceRelease":"119-100","text":"make information available to interested parties on the process for establishing a biorefinery; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t42/s17033/b/4","parentIdentifier":"/us/usc/t42/s17033/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17033%2Fb%2F4","sourceRelease":"119-100","text":"make information and assistance provided by the center available through a toll-free telephone number and website.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Coordination and nonduplication","label":"c Coordination and nonduplication","identifier":"/us/usc/t42/s17033/c","parentIdentifier":"/us/usc/t42/s17033","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs17033%2Fc","sourceRelease":"119-100","text":"To the maximum extent practicable, the Secretary shall ensure that the activities under this section are coordinated with, and do not duplicate the efforts of, centers at other government agencies.","notes":[],"amendments":[],"effectiveDate":null,"