{"type":"section","nativeType":"section","number":"3478","heading":"Facilities at remote locations","label":"3478 Facilities at remote locations","identifier":"/us/usc/t20/s3478","parentIdentifier":"/us/usc/t20/ch48/schIV/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Authorized services, supplies and facilities","label":"a Authorized services, supplies and facilities","identifier":"/us/usc/t20/s3478/a","parentIdentifier":"/us/usc/t20/s3478","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s3478/a/1","parentIdentifier":"/us/usc/t20/s3478/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fa%2F1","sourceRelease":"119-100","text":"emergency medical services and supplies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t20/s3478/a/2","parentIdentifier":"/us/usc/t20/s3478/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fa%2F2","sourceRelease":"119-100","text":"food and other subsistence supplies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t20/s3478/a/3","parentIdentifier":"/us/usc/t20/s3478/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fa%2F3","sourceRelease":"119-100","text":"dining facilities;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t20/s3478/a/4","parentIdentifier":"/us/usc/t20/s3478/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fa%2F4","sourceRelease":"119-100","text":"audiovisual equipment, accessories, and supplies for recreation and training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t20/s3478/a/5","parentIdentifier":"/us/usc/t20/s3478/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fa%2F5","sourceRelease":"119-100","text":"reimbursement for food, clothing, medicine, and other supplies furnished by such employees in emergencies for the temporary relief of distressed persons;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t20/s3478/a/6","parentIdentifier":"/us/usc/t20/s3478/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fa%2F6","sourceRelease":"119-100","text":"living and working quarters and facilities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t20/s3478/a/7","parentIdentifier":"/us/usc/t20/s3478/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fa%2F7","sourceRelease":"119-100","text":"transportation for dependents of employees of the Department to the nearest appropriate educational facilities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Reimbursements","label":"b Reimbursements","identifier":"/us/usc/t20/s3478/b","parentIdentifier":"/us/usc/t20/s3478","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fb","sourceRelease":"119-100","text":"The furnishing of medical treatment under paragraph (1) of subsection (a) and the furnishing of services and supplies under paragraphs (2), (3), and (4) of subsection (a) shall be at prices reflecting reasonable value as determined by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Appropriation credits and refunds","label":"c Appropriation credits and refunds","identifier":"/us/usc/t20/s3478/c","parentIdentifier":"/us/usc/t20/s3478","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3478%2Fc","sourceRelease":"119-100","text":"Proceeds from reimbursements under this section may be credited to the appropriation of funds that bear or will bear all or part of the cost of such work or services or used to refund excess sums when necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
