{"type":"section","nativeType":"section","number":"3426","heading":"Liaison for Proprietary Institutions of Higher Education","label":"3426 Liaison for Proprietary Institutions of Higher Education","identifier":"/us/usc/t20/s3426","parentIdentifier":"/us/usc/t20/ch48/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3426","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , except as otherwise provided in , see , set out as an Effective Date of 1998 Amendment note under .Oct. 1, 1998Pub. L. 105–244section 3 of Pub. L. 105–244section 1001 of this title"],"amendments":["Effective DateSection effective , except as otherwise provided in , see , set out as an Effective Date of 1998 Amendment note under .Oct. 1, 1998Pub. L. 105–244section 3 of Pub. L. 105–244section 1001 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment","label":"a Establishment","identifier":"/us/usc/t20/s3426/a","parentIdentifier":"/us/usc/t20/s3426","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3426%2Fa","sourceRelease":"119-100","text":"There shall be in the Department a Liaison for Proprietary Institutions of Higher Education, who shall be an officer of the Department appointed by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Appointment","label":"b Appointment","identifier":"/us/usc/t20/s3426/b","parentIdentifier":"/us/usc/t20/s3426","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs3426%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t20/s3426/b/1","parentIdentifier":"/us/usc/t20/s3426/b","sourceUrl":"h