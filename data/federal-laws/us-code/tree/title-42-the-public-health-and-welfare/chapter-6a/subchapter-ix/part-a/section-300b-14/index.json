","text":"the diagnostic confirmation of positive screening results;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t42/s300b–14/b/6","parentIdentifier":"/us/usc/t42/s300b–14/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300b%E2%80%9314%2Fb%2F6","sourceRelease":"119-100","text":"ensuring the availability of treatment and management resources;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t42/s300b–14/b/7","parentIdentifier":"/us/usc/t42/s300b–14/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300b%E2%80%9314%2Fb%2F7","sourceRelease":"119-100","text":"educating families about newborn screening; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t42/s300b–14/b/8","parentIdentifier":"/us/usc/t42/s300b–14/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs300b%E2%80%9314%2Fb%2F8","sourceRelease":"119-100","text":"carrying out other activities determined appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
