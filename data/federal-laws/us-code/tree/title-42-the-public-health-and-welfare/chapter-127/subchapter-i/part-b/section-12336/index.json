{"type":"section","nativeType":"section","number":"12336","heading":"Independent State body","label":"12336 Independent State body","identifier":"/us/usc/t42/s12336","parentIdentifier":"/us/usc/t42/ch127/schI/ptB","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as an Effective Date of 1990 Amendment note under .Oct. 1, 1990section 1001(a) of Pub. L. 101–501section 8621 of this title"],"amendments":["Effective DateSection effective , see , set out as an Effective Date of 1990 Amendment note under .Oct. 1, 1990section 1001(a) of Pub. L. 101–501section 8621 of this title"],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Designation","label":"a Designation","identifier":"/us/usc/t42/s12336/a","parentIdentifier":"/us/usc/t42/s12336","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t42/s12336/a/1","parentIdentifier":"/us/usc/t42/s12336/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s12336/a/1/A","parentIdentifier":"/us/usc/t42/s12336/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FA","sourceRelease":"119-100","text":"cabinet level representatives from each agency of such State that has responsibilities for programs affecting young individuals who shall comprise a majority of the independent State body; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s12336/a/1/B","parentIdentifier":"/us/usc/t42/s12336/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s12336/a/1/B/i","parentIdentifier":"/us/usc/t42/s12336/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"private nonprofit providers of services to young individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s12336/a/1/B/ii","parentIdentifier":"/us/usc/t42/s12336/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"advocacy and citizens groups concerned with young individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s12336/a/1/B/iii","parentIdentifier":"/us/usc/t42/s12336/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"committees of the legislature of such State that have responsibility for young individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t42/s12336/a/1/B/iv","parentIdentifier":"/us/usc/t42/s12336/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"leaders who are young individuals, including such leaders who are recipients of services provided under this subchapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t42/s12336/a/1/B/v","parentIdentifier":"/us/usc/t42/s12336/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fv","sourceRelease":"119-100","text":"representatives of the business community;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t42/s12336/a/1/B/vi","parentIdentifier":"/us/usc/t42/s12336/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fvi","sourceRelease":"119-100","text":"representatives of employees of providers of services to young individuals;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t42/s12336/a/1/B/vii","parentIdentifier":"/us/usc/t42/s12336/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fvii","sourceRelease":"119-100","text":"representatives of general purpose local government; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t42/s12336/a/1/B/viii","parentIdentifier":"/us/usc/t42/s12336/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fviii","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t42/s12336/a/1/B/viii/I","parentIdentifier":"/us/usc/t42/s12336/a/1/B/viii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fviii%2FI","sourceRelease":"119-100","text":"develop a State plan to be submitted to the Commissioner for approval under ;section 12337 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t42/s12336/a/1/B/viii/II","parentIdentifier":"/us/usc/t42/s12336/a/1/B/viii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fviii%2FII","sourceRelease":"119-100","text":"administer and monitor the State plan within such State;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"III","heading":null,"label":"III","identifier":"/us/usc/t42/s12336/a/1/B/viii/III","parentIdentifier":"/us/usc/t42/s12336/a/1/B/viii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fviii%2FIII","sourceRelease":"119-100","text":"assist in the coordination of all State activities related to the purpose of the chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"IV","heading":null,"label":"IV","identifier":"/us/usc/t42/s12336/a/1/B/viii/IV","parentIdentifier":"/us/usc/t42/s12336/a/1/B/viii","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F1%2FB%2Fviii%2FIV","sourceRelease":"119-100","text":"serve as an effective and visible advocate for young individuals by reviewing and commenting on all State plans, budgets, and policies that affect such individuals and the families of such individuals by providing technical assistance to any agency, organization, association, or individual representing the needs of young individuals; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t42/s12336/a/2","parentIdentifier":"/us/usc/t42/s12336/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t42/s12336/a/2/A","parentIdentifier":"/us/usc/t42/s12336/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F2%2FA","sourceRelease":"119-100","text":"develops a system for the distribution within the State of funds received under sections 12337 and 12338 of this title by the chief executive officer;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t42/s12336/a/2/B","parentIdentifier":"/us/usc/t42/s12336/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F2%2FB","sourceRelease":"119-100","text":"submits a description of such system to the Commissioner for review and comment; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t42/s12336/a/2/C","parentIdentifier":"/us/usc/t42/s12336/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t42/s12336/a/2/C/i","parentIdentifier":"/us/usc/t42/s12336/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F2%2FC%2Fi","sourceRelease":"119-100","text":"provide a range of services organized to tailor responses to needs rather than a predetermined array of services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t42/s12336/a/2/C/ii","parentIdentifier":"/us/usc/t42/s12336/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F2%2FC%2Fii","sourceRelease":"119-100","text":"are rooted in and part of the communities that such systems are designed to serve as measured by the degree to which public and private community leaders and young individuals participate in the planning of such systems; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t42/s12336/a/2/C/iii","parentIdentifier":"/us/usc/t42/s12336/a/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fa%2F2%2FC%2Fiii","sourceRelease":"119-100","text":"demonstrate an ability to develop systematic collaboration among service providers on behalf of children, youth and families, including joint planning, joint financing, joint service delivery, common intake and assessment, and other arrangements that promote more effective service systems for such individuals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Existing entity","label":"b Existing entity","identifier":"/us/usc/t42/s12336/b","parentIdentifier":"/us/usc/t42/s12336","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft42%2Fs12336%2Fb","sourceRelease":"119-100","text":"The Commissioner may approve a State plan in which the chief executive officer of the State designates as the independent State body an existing State entity that is comprised of the parties described in subsection (a) and that is authorized to conduct the same range of interagency planning and coordination activities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
