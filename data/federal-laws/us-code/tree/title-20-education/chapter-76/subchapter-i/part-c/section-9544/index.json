{"type":"section","nativeType":"section","number":"9544","heading":"Performance of duties","label":"9544 Performance of duties","identifier":"/us/usc/t20/s9544","parentIdentifier":"/us/usc/t20/ch76/schI/ptC","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Grants, contracts, and cooperative agreements","label":"a Grants, contracts, and cooperative agreements","identifier":"/us/usc/t20/s9544/a","parentIdentifier":"/us/usc/t20/s9544","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fa","sourceRelease":"119-100","text":"In carrying out the duties under this part, the Statistics Commissioner, may award grants, enter into contracts and cooperative agreements, and provide technical assistance.1So in original. The comma probably should not appear.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Gathering information","label":"b Gathering information","identifier":"/us/usc/t20/s9544/b","parentIdentifier":"/us/usc/t20/s9544","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Sampling","label":"1 Sampling","identifier":"/us/usc/t20/s9544/b/1","parentIdentifier":"/us/usc/t20/s9544/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F1","sourceRelease":"119-100","text":"The Statistics Commissioner may use the statistical method known as sampling (including random sampling) to carry out this part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Source of information","label":"2 Source of information","identifier":"/us/usc/t20/s9544/b/2","parentIdentifier":"/us/usc/t20/s9544/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s9544/b/2/A","parentIdentifier":"/us/usc/t20/s9544/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F2%2FA","sourceRelease":"119-100","text":"from States, local educational agencies, public and private schools, preschools, institutions of higher education, vocational and adult education programs, libraries, administrators, teachers, students, the general public, and other individuals, organizations, agencies, and institutions (including information collected by States and local educational agencies for their own use); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s9544/b/2/B","parentIdentifier":"/us/usc/t20/s9544/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F2%2FB","sourceRelease":"119-100","text":"by other offices within the Institute and by other Federal departments, agencies, and instrumentalities.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Collection","label":"3 Collection","identifier":"/us/usc/t20/s9544/b/3","parentIdentifier":"/us/usc/t20/s9544/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s9544/b/3/A","parentIdentifier":"/us/usc/t20/s9544/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F3%2FA","sourceRelease":"119-100","text":"enter into interagency agreements for the collection of statistics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s9544/b/3/B","parentIdentifier":"/us/usc/t20/s9544/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F3%2FB","sourceRelease":"119-100","text":"arrange with any agency, organization, or institution for the collection of statistics; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t20/s9544/b/3/C","parentIdentifier":"/us/usc/t20/s9544/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F3%2FC","sourceRelease":"119-100","text":"assign employees of the Statistics Center to any such agency, organization, or institution to assist in such collection.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Technical assistance and coordination","label":"4 Technical assistance and coordination","identifier":"/us/usc/t20/s9544/b/4","parentIdentifier":"/us/usc/t20/s9544/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t20/s9544/b/4/A","parentIdentifier":"/us/usc/t20/s9544/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F4%2FA","sourceRelease":"119-100","text":"provide technical assistance to the Department offices that gather data for statistical purposes; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t20/s9544/b/4/B","parentIdentifier":"/us/usc/t20/s9544/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fb%2F4%2FB","sourceRelease":"119-100","text":"coordinate with other Department offices in the collection of data.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Duration","label":"c Duration","identifier":"/us/usc/t20/s9544/c","parentIdentifier":"/us/usc/t20/s9544","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft20%2Fs9544%2Fc","sourceRelease":"119-100","text":"Notwithstanding any other provision of law, the grants, contracts, and cooperative agreements under this section may be awarded, on a competitive basis, for a period of not more than 5 years, and may be renewed at the discretion of the Statistics Commissioner for an additional period of not more than 5 years.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
