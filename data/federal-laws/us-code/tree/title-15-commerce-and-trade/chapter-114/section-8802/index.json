{"type":"section","nativeType":"section","number":"8802","heading":"Purposes","label":"8802 Purposes","identifier":"/us/usc/t15/s8802","parentIdentifier":"/us/usc/t15/ch114","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t15/s8802/1","parentIdentifier":"/us/usc/t15/s8802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8802/1/A","parentIdentifier":"/us/usc/t15/s8802/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F1%2FA","sourceRelease":"119-100","text":"to expand the number of researchers, educators, and students with training in quantum information science and technology to develop a workforce pipeline;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8802/1/B","parentIdentifier":"/us/usc/t15/s8802/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F1%2FB","sourceRelease":"119-100","text":"to promote the development and inclusion of multidisciplinary curriculum and research opportunities for quantum information science at the undergraduate, graduate, and postdoctoral level;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t15/s8802/1/C","parentIdentifier":"/us/usc/t15/s8802/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F1%2FC","sourceRelease":"119-100","text":"to address basic research knowledge gaps, including computational research gaps;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t15/s8802/1/D","parentIdentifier":"/us/usc/t15/s8802/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F1%2FD","sourceRelease":"119-100","text":"to promote the further development of facilities and centers available for quantum information science and technology research, testing and education; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"E","heading":null,"label":"E","identifier":"/us/usc/t15/s8802/1/E","parentIdentifier":"/us/usc/t15/s8802/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F1%2FE","sourceRelease":"119-100","text":"to stimulate research on and promote more rapid development of quantum-based technologies;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t15/s8802/2","parentIdentifier":"/us/usc/t15/s8802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F2","sourceRelease":"119-100","text":"improving the interagency planning and coordination of Federal research and development of quantum information science and technology;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t15/s8802/3","parentIdentifier":"/us/usc/t15/s8802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F3","sourceRelease":"119-100","text":"maximizing the effectiveness of the Federal Government’s quantum information science and technology research, development, and demonstration programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t15/s8802/4","parentIdentifier":"/us/usc/t15/s8802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F4","sourceRelease":"119-100","text":"promoting collaboration among the Federal Government, Federal laboratories, industry, and universities; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t15/s8802/5","parentIdentifier":"/us/usc/t15/s8802","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t15/s8802/5/A","parentIdentifier":"/us/usc/t15/s8802/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F5%2FA","sourceRelease":"119-100","text":"to facilitate technology innovation and private sector commercialization; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t15/s8802/5/B","parentIdentifier":"/us/usc/t15/s8802/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft15%2Fs8802%2F5%2FB","sourceRelease":"119-100","text":"to meet economic and national security goals.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
