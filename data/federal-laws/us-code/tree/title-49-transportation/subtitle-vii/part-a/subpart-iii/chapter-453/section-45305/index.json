s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F2","sourceRelease":"119-100","text":"Reregistering, replacing, or renewing an aircraft registration certificate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t49/s45305/a/3","parentIdentifier":"/us/usc/t49/s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F3","sourceRelease":"119-100","text":"Issuing an original dealer’s aircraft registration certificate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t49/s45305/a/4","parentIdentifier":"/us/usc/t49/s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F4","sourceRelease":"119-100","text":"Issuing an additional dealer’s aircraft registration certificate (other than the original).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t49/s45305/a/5","parentIdentifier":"/us/usc/t49/s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F5","sourceRelease":"119-100","text":"Issuing a special registration number.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t49/s45305/a/6","parentIdentifier":"/us/usc/t49/s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F6","sourceRelease":"119-100","text":"Issuing a renewal of a special registration number reservation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t49/s45305/a/7","parentIdentifier":"/us/usc/t49/s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F7","sourceRelease":"119-100","text":"Recording a security interest in an aircraft or aircraft part.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"8","heading":null,"label":"8","identifier":"/us/usc/t49/s45305/a/8","parentIdentifier":"/us/usc/t49/s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F8","sourceRelease":"119-100","text":"Issuing an airman certificate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"9","heading":null,"label":"9","identifier":"/us/usc/t49/s45305/a/9","parentIdentifier":"/us/usc/t49/s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F9","sourceRelease":"119-100","text":"Issuing a replacement airman certificate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"10","heading":null,"label":"10","identifier":"/us/usc/t49/s45305/a/10","parentIdentifier":"/us/usc/t49/s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F10","sourceRelease":"119-100","text":"Issuing an airman medical certificate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"11","heading":null,"label":"11","identifier":"/us/usc/t49/s45305/a/11","parentIdentifier":"/us/usc/t49/s45305/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fa%2F11","sourceRelease":"119-100","text":"Providing a legal opinion pertaining to aircraft registration or recordation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Certification Services","label":"b .—Certification Services","identifier":"/us/usc/t49/s45305/b","parentIdentifier":"/us/usc/t49/s45305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t49/s45305/b/1","parentIdentifier":"/us/usc/t49/s45305/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fb%2F1","sourceRelease":"119-100","text":"is established and collected in a manner consistent with aviation safety agreements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t49/s45305/b/2","parentIdentifier":"/us/usc/t49/s45305/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fb%2F2","sourceRelease":"119-100","text":"does not exceed the estimated costs of the services.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Limitation on Collection","label":"c .—Limitation on Collection","identifier":"/us/usc/t49/s45305/c","parentIdentifier":"/us/usc/t49/s45305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fc","sourceRelease":"119-100","text":"No fee may be collected under this section unless the expenditure of the fee to pay the costs of activities and services for which the fee is imposed is provided for in advance in an appropriations Act.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Fees Credited as Offsetting Collections.—","label":"d Fees Credited as Offsetting Collections.—","identifier":"/us/usc/t49/s45305/d","parentIdentifier":"/us/usc/t49/s45305","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t49/s45305/d/1","parentIdentifier":"/us/usc/t49/s45305/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t49/s45305/d/1/A","parentIdentifier":"/us/usc/t49/s45305/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fd%2F1%2FA","sourceRelease":"119-100","text":"be credited as offsetting collections to the account that finances the activities and services for which the fee is imposed;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t49/s45305/d/1/B","parentIdentifier":"/us/usc/t49/s45305/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fd%2F1%2FB","sourceRelease":"119-100","text":"be available for expenditure only to pay the costs of activities and services for which the fee is imposed, including all costs associated with collecting the fee; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t49/s45305/d/1/C","parentIdentifier":"/us/usc/t49/s45305/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fd%2F1%2FC","sourceRelease":"119-100","text":"remain available until expended.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Continuing appropriations","label":"2 .—Continuing appropriations","identifier":"/us/usc/t49/s45305/d/2","parentIdentifier":"/us/usc/t49/s45305/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fd%2F2","sourceRelease":"119-100","text":"The Administrator may continue to assess, collect, and spend fees established under this section during any period in which the funding for the Federal Aviation Administration is provided under an Act providing continuing appropriations in lieu of the Administration’s regular appropriations.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Adjustments","label":"3 .—Adjustments","identifier":"/us/usc/t49/s45305/d/3","parentIdentifier":"/us/usc/t49/s45305/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft49%2Fs45305%2Fd%2F3","sourceRelease":"119-100","text":"The Administrator shall adjust a fee established under subsection (a) for a service or activity if the Administrator determines that the actual cost of the service or activity is higher or lower than was indicated by the cost data used to establish such fee.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
