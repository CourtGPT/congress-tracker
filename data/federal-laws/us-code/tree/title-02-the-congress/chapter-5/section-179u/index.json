{"type":"section","nativeType":"section","number":"179u","heading":"Definitions","label":"179u Definitions","identifier":"/us/usc/t2/s179u","parentIdentifier":"/us/usc/t2/ch5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs179u","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t2/s179u/1","parentIdentifier":"/us/usc/t2/s179u","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs179u%2F1","sourceRelease":"119-100","text":"the term “Librarian” means the Librarian of Congress;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t2/s179u/2","parentIdentifier":"/us/usc/t2/s179u","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs179u%2F2","sourceRelease":"119-100","text":"the term “Board” means the National Film Preservation Board;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t2/s179u/3","parentIdentifier":"/us/usc/t2/s179u","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs179u%2F3","sourceRelease":"119-100","text":"the term “film” means a “motion picture” as defined in , except that such term does not include any work not originally fixed on film stock, such as a work fixed on videotape or laser disk;section 101 of title 17","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t2/s179u/4","parentIdentifier":"/us/usc/t2/s179u","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs179u%2F4","sourceRelease":"119-100","text":"the term “publication” means “publication” as defined in ; andsection 101 of title 17","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t2/s179u/5","parentIdentifier":"/us/usc/t2/s179u","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft2%2Fs179u%2F5","sourceRelease":"119-100","text":"the term “Registry version” means, with respect to a film, the version of a film first published, or as complete a version as bona fide preservation and restoration activities by the Librarian, an archivist other than the Librarian, or the copyright owner can compile in those cases where the original material has been irretrievably lost.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
