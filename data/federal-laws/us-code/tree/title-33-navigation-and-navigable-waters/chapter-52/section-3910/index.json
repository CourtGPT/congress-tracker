{"type":"section","nativeType":"section","number":"3910","heading":"State, tribal, and local permits","label":"3910 State, tribal, and local permits","identifier":"/us/usc/t33/s3910","parentIdentifier":"/us/usc/t33/ch52","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3910","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s3910/1","parentIdentifier":"/us/usc/t33/s3910","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3910%2F1","sourceRelease":"119-100","text":"relieve any recipient of the assistance of any obligation to obtain any required State, local, or tribal permit or approval with respect to the project;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s3910/2","parentIdentifier":"/us/usc/t33/s3910","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3910%2F2","sourceRelease":"119-100","text":"limit the right of any unit of State, local, or tribal government to approve or regulate any rate of return on private equity invested in the project; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s3910/3","parentIdentifier":"/us/usc/t33/s3910","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3910%2F3","sourceRelease":"119-100","text":"otherwise supersede any State, local, or tribal law (including any regulation) applicable to the construction or operation of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
