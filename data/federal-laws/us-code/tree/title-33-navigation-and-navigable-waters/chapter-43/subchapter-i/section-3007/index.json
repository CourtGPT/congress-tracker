{"type":"section","nativeType":"section","number":"3007","heading":"Training and physical fitness","label":"3007 Training and physical fitness","identifier":"/us/usc/t33/s3007","parentIdentifier":"/us/usc/t33/ch43/schI","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3007","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Training","label":"a Training","identifier":"/us/usc/t33/s3007/a","parentIdentifier":"/us/usc/t33/s3007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3007%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t33/s3007/a/1","parentIdentifier":"/us/usc/t33/s3007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3007%2Fa%2F1","sourceRelease":"119-100","text":"Carrying out training programs and correspondence courses, including establishing and operating a basic officer training program to provide initial indoctrination and maritime vocational training for officer candidates as well as refresher training, mid-career training, aviation training, and such other training as the Secretary considers necessary for officer development and proficiency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t33/s3007/a/2","parentIdentifier":"/us/usc/t33/s3007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3007%2Fa%2F2","sourceRelease":"119-100","text":"Providing officers and officer candidates with educational materials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t33/s3007/a/3","parentIdentifier":"/us/usc/t33/s3007/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3007%2Fa%2F3","sourceRelease":"119-100","text":"Acquiring such equipment as may be necessary for training and instructional purposes.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Physical fitness","label":"b Physical fitness","identifier":"/us/usc/t33/s3007/b","parentIdentifier":"/us/usc/t33/s3007","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft33%2Fs3007%2Fb","sourceRelease":"119-100","text":"The Secretary shall ensure that officers maintain a high physical state of readiness by establishing standards of physical fitness for officers that are substantially equivalent to those prescribed for officers in the Coast Guard.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
