{"type":"section","nativeType":"section","number":"21904","heading":"Minimum standards for issuance and dissemination of alerts through Ashanti Alert communications network","label":"21904 Minimum standards for issuance and dissemination of alerts through Ashanti Alert communications network","identifier":"/us/usc/t34/s21904","parentIdentifier":"/us/usc/t34/stII/ch219","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Establishment of minimum standards","label":"a Establishment of minimum standards","identifier":"/us/usc/t34/s21904/a","parentIdentifier":"/us/usc/t34/s21904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t34/s21904/a/1","parentIdentifier":"/us/usc/t34/s21904/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fa%2F1","sourceRelease":"119-100","text":"the issuance of alerts through the Ashanti Alert communications network; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t34/s21904/a/2","parentIdentifier":"/us/usc/t34/s21904/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fa%2F2","sourceRelease":"119-100","text":"the extent of the dissemination of alerts issued through the Ashanti Alert communications network.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Limitations","label":"b Limitations","identifier":"/us/usc/t34/s21904/b","parentIdentifier":"/us/usc/t34/s21904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Dissemination of information","label":"1 Dissemination of information","identifier":"/us/usc/t34/s21904/b/1","parentIdentifier":"/us/usc/t34/s21904/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F1","sourceRelease":"119-100","text":"The minimum standards established under subsection (a) shall, to the maximum extent practicable (as determined by the Coordinator in consultation with State, Tribal, and local law enforcement agencies), provide for the dissemination of appropriate information relating to the special needs of a missing adult (including health care needs) to the appropriate law enforcement, public health, and other public officials.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Geographic areas","label":"2 Geographic areas","identifier":"/us/usc/t34/s21904/b/2","parentIdentifier":"/us/usc/t34/s21904/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21904/b/2/A","parentIdentifier":"/us/usc/t34/s21904/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the circumstances and physical and mental condition of the missing adult;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21904/b/2/B","parentIdentifier":"/us/usc/t34/s21904/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the modes of transportation available to the missing adult; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s21904/b/2/C","parentIdentifier":"/us/usc/t34/s21904/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F2%2FC","sourceRelease":"119-100","text":"the circumstances of the disappearance.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Other requirements","label":"3 Other requirements","identifier":"/us/usc/t34/s21904/b/3","parentIdentifier":"/us/usc/t34/s21904/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21904/b/3/A","parentIdentifier":"/us/usc/t34/s21904/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F3%2FA","sourceRelease":"119-100","text":"suffers from a proven mental or physical disability, as documented by a source determined credible by an appropriate law enforcement agency; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21904/b/3/B","parentIdentifier":"/us/usc/t34/s21904/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F3%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t34/s21904/b/3/B/i","parentIdentifier":"/us/usc/t34/s21904/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F3%2FB%2Fi","sourceRelease":"119-100","text":"that the physical safety of the missing adult may be endangered; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t34/s21904/b/3/B/ii","parentIdentifier":"/us/usc/t34/s21904/b/3/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F3%2FB%2Fii","sourceRelease":"119-100","text":"that the disappearance of the missing adult may not have been voluntary, including an abduction or kidnapping.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":"Safety, privacy, and civil liberties protections","label":"4 Safety, privacy, and civil liberties protections","identifier":"/us/usc/t34/s21904/b/4","parentIdentifier":"/us/usc/t34/s21904/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F4","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t34/s21904/b/4/A","parentIdentifier":"/us/usc/t34/s21904/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F4%2FA","sourceRelease":"119-100","text":"ensure that alerts issued through the Ashanti Alert communications network comply with all applicable Federal, State, Tribal, and local privacy laws and regulations;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t34/s21904/b/4/B","parentIdentifier":"/us/usc/t34/s21904/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F4%2FB","sourceRelease":"119-100","text":"include standards that specifically provide for the protection of the civil liberties and sensitive medical information of missing adults; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t34/s21904/b/4/C","parentIdentifier":"/us/usc/t34/s21904/b/4","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F4%2FC","sourceRelease":"119-100","text":"include standards requiring, as appropriate, a review of relevant court records, prior contacts with law enforcement, and other information relevant to the missing adult or the individual reporting, in order to provide protections against domestic violence.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":"State, Tribal, and local voluntary coordination","label":"5 State, Tribal, and local voluntary coordination","identifier":"/us/usc/t34/s21904/b/5","parentIdentifier":"/us/usc/t34/s21904/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft34%2Fs21904%2Fb%2F5","sourceRelease":"119-100","text":"In establishing minimum standards under subsection (a), the Coordinator may not interfere with the system of voluntary coordination between local broadcasters and State, Tribal, and local law enforcement agencies for purposes of regional and local search efforts for missing adults that was in effect on the day before .December 31, 2018","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
