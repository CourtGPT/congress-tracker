{"type":"section","nativeType":"section","number":"1807","heading":"Form I–94 fee","label":"1807 Form I–94 fee","identifier":"/us/usc/t8/s1807","parentIdentifier":"/us/usc/t8/ch16","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Fee authorized","label":"a Fee authorized","identifier":"/us/usc/t8/s1807/a","parentIdentifier":"/us/usc/t8/s1807","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fa","sourceRelease":"119-100","text":"In addition to any other fee authorized by law, the Secretary of Homeland Security shall require the payment of a fee, equal to the amount specified in subsection (b), by any alien who submits an application for a Form I–94 Arrival/Departure Record.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Amount specified","label":"b Amount specified","identifier":"/us/usc/t8/s1807/b","parentIdentifier":"/us/usc/t8/s1807","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"Initial amount","label":"1 Initial amount","identifier":"/us/usc/t8/s1807/b/1","parentIdentifier":"/us/usc/t8/s1807/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1807/b/1/A","parentIdentifier":"/us/usc/t8/s1807/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fb%2F1%2FA","sourceRelease":"119-100","text":"$24; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1807/b/1/B","parentIdentifier":"/us/usc/t8/s1807/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fb%2F1%2FB","sourceRelease":"119-100","text":"such amount as the Secretary of Homeland Security may establish, by rule.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Annual adjustments for inflation","label":"2 Annual adjustments for inflation","identifier":"/us/usc/t8/s1807/b/2","parentIdentifier":"/us/usc/t8/s1807/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1807/b/2/A","parentIdentifier":"/us/usc/t8/s1807/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fb%2F2%2FA","sourceRelease":"119-100","text":"the amount of the fee required under this subsection for the most recently concluded fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1807/b/2/B","parentIdentifier":"/us/usc/t8/s1807/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fb%2F2%2FB","sourceRelease":"119-100","text":"the product resulting from the multiplication of the amount referred to in subparagraph (A) by the percentage (if any) by which the Consumer Price Index for All Urban Consumers for the month of July preceding the date on which such adjustment takes effect exceeds the Consumer Price Index for All Urban Consumers for the same month of the preceding calendar year, rounded down to the nearest dollar.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Disposition of Form I–94 fees","label":"c Disposition of Form I–94 fees","identifier":"/us/usc/t8/s1807/c","parentIdentifier":"/us/usc/t8/s1807","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t8/s1807/c/1","parentIdentifier":"/us/usc/t8/s1807/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t8/s1807/c/1/A","parentIdentifier":"/us/usc/t8/s1807/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fc%2F1%2FA","sourceRelease":"119-100","text":"shall be deposited into the Land Border Inspection Fee Account in accordance with ; andsection 1356(q)(2) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t8/s1807/c/1/B","parentIdentifier":"/us/usc/t8/s1807/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fc%2F1%2FB","sourceRelease":"119-100","text":"shall be made available to U.S. Customs and Border Protection to retain and spend without further appropriation for the purpose of processing Form I–94; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t8/s1807/c/2","parentIdentifier":"/us/usc/t8/s1807/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fc%2F2","sourceRelease":"119-100","text":"any amounts not deposited into the Land Border Inspection Fee Account pursuant to paragraph (1)(A) shall be deposited in the general fund of the Treasury.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"No fee waiver","label":"d No fee waiver","identifier":"/us/usc/t8/s1807/d","parentIdentifier":"/us/usc/t8/s1807","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft8%2Fs1807%2Fd","sourceRelease":"119-100","text":"Fees required to be paid under this section shall not be waived or reduced.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
