{"type":"section","nativeType":"section","number":"4101","heading":"Congressional findings and policy","label":"4101 Congressional findings and policy","identifier":"/us/usc/t22/s4101","parentIdentifier":"/us/usc/t22/ch52/schX","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4101","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t22/s4101/1","parentIdentifier":"/us/usc/t22/s4101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4101%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t22/s4101/1/A","parentIdentifier":"/us/usc/t22/s4101/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4101%2F1%2FA","sourceRelease":"119-100","text":"safeguards the public interest,","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t22/s4101/1/B","parentIdentifier":"/us/usc/t22/s4101/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4101%2F1%2FB","sourceRelease":"119-100","text":"contributes to the effective conduct of public business, and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t22/s4101/1/C","parentIdentifier":"/us/usc/t22/s4101/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4101%2F1%2FC","sourceRelease":"119-100","text":"facilitates and encourages the amicable settlement of disputes between workers and their employers involving conditions of employment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t22/s4101/2","parentIdentifier":"/us/usc/t22/s4101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4101%2F2","sourceRelease":"119-100","text":"the public interest demands the highest standards of performance by members of the Service and the continuous development and implementation of modern and progressive work practices to facilitate improved performance and efficiency; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t22/s4101/3","parentIdentifier":"/us/usc/t22/s4101","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft22%2Fs4101%2F3","sourceRelease":"119-100","text":"the unique conditions of Foreign Service employment require a distinct framework for the development and implementation of modern, constructive, and cooperative relationships between management officials and organizations representing members of the Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
