{"type":"section","nativeType":"section","number":"3635","heading":"Definitions","label":"3635 Definitions","identifier":"/us/usc/t18/s3635","parentIdentifier":"/us/usc/t18/ptII/ch229/schD","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Dyslexia","label":"1 .—Dyslexia","identifier":"/us/usc/t18/s3635/1","parentIdentifier":"/us/usc/t18/s3635","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F1","sourceRelease":"119-100","text":"The term “dyslexia” means an unexpected difficulty in reading for an individual who has the intelligence to be a much better reader, most commonly caused by a difficulty in the phonological processing (the appreciation of the individual sounds of spoken language), which affects the ability of an individual to speak, read, and spell.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Dyslexia screening program","label":"2 .—Dyslexia screening program","identifier":"/us/usc/t18/s3635/2","parentIdentifier":"/us/usc/t18/s3635","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s3635/2/A","parentIdentifier":"/us/usc/t18/s3635/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F2%2FA","sourceRelease":"119-100","text":"evidence-based (as defined in section 8101(21) of the Elementary and Secondary Education Act of 1965 ()) with proven psychometrics for validity;20 U.S.C. 7801(21)","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s3635/2/B","parentIdentifier":"/us/usc/t18/s3635/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F2%2FB","sourceRelease":"119-100","text":"efficient and low-cost; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s3635/2/C","parentIdentifier":"/us/usc/t18/s3635/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F2%2FC","sourceRelease":"119-100","text":"readily available.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Evidence-based recidivism reduction program","label":"3 .—Evidence-based recidivism reduction program","identifier":"/us/usc/t18/s3635/3","parentIdentifier":"/us/usc/t18/s3635","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s3635/3/A","parentIdentifier":"/us/usc/t18/s3635/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FA","sourceRelease":"119-100","text":"has been shown by empirical evidence to reduce recidivism or is based on research indicating that it is likely to be effective in reducing recidivism;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s3635/3/B","parentIdentifier":"/us/usc/t18/s3635/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FB","sourceRelease":"119-100","text":"is designed to help prisoners succeed in their communities upon release from prison; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s3635/3/C","parentIdentifier":"/us/usc/t18/s3635/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t18/s3635/3/C/i","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fi","sourceRelease":"119-100","text":"social learning and communication, interpersonal, anti-bullying, rejection response, and other life skills;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t18/s3635/3/C/ii","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fii","sourceRelease":"119-100","text":"family relationship building, structured parent-child interaction, and parenting skills;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t18/s3635/3/C/iii","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fiii","sourceRelease":"119-100","text":"classes on morals or ethics;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t18/s3635/3/C/iv","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fiv","sourceRelease":"119-100","text":"academic classes;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t18/s3635/3/C/v","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fv","sourceRelease":"119-100","text":"cognitive behavioral treatment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vi","heading":null,"label":"vi","identifier":"/us/usc/t18/s3635/3/C/vi","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fvi","sourceRelease":"119-100","text":"mentoring;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"vii","heading":null,"label":"vii","identifier":"/us/usc/t18/s3635/3/C/vii","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fvii","sourceRelease":"119-100","text":"substance abuse treatment;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"viii","heading":null,"label":"viii","identifier":"/us/usc/t18/s3635/3/C/viii","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fviii","sourceRelease":"119-100","text":"vocational training;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ix","heading":null,"label":"ix","identifier":"/us/usc/t18/s3635/3/C/ix","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fix","sourceRelease":"119-100","text":"faith-based classes or services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"x","heading":null,"label":"x","identifier":"/us/usc/t18/s3635/3/C/x","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fx","sourceRelease":"119-100","text":"civic engagement and reintegrative community services;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xi","heading":null,"label":"xi","identifier":"/us/usc/t18/s3635/3/C/xi","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fxi","sourceRelease":"119-100","text":"a prison job, including through a prison work program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xii","heading":null,"label":"xii","identifier":"/us/usc/t18/s3635/3/C/xii","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fxii","sourceRelease":"119-100","text":"victim impact classes or other restorative justice programs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"xiii","heading":null,"label":"xiii","identifier":"/us/usc/t18/s3635/3/C/xiii","parentIdentifier":"/us/usc/t18/s3635/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F3%2FC%2Fxiii","sourceRelease":"119-100","text":"trauma counseling and trauma-informed support programs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":".—Prisoner","label":"4 .—Prisoner","identifier":"/us/usc/t18/s3635/4","parentIdentifier":"/us/usc/t18/s3635","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F4","sourceRelease":"119-100","text":"The term “prisoner” means a person who has been sentenced to a term of imprisonment pursuant to a conviction for a Federal criminal offense, or a person in the custody of the Bureau of Prisons.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":".—Productive activity","label":"5 .—Productive activity","identifier":"/us/usc/t18/s3635/5","parentIdentifier":"/us/usc/t18/s3635","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F5","sourceRelease":"119-100","text":"The term “productive activity” means either a group or individual activity that is designed to allow prisoners determined as having a minimum or low risk of recidivating to remain productive and thereby maintain a minimum or low risk of recidivating, and may include the delivery of the programs described in paragraph (1) to other prisoners.1So in original. Probably should be “paragraph (3)”.1","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":".—Risk and needs assessment tool","label":"6 .—Risk and needs assessment tool","identifier":"/us/usc/t18/s3635/6","parentIdentifier":"/us/usc/t18/s3635","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F6","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t18/s3635/6/A","parentIdentifier":"/us/usc/t18/s3635/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F6%2FA","sourceRelease":"119-100","text":"as part of the intake process, the risk that a prisoner will recidivate upon release from prison;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t18/s3635/6/B","parentIdentifier":"/us/usc/t18/s3635/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F6%2FB","sourceRelease":"119-100","text":"the recidivism reduction programs that will best minimize the risk that the prisoner will recidivate upon release from prison; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t18/s3635/6/C","parentIdentifier":"/us/usc/t18/s3635/6","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft18%2Fs3635%2F6%2FC","sourceRelease":"119-100","text":"the periodic reassessment of risk that a prisoner will recidivate upon release from prison, based on factors including indicators of progress and of regression, that are dynamic and that can reasonably be expected to change while in prison.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
