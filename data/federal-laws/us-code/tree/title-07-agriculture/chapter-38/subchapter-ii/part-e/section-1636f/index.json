{"type":"section","nativeType":"section","number":"1636f","heading":"Publication of information on retail purchase prices for representative meat products","label":"1636f Publication of information on retail purchase prices for representative meat products","identifier":"/us/usc/t7/s1636f","parentIdentifier":"/us/usc/t7/ch38/schII/ptE","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s1636f/a","parentIdentifier":"/us/usc/t7/s1636f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fa","sourceRelease":"119-100","text":"Beginning not later than 90 days after , the Secretary shall compile and publish at least monthly (weekly, if practicable) information on retail prices for representative food products made from beef, pork, chicken, turkey, veal, or lamb.October 22, 1999","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Information","label":"b Information","identifier":"/us/usc/t7/s1636f/b","parentIdentifier":"/us/usc/t7/s1636f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1636f/b/1","parentIdentifier":"/us/usc/t7/s1636f/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fb%2F1","sourceRelease":"119-100","text":"information on retail prices for each representative food product described in subsection (a); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1636f/b/2","parentIdentifier":"/us/usc/t7/s1636f/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fb%2F2","sourceRelease":"119-100","text":"information on total sales quantity (in pounds and dollars) for each representative food product.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Meat Price Spreads Report","label":"c Meat Price Spreads Report","identifier":"/us/usc/t7/s1636f/c","parentIdentifier":"/us/usc/t7/s1636f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fc","sourceRelease":"119-100","text":"During the period ending 2 years after the initial publication of the report required under subsection (a), the Secretary shall continue to publish the Meat Price Spreads Report in the same manner as the Report was published before .October 22, 1999","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Information collection","label":"d Information collection","identifier":"/us/usc/t7/s1636f/d","parentIdentifier":"/us/usc/t7/s1636f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s1636f/d/1","parentIdentifier":"/us/usc/t7/s1636f/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1636f/d/1/A","parentIdentifier":"/us/usc/t7/s1636f/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F1%2FA","sourceRelease":"119-100","text":"a consistently representative set of retail transactions; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1636f/d/1/B","parentIdentifier":"/us/usc/t7/s1636f/d/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F1%2FB","sourceRelease":"119-100","text":"both prices and sales quantities for the transactions.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Source of information","label":"2 Source of information","identifier":"/us/usc/t7/s1636f/d/2","parentIdentifier":"/us/usc/t7/s1636f/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1636f/d/2/A","parentIdentifier":"/us/usc/t7/s1636f/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F2%2FA","sourceRelease":"119-100","text":"obtain the information from retailers or commercial information sources; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1636f/d/2/B","parentIdentifier":"/us/usc/t7/s1636f/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F2%2FB","sourceRelease":"119-100","text":"use valid statistical sampling procedures, if necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"Adjustments","label":"3 Adjustments","identifier":"/us/usc/t7/s1636f/d/3","parentIdentifier":"/us/usc/t7/s1636f/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s1636f/d/3/A","parentIdentifier":"/us/usc/t7/s1636f/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F3%2FA","sourceRelease":"119-100","text":"the geographic location of consumption;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s1636f/d/3/B","parentIdentifier":"/us/usc/t7/s1636f/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F3%2FB","sourceRelease":"119-100","text":"the location of the principal source of supply;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s1636f/d/3/C","parentIdentifier":"/us/usc/t7/s1636f/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F3%2FC","sourceRelease":"119-100","text":"distribution costs; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s1636f/d/3/D","parentIdentifier":"/us/usc/t7/s1636f/d/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fd%2F3%2FD","sourceRelease":"119-100","text":"such other factors as the Secretary determines reflect a verifiable comparative retail price for a representative food product.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"e","heading":"Administration","label":"e Administration","identifier":"/us/usc/t7/s1636f/e","parentIdentifier":"/us/usc/t7/s1636f","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fe","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s1636f/e/1","parentIdentifier":"/us/usc/t7/s1636f/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fe%2F1","sourceRelease":"119-100","text":"shall collect information under this section only on a voluntary basis; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s1636f/e/2","parentIdentifier":"/us/usc/t7/s1636f/e","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs1636f%2Fe%2F2","sourceRelease":"119-100","text":"shall not impose a penalty on a person for failure to provide the information or otherwise compel a person to provide the information.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
