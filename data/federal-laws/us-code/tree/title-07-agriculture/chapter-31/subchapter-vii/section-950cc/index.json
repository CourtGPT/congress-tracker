{"type":"section","nativeType":"section","number":"950cc","heading":"Public notice, assessments, and reporting requirements","label":"950cc Public notice, assessments, and reporting requirements","identifier":"/us/usc/t7/s950cc","parentIdentifier":"/us/usc/t7/ch31/schVII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Notice requirements","label":"a Notice requirements","identifier":"/us/usc/t7/s950cc/a","parentIdentifier":"/us/usc/t7/s950cc","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s950cc/a/1","parentIdentifier":"/us/usc/t7/s950cc/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950cc/a/1/A","parentIdentifier":"/us/usc/t7/s950cc/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F1%2FA","sourceRelease":"119-100","text":"the identity of the applicant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950cc/a/1/B","parentIdentifier":"/us/usc/t7/s950cc/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s950cc/a/1/B/i","parentIdentifier":"/us/usc/t7/s950cc/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F1%2FB%2Fi","sourceRelease":"119-100","text":"a map of the proposed service area of the applicant; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s950cc/a/1/B/ii","parentIdentifier":"/us/usc/t7/s950cc/a/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the amount and type of support requested by each applicant;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s950cc/a/1/C","parentIdentifier":"/us/usc/t7/s950cc/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F1%2FC","sourceRelease":"119-100","text":"the status of each application; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s950cc/a/1/D","parentIdentifier":"/us/usc/t7/s950cc/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F1%2FD","sourceRelease":"119-100","text":"the estimated number and proportion of service points in the proposed service territory without fixed broadband service, whether terrestrial or wireless;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s950cc/a/2","parentIdentifier":"/us/usc/t7/s950cc/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950cc/a/2/A","parentIdentifier":"/us/usc/t7/s950cc/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F2%2FA","sourceRelease":"119-100","text":"the name of the entity;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950cc/a/2/B","parentIdentifier":"/us/usc/t7/s950cc/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F2%2FB","sourceRelease":"119-100","text":"the type of assistance being received;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s950cc/a/2/C","parentIdentifier":"/us/usc/t7/s950cc/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F2%2FC","sourceRelease":"119-100","text":"the purpose for which the entity is receiving the assistance; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t7/s950cc/a/2/D","parentIdentifier":"/us/usc/t7/s950cc/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F2%2FD","sourceRelease":"119-100","text":"each annual report submitted under subsection (c) (redacted to protect any proprietary information in the report); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s950cc/a/3","parentIdentifier":"/us/usc/t7/s950cc/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fa%2F3","sourceRelease":"119-100","text":"such other information as is sufficient to allow the public to understand assistance provided.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Service area assessment","label":"b Service area assessment","identifier":"/us/usc/t7/s950cc/b","parentIdentifier":"/us/usc/t7/s950cc","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s950cc/b/1","parentIdentifier":"/us/usc/t7/s950cc/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fb%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950cc/b/1/A","parentIdentifier":"/us/usc/t7/s950cc/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fb%2F1%2FA","sourceRelease":"119-100","text":"after giving notice required by subsection (a)(1), afford service providers not less than 45 days to voluntarily submit information required by the Secretary onto the agency’s online mapping tool with respect to areas that are coterminous with the proposed service area of the application (or any parts thereof), such that the Secretary may assess whether the application submitted meets the eligibility requirements under this subchapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950cc/b/1/B","parentIdentifier":"/us/usc/t7/s950cc/b/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fb%2F1%2FB","sourceRelease":"119-100","text":"if no broadband service provider submits information under paragraph (1), consider the number of providers in the proposed service area to be established by using any other data regarding the availability of broadband service that the Secretary may collect or obtain through reasonable efforts.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Assessment of unserved communities","label":"2 Assessment of unserved communities","identifier":"/us/usc/t7/s950cc/b/2","parentIdentifier":"/us/usc/t7/s950cc/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950cc/b/2/A","parentIdentifier":"/us/usc/t7/s950cc/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fb%2F2%2FA","sourceRelease":"119-100","text":"conferring with, and obtaining data from, the Chair of the Federal Communications Commission and the Administrator of the National Telecommunications and Information Administration with respect to the service level in the service area proposed in the application;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950cc/b/2/B","parentIdentifier":"/us/usc/t7/s950cc/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fb%2F2%2FB","sourceRelease":"119-100","text":"reviewing any other source that is relevant to service data validation, as determined by the Secretary; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s950cc/b/2/C","parentIdentifier":"/us/usc/t7/s950cc/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fb%2F2%2FC","sourceRelease":"119-100","text":"performing site-specific testing to verify the unavailability of any retail broadband service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":"FOIA exemption","label":"3 FOIA exemption","identifier":"/us/usc/t7/s950cc/b/3","parentIdentifier":"/us/usc/t7/s950cc/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fb%2F3","sourceRelease":"119-100","text":"For purposes of , information received by the Secretary pursuant to paragraph (1)(A) of this subsection shall be exempt from disclosure pursuant to subsection (b)(2)(B) of such section 552.section 552 of title 5","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Reporting broadband improvements to USDA","label":"c Reporting broadband improvements to USDA","identifier":"/us/usc/t7/s950cc/c","parentIdentifier":"/us/usc/t7/s950cc","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":"In general","label":"1 In general","identifier":"/us/usc/t7/s950cc/c/1","parentIdentifier":"/us/usc/t7/s950cc/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950cc/c/1/A","parentIdentifier":"/us/usc/t7/s950cc/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F1%2FA","sourceRelease":"119-100","text":"the use by the entity of the assistance, including new equipment and capacity enhancements that support high-speed broadband access for educational institutions, health care providers, and public safety service providers (including the estimated number of end users who are currently using or forecasted to use the new or upgraded infrastructure); and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950cc/c/1/B","parentIdentifier":"/us/usc/t7/s950cc/c/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F1%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s950cc/c/1/B/i","parentIdentifier":"/us/usc/t7/s950cc/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F1%2FB%2Fi","sourceRelease":"119-100","text":"the number of service points that will receive new broadband service, existing network service improvements, and facility upgrades resulting from the Federal assistance;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s950cc/c/1/B/ii","parentIdentifier":"/us/usc/t7/s950cc/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F1%2FB%2Fii","sourceRelease":"119-100","text":"the speed of broadband service;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s950cc/c/1/B/iii","parentIdentifier":"/us/usc/t7/s950cc/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F1%2FB%2Fiii","sourceRelease":"119-100","text":"the average price of the most subscribed tier of broadband service in a proposed service area;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iv","heading":null,"label":"iv","identifier":"/us/usc/t7/s950cc/c/1/B/iv","parentIdentifier":"/us/usc/t7/s950cc/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F1%2FB%2Fiv","sourceRelease":"119-100","text":"new subscribers generated from the project; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"v","heading":null,"label":"v","identifier":"/us/usc/t7/s950cc/c/1/B/v","parentIdentifier":"/us/usc/t7/s950cc/c/1/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F1%2FB%2Fv","sourceRelease":"119-100","text":"any metrics the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":"Additional reporting","label":"2 Additional reporting","identifier":"/us/usc/t7/s950cc/c/2","parentIdentifier":"/us/usc/t7/s950cc/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":"Broadband buildout data","label":"A Broadband buildout data","identifier":"/us/usc/t7/s950cc/c/2/A","parentIdentifier":"/us/usc/t7/s950cc/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F2%2FA","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s950cc/c/2/A/i","parentIdentifier":"/us/usc/t7/s950cc/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F2%2FA%2Fi","sourceRelease":"119-100","text":"the date of completion of any project milestone established by the Secretary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s950cc/c/2/A/ii","parentIdentifier":"/us/usc/t7/s950cc/c/2/A","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F2%2FA%2Fii","sourceRelease":"119-100","text":"the date of completion of the project.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":"Reporting for middle mile projects","label":"B Reporting for middle mile projects","identifier":"/us/usc/t7/s950cc/c/2/B","parentIdentifier":"/us/usc/t7/s950cc/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s950cc/c/2/B/i","parentIdentifier":"/us/usc/t7/s950cc/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F2%2FB%2Fi","sourceRelease":"119-100","text":"the use by the entity of the assistance to construct, improve, or acquire middle mile infrastructure;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s950cc/c/2/B/ii","parentIdentifier":"/us/usc/t7/s950cc/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F2%2FB%2Fii","sourceRelease":"119-100","text":"the progress towards meeting the end-user connection plan submitted under ; andsection 950bb–1(d)(1)(A)(iii) of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"iii","heading":null,"label":"iii","identifier":"/us/usc/t7/s950cc/c/2/B/iii","parentIdentifier":"/us/usc/t7/s950cc/c/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F2%2FB%2Fiii","sourceRelease":"119-100","text":"any additional metrics the Secretary determines to be appropriate.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":"Additional reporting","label":"C Additional reporting","identifier":"/us/usc/t7/s950cc/c/2/C","parentIdentifier":"/us/usc/t7/s950cc/c/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fc%2F2%2FC","sourceRelease":"119-100","text":"The Secretary may require any additional reporting and information by any recipient of any broadband assistance under this chapter so as to ensure compliance with this section.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Annual report on broadband projects and service to Congress","label":"d Annual report on broadband projects and service to Congress","identifier":"/us/usc/t7/s950cc/d","parentIdentifier":"/us/usc/t7/s950cc","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s950cc/d/1","parentIdentifier":"/us/usc/t7/s950cc/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F1","sourceRelease":"119-100","text":"the number of applications received and accepted, including any special loan terms or conditions for which the Secretary provided additional assistance to unserved areas;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s950cc/d/2","parentIdentifier":"/us/usc/t7/s950cc/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950cc/d/2/A","parentIdentifier":"/us/usc/t7/s950cc/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F2%2FA","sourceRelease":"119-100","text":"the communities proposed to be served in each application submitted for the fiscal year; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s950cc/d/2/B","parentIdentifier":"/us/usc/t7/s950cc/d/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F2%2FB","sourceRelease":"119-100","text":"the communities served by projects funded by broadband assistance programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s950cc/d/3","parentIdentifier":"/us/usc/t7/s950cc/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F3","sourceRelease":"119-100","text":"the period of time required to approve each loan application under broadband programs;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s950cc/d/4","parentIdentifier":"/us/usc/t7/s950cc/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F4","sourceRelease":"119-100","text":"any outreach activities carried out by the Secretary to encourage entities in rural areas without broadband service to submit applications under this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t7/s950cc/d/5","parentIdentifier":"/us/usc/t7/s950cc/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F5","sourceRelease":"119-100","text":"the method by which the Secretary determines that a service enables a subscriber to originate and receive high-quality voice, data, graphics, and video for purposes of providing broadband service under this chapter;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t7/s950cc/d/6","parentIdentifier":"/us/usc/t7/s950cc/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F6","sourceRelease":"119-100","text":"each broadband service, including the type and speed of broadband service, for which assistance was sought, and each broadband service for which assistance was provided, under this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"7","heading":null,"label":"7","identifier":"/us/usc/t7/s950cc/d/7","parentIdentifier":"/us/usc/t7/s950cc/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F7","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s950cc/d/7/A","parentIdentifier":"/us/usc/t7/s950cc/d/7","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs950cc%2Fd%2F7%2FA","sourceR