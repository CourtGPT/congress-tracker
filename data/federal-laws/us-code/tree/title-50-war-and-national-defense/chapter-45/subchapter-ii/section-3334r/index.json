{"type":"section","nativeType":"section","number":"3334r","heading":"Designation of a chief technology officer within certain elements of the intelligence community","label":"3334r Designation of a chief technology officer within certain elements of the intelligence community","identifier":"/us/usc/t50/s3334r","parentIdentifier":"/us/usc/t50/ch45/schII","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","DefinitionsFor definition of “intelligence community” as used in this section, see , set out as a note under .section 7002 of Pub. L. 118–31section 3003 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Designation authority","label":"a Designation authority","identifier":"/us/usc/t50/s3334r/a","parentIdentifier":"/us/usc/t50/s3334r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fa","sourceRelease":"119-100","text":"The head of each covered element of the intelligence community shall designate a senior official to serve as the chief technology officer of such element.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Covered elements","label":"b Covered elements","identifier":"/us/usc/t50/s3334r/b","parentIdentifier":"/us/usc/t50/s3334r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t50/s3334r/b/1","parentIdentifier":"/us/usc/t50/s3334r/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fb%2F1","sourceRelease":"119-100","text":"The Central Intelligence Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t50/s3334r/b/2","parentIdentifier":"/us/usc/t50/s3334r/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fb%2F2","sourceRelease":"119-100","text":"The Defense Intelligence Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t50/s3334r/b/3","parentIdentifier":"/us/usc/t50/s3334r/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fb%2F3","sourceRelease":"119-100","text":"The Federal Bureau of Investigation.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t50/s3334r/b/4","parentIdentifier":"/us/usc/t50/s3334r/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fb%2F4","sourceRelease":"119-100","text":"The National Geospatial-Intelligence Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t50/s3334r/b/5","parentIdentifier":"/us/usc/t50/s3334r/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fb%2F5","sourceRelease":"119-100","text":"The National Security Agency.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"6","heading":null,"label":"6","identifier":"/us/usc/t50/s3334r/b/6","parentIdentifier":"/us/usc/t50/s3334r/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fb%2F6","sourceRelease":"119-100","text":"The National Reconnaissance Office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Responsibility","label":"c Responsibility","identifier":"/us/usc/t50/s3334r/c","parentIdentifier":"/us/usc/t50/s3334r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fc","sourceRelease":"119-100","text":"The chief technology officer of each covered element of the intelligence community shall be responsible for assisting the head of such element in the identification and adoption of technology to advance mission needs.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":"Prohibition of dual appointment","label":"d Prohibition of dual appointment","identifier":"/us/usc/t50/s3334r/d","parentIdentifier":"/us/usc/t50/s3334r","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft50%2Fs3334r%2Fd","sourceRelease":"119-100","text":"Any chief technology officer designated pursuant to subsection (a) may not concurrently serve as the chief information officer, the chief data officer, or the principal science officer of any element of the intelligence community.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
