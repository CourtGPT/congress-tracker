{"type":"section","nativeType":"section","number":"4810","heading":"Permissive provisions","label":"4810 Permissive provisions","identifier":"/us/usc/t7/s4810","parentIdentifier":"/us/usc/t7/ch79","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810","sourceRelease":"119-100","text":null,"notes":["Statutory Notes and Related Subsidiaries","Effective DateSection effective , see , set out as a note under .Jan. 1, 1986section 1631 of Pub. L. 99–198section 4801 of this title"],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"Recordkeeping and reporting requirements; incidental and necessary terms and conditions","label":"a Recordkeeping and reporting requirements; incidental and necessary terms and conditions","identifier":"/us/usc/t7/s4810/a","parentIdentifier":"/us/usc/t7/s4810","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4810/a/1","parentIdentifier":"/us/usc/t7/s4810/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fa%2F1","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s4810/a/1/A","parentIdentifier":"/us/usc/t7/s4810/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fa%2F1%2FA","sourceRelease":"119-100","text":"maintain and make available for inspection such books and records as may be required by the order; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s4810/a/1/B","parentIdentifier":"/us/usc/t7/s4810/a/1","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fa%2F1%2FB","sourceRelease":"119-100","text":"file reports at the time, in the manner, and having the content prescribed by the order,","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4810/a/2","parentIdentifier":"/us/usc/t7/s4810/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fa%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s4810/a/2/A","parentIdentifier":"/us/usc/t7/s4810/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fa%2F2%2FA","sourceRelease":"119-100","text":"incidental to, and not inconsistent with, the terms and conditions specified in this chapter; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s4810/a/2/B","parentIdentifier":"/us/usc/t7/s4810/a/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fa%2F2%2FB","sourceRelease":"119-100","text":"necessary to effectuate the other provisions of such order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Availability of information to Secretary and Board; confidentiality; disclosure; issuance of general statement, statistical data, or name of violator of order","label":"b Availability of information to Secretary and Board; confidentiality; disclosure; issuance of general statement, statistical data, or name of violator of order","identifier":"/us/usc/t7/s4810/b","parentIdentifier":"/us/usc/t7/s4810","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4810/b/1","parentIdentifier":"/us/usc/t7/s4810/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F1","sourceRelease":"119-100","text":"Information referred to in subsection (a)(1) shall be made available to the Secretary and the Board as is appropriate or necessary for the effectuation, administration, or enforcement of this chapter or an order.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4810/b/2","parentIdentifier":"/us/usc/t7/s4810/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t7/s4810/b/2/A","parentIdentifier":"/us/usc/t7/s4810/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2%2FA","sourceRelease":"119-100","text":"Except as provided in subparagraphs (B) and (C), information obtained under subsection (a)(1) shall be kept confidential by officers or employees of the Department of Agriculture or the Board.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t7/s4810/b/2/B","parentIdentifier":"/us/usc/t7/s4810/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2%2FB","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s4810/b/2/B/i","parentIdentifier":"/us/usc/t7/s4810/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2%2FB%2Fi","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subclause","nativeType":"subclause","number":"I","heading":null,"label":"I","identifier":"/us/usc/t7/s4810/b/2/B/i/I","parentIdentifier":"/us/usc/t7/s4810/b/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2%2FB%2Fi%2FI","sourceRelease":"119-100","text":"brought at the direction or on the request of the Secretary; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subclause","nativeType":"subclause","number":"II","heading":null,"label":"II","identifier":"/us/usc/t7/s4810/b/2/B/i/II","parentIdentifier":"/us/usc/t7/s4810/b/2/B/i","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2%2FB%2Fi%2FII","sourceRelease":"119-100","text":"to which the Secretary or an officer of the United States is a party; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s4810/b/2/B/ii","parentIdentifier":"/us/usc/t7/s4810/b/2/B","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2%2FB%2Fii","sourceRelease":"119-100","text":"if the Secretary considers such information to be relevant to such suit or hearing.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t7/s4810/b/2/C","parentIdentifier":"/us/usc/t7/s4810/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t7/s4810/b/2/C/i","parentIdentifier":"/us/usc/t7/s4810/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2%2FC%2Fi","sourceRelease":"119-100","text":"the issuance of a general statement based on the reports of a number of persons subject to an order, or statistical data collected therefrom, if such statement or data does not identify the information furnished by any person; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t7/s4810/b/2/C/ii","parentIdentifier":"/us/usc/t7/s4810/b/2/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fb%2F2%2FC%2Fii","sourceRelease":"119-100","text":"the publication, by direction of the Secretary, of the name of a person violating an order, together with a statement of the particular provisions of the order violated by such person.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":"Penalty for willful violations","label":"c Penalty for willful violations","identifier":"/us/usc/t7/s4810/c","parentIdentifier":"/us/usc/t7/s4810","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s4810/c/1","parentIdentifier":"/us/usc/t7/s4810/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fc%2F1","sourceRelease":"119-100","text":"subject to a fine of not more than $1,000 or imprisoned for not more than 1 year, or both; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s4810/c/2","parentIdentifier":"/us/usc/t7/s4810/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs4810%2Fc%2F2","sourceRelease":"119-100","text":"if such person is an employee of the Department of Agriculture or the Board, removed from office.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
