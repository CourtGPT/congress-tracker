{"type":"section","nativeType":"section","number":"5663","heading":"Departmental administration system","label":"5663 Departmental administration system","identifier":"/us/usc/t7/s5663","parentIdentifier":"/us/usc/t7/ch87/schIV/ptA","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5663","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":"In general","label":"a In general","identifier":"/us/usc/t7/s5663/a","parentIdentifier":"/us/usc/t7/s5663","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5663%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t7/s5663/a/1","parentIdentifier":"/us/usc/t7/s5663/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5663%2Fa%2F1","sourceRelease":"119-100","text":"specify by regulation the criteria used to evaluate and approve proposals for that program;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t7/s5663/a/2","parentIdentifier":"/us/usc/t7/s5663/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5663%2Fa%2F2","sourceRelease":"119-100","text":"establish a centralized system to permit the Foreign Agricultural Service to provide the history and current status of any proposal;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t7/s5663/a/3","parentIdentifier":"/us/usc/t7/s5663/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5663%2Fa%2F3","sourceRelease":"119-100","text":"provide for regular audits of program transactions to determine compliance with program objectives and requirements; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t7/s5663/a/4","parentIdentifier":"/us/usc/t7/s5663/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5663%2Fa%2F4","sourceRelease":"119-100","text":"establish criteria to evaluate loans eligible for guarantees by the Commodity Credit Corporation, so as to ensure that the Corporation does not assume undue risk in providing such guarantees.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":"Accessibility of information","label":"b Accessibility of information","identifier":"/us/usc/t7/s5663/b","parentIdentifier":"/us/usc/t7/s5663","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft7%2Fs5663%2Fb","sourceRelease":"119-100","text":"Information pertaining to the status of a particular proposal shall be retrievable within the central system by appropriate categories, as determined appropriate by the Secretary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
