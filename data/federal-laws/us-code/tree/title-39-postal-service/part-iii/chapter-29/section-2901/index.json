{"type":"section","nativeType":"section","number":"2901","heading":"Definitions","label":"2901 Definitions","identifier":"/us/usc/t39/s2901","parentIdentifier":"/us/usc/t39/ptIII/ch29","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2901","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—Excess property","label":"1 .—Excess property","identifier":"/us/usc/t39/s2901/1","parentIdentifier":"/us/usc/t39/s2901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2901%2F1","sourceRelease":"119-100","text":"The term “excess property” means any postal property that the Postal Service determines is not required to meet the needs or responsibilities of the Postal Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Postal property","label":"2 .—Postal property","identifier":"/us/usc/t39/s2901/2","parentIdentifier":"/us/usc/t39/s2901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2901%2F2","sourceRelease":"119-100","text":"The term “postal property” means any property owned or leased by the Postal Service.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Underutilized property","label":"3 .—Underutilized property","identifier":"/us/usc/t39/s2901/3","parentIdentifier":"/us/usc/t39/s2901","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2901%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t39/s2901/3/A","parentIdentifier":"/us/usc/t39/s2901/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2901%2F3%2FA","sourceRelease":"119-100","text":"irregularly or intermittently by the Postal Service for program purposes of the Postal Service; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t39/s2901/3/B","parentIdentifier":"/us/usc/t39/s2901/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft39%2Fs2901%2F3%2FB","sourceRelease":"119-100","text":"for program purposes that can be satisfied only with a portion of the property.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
