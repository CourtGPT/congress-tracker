{"type":"section","nativeType":"section","number":"7906","heading":"Services of post-combat case coordinators","label":"7906 Services of post-combat case coordinators","identifier":"/us/usc/t5/s7906","parentIdentifier":"/us/usc/t5/ptIII/sptF/ch79","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Definitions","label":"a .—Definitions","identifier":"/us/usc/t5/s7906/a","parentIdentifier":"/us/usc/t5/s7906","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fa","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s7906/a/1","parentIdentifier":"/us/usc/t5/s7906/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fa%2F1","sourceRelease":"119-100","text":"the terms “employee”, “agency”, “injury”, “war-risk hazard”, and “hostile force or individual” have the meanings given those terms in section 8101; and1So in original. The definition of “agency” does not appear in .1section 8101 of this title","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s7906/a/2","parentIdentifier":"/us/usc/t5/s7906/a","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fa%2F2","sourceRelease":"119-100","text":"the term “qualified employee” means an employee as described in subsection (b).","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Requirement","label":"b .—Requirement","identifier":"/us/usc/t5/s7906/b","parentIdentifier":"/us/usc/t5/s7906","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fb","sourceRelease":"119-100","text":"The head of each agency shall, in a manner consistent with the guidelines prescribed under subsection (c), provide for the assignment of a post-combat case coordinator in the case of any employee of such agency who suffers an injury or disability incurred, or an illness contracted, while in the performance of such employee’s duties, as a result of a war-risk hazard or during or as a result of capture, detention, or other restraint by a hostile force or individual.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Guidelines","label":"c .—Guidelines","identifier":"/us/usc/t5/s7906/c","parentIdentifier":"/us/usc/t5/s7906","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fc","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s7906/c/1","parentIdentifier":"/us/usc/t5/s7906/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fc%2F1","sourceRelease":"119-100","text":"acting as the main point of contact for qualified employees seeking administrative guidance or assistance relating to benefits under chapter 81 or 89;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s7906/c/2","parentIdentifier":"/us/usc/t5/s7906/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fc%2F2","sourceRelease":"119-100","text":"assisting qualified employees in the collection of documentation or other supporting evidence for the expeditious processing of claims under chapter 81 or 89;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":null,"label":"3","identifier":"/us/usc/t5/s7906/c/3","parentIdentifier":"/us/usc/t5/s7906/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fc%2F3","sourceRelease":"119-100","text":"assisting qualified employees in connection with the receipt of prescribed medical care and the coordination of benefits under chapter 81 or 89;","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"4","heading":null,"label":"4","identifier":"/us/usc/t5/s7906/c/4","parentIdentifier":"/us/usc/t5/s7906/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fc%2F4","sourceRelease":"119-100","text":"resolving problems relating to the receipt of benefits under chapter 81 or 89; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"5","heading":null,"label":"5","identifier":"/us/usc/t5/s7906/c/5","parentIdentifier":"/us/usc/t5/s7906/c","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fc%2F5","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t5/s7906/c/5/A","parentIdentifier":"/us/usc/t5/s7906/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fc%2F5%2FA","sourceRelease":"119-100","text":"for post-traumatic stress disorder or other similar disorder stemming from combat trauma; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t5/s7906/c/5/B","parentIdentifier":"/us/usc/t5/s7906/c/5","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fc%2F5%2FB","sourceRelease":"119-100","text":"for suicidal or homicidal thoughts or behaviors.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Duration","label":"d .—Duration","identifier":"/us/usc/t5/s7906/d","parentIdentifier":"/us/usc/t5/s7906","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fd","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":null,"label":"1","identifier":"/us/usc/t5/s7906/d/1","parentIdentifier":"/us/usc/t5/s7906/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fd%2F1","sourceRelease":"119-100","text":"such employee accepts or declines a reasonable offer of employment in a position in the employee’s agency for which the employee is qualified, which is not lower than 2 grades (or pay levels) below the employee’s grade (or pay level) before the occurrence or onset of the injury, disability, or illness (as referred to in subsection (a)), and which is within the employee’s commuting area; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":null,"label":"2","identifier":"/us/usc/t5/s7906/d/2","parentIdentifier":"/us/usc/t5/s7906/d","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft5%2Fs7906%2Fd%2F2","sourceRelease":"119-100","text":"such employee gives written notice, in such manner as the employing agency prescribes, that those services are no longer desired or necessary.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}
