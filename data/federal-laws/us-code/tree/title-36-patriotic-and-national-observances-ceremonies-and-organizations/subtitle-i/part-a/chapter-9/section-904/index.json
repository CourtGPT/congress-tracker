{"type":"section","nativeType":"section","number":"904","heading":"Hostage and Wrongful Detainee flag","label":"904 Hostage and Wrongful Detainee flag","identifier":"/us/usc/t36/s904","parentIdentifier":"/us/usc/t36/stI/ptA/ch9","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subsection","nativeType":"subsection","number":"a","heading":".—Designation","label":"a .—Designation","identifier":"/us/usc/t36/s904/a","parentIdentifier":"/us/usc/t36/s904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fa","sourceRelease":"119-100","text":"The Hostage and Wrongful Detainee flag championed by the Bring Our Families Home Campaign is designated as the symbol of the commitment of the United States to recognizing, and prioritizing the freedom of, citizens and lawful permanent residents of the United States held as hostages or wrongfully detained abroad.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"b","heading":".—Required Display","label":"b .—Required Display","identifier":"/us/usc/t36/s904/b","parentIdentifier":"/us/usc/t36/s904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"paragraph","nativeType":"paragraph","number":"1","heading":".—In general","label":"1 .—In general","identifier":"/us/usc/t36/s904/b/1","parentIdentifier":"/us/usc/t36/s904/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F1","sourceRelease":"119-100","text":"The Hostage and Wrongful Detainee flag shall be displayed at the locations specified in paragraph (3) on the days specified in paragraph (2).","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"paragraph","nativeType":"paragraph","number":"2","heading":".—Days specified","label":"2 .—Days specified","identifier":"/us/usc/t36/s904/b/2","parentIdentifier":"/us/usc/t36/s904/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F2","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t36/s904/b/2/A","parentIdentifier":"/us/usc/t36/s904/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F2%2FA","sourceRelease":"119-100","text":"U.S. Hostage and Wrongful Detainee Day, March 9.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t36/s904/b/2/B","parentIdentifier":"/us/usc/t36/s904/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F2%2FB","sourceRelease":"119-100","text":"Flag Day, June 14.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t36/s904/b/2/C","parentIdentifier":"/us/usc/t36/s904/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F2%2FC","sourceRelease":"119-100","text":"Independence Day, July 4.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"D","heading":null,"label":"D","identifier":"/us/usc/t36/s904/b/2/D","parentIdentifier":"/us/usc/t36/s904/b/2","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F2%2FD","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t36/s904/b/2/D/i","parentIdentifier":"/us/usc/t36/s904/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F2%2FD%2Fi","sourceRelease":"119-100","text":"returns to the United States from being held hostage or wrongfully detained abroad; or","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t36/s904/b/2/D/ii","parentIdentifier":"/us/usc/t36/s904/b/2/D","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F2%2FD%2Fii","sourceRelease":"119-100","text":"dies while being held hostage or wrongfully detained abroad.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]},{"type":"paragraph","nativeType":"paragraph","number":"3","heading":".—Locations specified","label":"3 .—Locations specified","identifier":"/us/usc/t36/s904/b/3","parentIdentifier":"/us/usc/t36/s904/b","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F3","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"subparagraph","nativeType":"subparagraph","number":"A","heading":null,"label":"A","identifier":"/us/usc/t36/s904/b/3/A","parentIdentifier":"/us/usc/t36/s904/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F3%2FA","sourceRelease":"119-100","text":"The Capitol.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"B","heading":null,"label":"B","identifier":"/us/usc/t36/s904/b/3/B","parentIdentifier":"/us/usc/t36/s904/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F3%2FB","sourceRelease":"119-100","text":"The White House.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subparagraph","nativeType":"subparagraph","number":"C","heading":null,"label":"C","identifier":"/us/usc/t36/s904/b/3/C","parentIdentifier":"/us/usc/t36/s904/b/3","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F3%2FC","sourceRelease":"119-100","text":null,"notes":[],"amendments":[],"effectiveDate":null,"children":[{"type":"clause","nativeType":"clause","number":"i","heading":null,"label":"i","identifier":"/us/usc/t36/s904/b/3/C/i","parentIdentifier":"/us/usc/t36/s904/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F3%2FC%2Fi","sourceRelease":"119-100","text":"the Secretary of State; and","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"clause","nativeType":"clause","number":"ii","heading":null,"label":"ii","identifier":"/us/usc/t36/s904/b/3/C/ii","parentIdentifier":"/us/usc/t36/s904/b/3/C","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fb%2F3%2FC%2Fii","sourceRelease":"119-100","text":"the Secretary of Defense.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}]}]},{"type":"subsection","nativeType":"subsection","number":"c","heading":".—Display To Be in a Manner Visible to the Public","label":"c .—Display To Be in a Manner Visible to the Public","identifier":"/us/usc/t36/s904/c","parentIdentifier":"/us/usc/t36/s904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fc","sourceRelease":"119-100","text":"Display of the Hostage and Wrongful Detainee flag pursuant to this section shall be in a manner designed to ensure visibility to the public.","notes":[],"amendments":[],"effectiveDate":null,"children":[]},{"type":"subsection","nativeType":"subsection","number":"d","heading":".—Limitation","label":"d .—Limitation","identifier":"/us/usc/t36/s904/d","parentIdentifier":"/us/usc/t36/s904","sourceUrl":"https://uscode.house.gov/view.xhtml?req=%2Fus%2Fusc%2Ft36%2Fs904%2Fd","sourceRelease":"119-100","text":"This section may not be construed or applied so as to require any employee to report to work solely for the purpose of providing for the display of the Hostage and Wrongful Detainee flag.","notes":[],"amendments":[],"effectiveDate":null,"children":[]}]}
